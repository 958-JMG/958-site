---
import V2bLayout from '../../layouts/V2bLayout.astro';
import Icon from '../../components/v2/Icon.astro';
import V2cHeader from '../../components/v2/V2cHeader.astro';
import V2cFooter from '../../components/v2/V2cFooter.astro';
import PortesEntree from '../../components/v2/PortesEntree.astro';
import CTAStickyMobile from '../../components/v2/CTAStickyMobile.astro';

const etapes = [
  {
    n: '01',
    titre: 'Audit',
    duree: '1 à 2 jours · sous accord de confidentialité',
    intro: "Immersion dans votre quotidien. Entretiens équipe. Cartographie des processus. Identification des irritants.",
    livre: "Un rapport de 15 à 25 pages. État des lieux, diagnostic, priorités hiérarchisées, estimation d'impact par chantier.",
    change: "Vous savez où l'IA a du sens chez vous. Et où elle n'en a pas. Vous pouvez vous arrêter là.",
  },
  {
    n: '02',
    titre: 'Structuration',
    duree: '1 à 3 semaines',
    intro: "Choix des outils. Architecture des flux. Rédaction des prompts. Schéma de base. Cadrage des workflows.",
    livre: "Un plan d'implémentation chiffré, daté, validable. Par qui, en combien de temps, pour combien.",
    change: "Vous signez en connaissance de cause. Aucune surprise.",
  },
  {
    n: '03',
    titre: 'Implémentation',
    duree: '3 à 12 semaines',
    intro: "Construction du cockpit. Bases, automatisations, intégrations. Tests en conditions réelles. Itérations jusqu'à validation.",
    livre: "Un système fonctionnel, documenté, prêt à tourner.",
    change: "Votre entreprise produit différemment. Les irritants identifiés ont disparu.",
  },
  {
    n: '04',
    titre: 'Accompagnement',
    duree: '3 mois à l’infini',
    intro: "Formation sur site. Points réguliers. Ajustements. Nouveaux chantiers. Support réactif.",
    livre: "Un partenaire. Pas un prestataire qui disparaît après la facture.",
    change: "Vous devenez autonomes. L'IA devient un réflexe interne, pas une dépendance externe.",
  },
];

const spari = [
  { l: 'S', mot: 'Scénario',     d: "Le contexte précis dans lequel l'IA intervient." },
  { l: 'P', mot: 'Problème',     d: "Le résultat attendu, formulé comme un problème à résoudre." },
  { l: 'A', mot: 'Action',       d: "Ce que l'IA doit faire, étape par étape." },
  { l: 'R', mot: 'Résultat',     d: "Le format et les critères de qualité de la sortie." },
  { l: 'I', mot: 'Instructions', d: "Les garde-fous, les interdits, les exigences." },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://www.958.fr/methode/#service',
  serviceType: 'Implémentation IA en entreprise',
  name: 'Méthode 9·58 — Audit, structuration, implémentation IA',
  description: "Méthode propriétaire SPARI en 4 étapes : audit, structuration, implémentation, accompagnement. Pour installer l'IA dans une PME sans dépendance.",
  provider: { '@id': 'https://www.958.fr/#organization' },
  areaServed: { '@type': 'Country', name: 'France' },
  audience: { '@type': 'BusinessAudience', audienceType: 'Dirigeants de TPE et PME' },
  category: 'Conseil en intelligence artificielle',
  offers: {
    '@type': 'Offer',
    priceCurrency: 'EUR',
    price: '900',
    availability: 'https://schema.org/InStock',
    url: 'https://www.958.fr/diagnostic/',
    description: "Audit IA forfait 1 200 € HT — 900 € HT en lancement jusqu'au 31 juillet 2026.",
    priceValidUntil: '2026-07-31',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Étapes 9·58',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Audit IA' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Structuration & roadmap IA' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Implémentation IA' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Accompagnement IA' } },
    ],
  },
};
---

<V2bLayout
  title="Méthode — Audit, structuration, implémentation IA"
  description="Ma méthode en 4 étapes et le cadre SPARI. Audit, structuration, implémentation, accompagnement. Pour installer l'IA dans une PME sans jargon ni dépendance."
>
  <V2cHeader />

  <!-- JSON-LD Service -->
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- HERO -->
  <section class="hero">
    <div class="container is-default">
      <p class="eyebrow reveal">Méthode</p>
      <h1 class="manifesto reveal">
        Transformer une entreprise<br>
        avec l'IA <em>ne s'improvise pas.</em>
      </h1>
      <p class="killer-line reveal">
        Voici mon cadre.<br>
        Le même pour tous mes clients.
      </p>
      <p class="lead reveal">
        De l'audit à l'autonomie. Quatre étapes claires,
        un cadre SPARI pour les prompts, et la promesse de
        <strong>vous laisser autonomes</strong> — pas accrochés à mon agenda.
      </p>
    </div>
  </section>

  <!-- 4 ÉTAPES -->
  <section class="section section--soft" aria-labelledby="etapes-title">
    <div class="container">
      <div class="section-head">
        <h2 id="etapes-title" class="reveal section-h2">
          Quatre étapes. <em>Aucune dépendance.</em>
        </h2>
        <p class="reveal section-sub">
          À chaque étape, vous pouvez vous arrêter. À chaque étape, vous
          récupérez un livrable utilisable, même sans la suite.
        </p>
      </div>

      <ol class="etapes-list">
        {etapes.map((e) => (
          <li class="etape-block reveal">
            <header class="etape-block-head">
              <span class="etape-block-n">{e.n}</span>
              <div>
                <h3 class="etape-block-h">{e.titre}</h3>
                <p class="etape-block-duree">{e.duree}</p>
              </div>
            </header>
            <dl class="etape-dl">
              <div>
                <dt>Ce que je fais</dt>
                <dd>{e.intro}</dd>
              </div>
              <div>
                <dt>Ce que vous recevez</dt>
                <dd>{e.livre}</dd>
              </div>
              <div>
                <dt>Ce qui change</dt>
                <dd class="etape-change">{e.change}</dd>
              </div>
            </dl>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- SPARI -->
  <section class="section" aria-labelledby="spari-title">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Cadre propriétaire</p>
        <h2 id="spari-title" class="reveal section-h2">
          <em>SPARI</em> — écrire un prompt qui tient.
        </h2>
        <p class="reveal section-sub">
          Chaque prompt que j'écris suit ce cadre. Chaque prompt que vos
          équipes écriront après mon passage suivra ce cadre. C'est ça,
          l'autonomie : un cadre se transmet, un prompt inspiré non.
        </p>
      </div>

      <ul class="spari-grid reveal-stagger" role="list">
        {spari.map((s) => (
          <li class="spari-item reveal">
            <span class="spari-letter">{s.l}</span>
            <p class="spari-mot">{s.mot}</p>
            <p class="spari-desc">{s.d}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 3 PORTES D'ENTRÉE -->
  <PortesEntree variant="soft" />

  <!-- CTA FINAL -->
  <section class="section section--accent" aria-labelledby="cta-title">
    <div class="container is-default" style="text-align: center;">
      <h2 id="cta-title" class="reveal section-h2" style="color: var(--ivoire);">
        Savoir si cette méthode<br>
        <em>s'applique à votre entreprise.</em>
      </h2>
      <p class="reveal lead" style="color: var(--ivoire); max-width: 56ch; margin: var(--s-5) auto;">
        Échange de 30 minutes · Sans engagement · Réponse sous 48 h
      </p>
      <div class="reveal" style="margin-top: var(--s-6);">
        <a href="/diagnostic/" class="btn btn--lg btn-on-accent">
          Demander un diagnostic
          <Icon name="arrow-right" size={18} class="arrow" />
        </a>
      </div>
    </div>
  </section>

  <V2cFooter />
  <CTAStickyMobile anchorHide="portes" />
</V2bLayout>

<style>
  .hero { padding-block: var(--s-10) var(--s-9); }
  .hero .eyebrow { margin-bottom: var(--s-5); }
  .hero .manifesto { margin-bottom: var(--s-5); max-width: 18ch; }
  .hero .killer-line { margin-bottom: var(--s-6); max-width: 22ch; }
  .hero .lead { max-width: 56ch; }

  .section-head { max-width: 62ch; margin-bottom: var(--s-8); }
  .section-h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw + 0.5rem, 3rem);
    line-height: 1.1; letter-spacing: var(--tr-tighter);
    color: var(--ivoire); font-weight: 400;
    margin: 0 0 var(--s-3) 0;
  }
  .section-h2 em { color: var(--cuivre); font-style: italic; }
  .section-sub {
    font-size: var(--step-1); line-height: var(--lh-loose);
    color: var(--ink-2); margin: 0; max-width: 56ch;
  }

  /* Étapes */
  .etapes-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: var(--s-6);
  }
  .etape-block {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: var(--s-6);
  }
  .etape-block-head {
    display: flex; align-items: baseline; gap: var(--s-4);
    margin-bottom: var(--s-5);
    padding-bottom: var(--s-4);
    border-bottom: 1px solid var(--line);
  }
  .etape-block-n {
    font-family: var(--font-mono);
    font-size: var(--step-2);
    color: var(--cuivre);
    letter-spacing: -0.02em;
  }
  .etape-block-h {
    font-family: var(--font-display);
    font-size: var(--step-3);
    color: var(--ivoire);
    margin: 0;
    line-height: 1.15;
  }
  .etape-block-duree {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-3);
    margin: 4px 0 0;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .etape-dl {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-5);
    margin: 0;
  }
  @media (max-width: 720px) {
    .etape-dl { grid-template-columns: 1fr; gap: var(--s-4); }
  }
  .etape-dl > div { margin: 0; }
  .etape-dl dt {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--cuivre);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 var(--s-2) 0;
  }
  .etape-dl dd {
    font-size: var(--step-0);
    line-height: var(--lh-loose);
    color: var(--ink-2);
    margin: 0;
  }
  .etape-change {
    color: var(--ivoire) !important;
    font-style: italic;
    font-family: var(--font-display);
  }

  /* SPARI grid */
  .spari-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--s-4);
  }
  @media (max-width: 960px) {
    .spari-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .spari-grid { grid-template-columns: 1fr; }
  }
  .spari-item {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: var(--s-5);
    text-align: center;
  }
  .spari-letter {
    display: inline-flex; align-items: center; justify-content: center;
    width: 48px; height: 48px;
    background: var(--cuivre-soft);
    color: var(--cuivre);
    border-radius: 50%;
    border: 1px solid var(--cuivre);
    font-family: var(--font-display);
    font-size: var(--step-2);
    margin-bottom: var(--s-3);
  }
  .spari-mot {
    font-family: var(--font-display);
    font-size: var(--step-1);
    color: var(--ivoire);
    margin: 0 0 var(--s-2);
  }
  .spari-desc {
    font-size: var(--step--1);
    line-height: var(--lh-loose);
    color: var(--ink-2);
    margin: 0;
  }

  /* Portes d'entrée */
  .portes-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: var(--s-3);
  }
  .porte {
    display: flex; align-items: center; gap: var(--s-4);
    padding: var(--s-4) var(--s-5);
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 12px;
    color: var(--ivoire);
    text-decoration: none;
    transition: border-color var(--dur-1) var(--ease), background var(--dur-1) var(--ease);
  }
  .porte:hover {
    border-color: var(--cuivre);
    background: var(--bg-3);
  }
  .porte > svg:first-of-type {
    color: var(--cuivre);
    flex-shrink: 0;
  }
  .porte > div {
    flex: 1;
    display: flex; flex-direction: column; gap: 2px;
  }
  .porte strong {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-1);
    color: var(--ivoire);
  }
  .porte span {
    font-size: var(--step--1);
    color: var(--ink-3);
  }
  .porte .arrow {
    color: var(--cuivre);
    flex-shrink: 0;
    transition: transform var(--dur-1) var(--ease);
  }
  .porte:hover .arrow { transform: translateX(3px); }

  /* CTA accent */
  .section--accent {
    background: var(--cuivre);
    padding-block: var(--s-9);
  }
  .btn-on-accent {
    background: var(--ivoire);
    color: var(--cuivre);
    border-color: var(--ivoire);
  }
  .btn-on-accent:hover {
    background: var(--bg);
    color: var(--ivoire);
    border-color: var(--bg);
  }
</style>

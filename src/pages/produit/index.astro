---
import V2bLayout from '../../layouts/V2bLayout.astro';
import Icon from '../../components/v2/Icon.astro';
import V2cHeader from '../../components/v2/V2cHeader.astro';
import V2cFooter from '../../components/v2/V2cFooter.astro';
import PortesEntree from '../../components/v2/PortesEntree.astro';
import Manifeste958 from '../../components/v2/Manifeste958.astro';
import OutilsCombines from '../../components/v2/OutilsCombines.astro';

const piliers = [
  {
    n: '01',
    icon: 'monitor',
    titre: "L'écran.",
    sous: "Tout votre métier, au même endroit, en temps réel.",
    body: "Vos devis, vos mandats, vos AG, vos chantiers, votre tréso : un seul écran. Pas dix logiciels, pas trois Excel, pas un poste de travail figé sur 2015.",
    points: [
      "Un cockpit conçu sur vos données et vos workflows réels — pas un dashboard générique.",
      "Tableaux interactifs, kanban, calendrier : ce qui sert votre métier, pas ce qui décore.",
      "Accessible PC, Mac, iPhone — vos mains où elles veulent travailler.",
    ],
  },
  {
    n: '02',
    icon: 'sparkles',
    titre: "La couche IA.",
    sous: "Elle trie, rédige, anticipe — à votre ton.",
    body: "L'IA travaille pour vous dans le cockpit, pas dans une fenêtre à côté. Elle lit vos mails, prépare vos brouillons, qualifie vos pipelines, surveille votre tréso, alerte sur les risques.",
    points: [
      "Tri automatique des mails par urgence, sujet, client — à votre style.",
      "Rédaction assistée : devis, mandats, comptes-rendus, brouillons de réponse.",
      "Anticipation : retards de paiement, fins de chantier, dossiers en sommeil.",
      "Assistant IA branché sur vos données métier — il connaît votre contexte.",
    ],
  },
  {
    n: '03',
    icon: 'shield',
    titre: "La souveraineté.",
    sous: "À votre nom. Vous décidez de tout.",
    body: "Vos données, vos prompts, vos workflows vivent chez vous — pas dans un datacenter texan. Mistral en moteur IA, Scaleway pour l'hébergement, n8n pour l'orchestration. Tout reste en Europe, traçable, rapatriable.",
    points: [
      "Hébergement Europe (Scaleway / OVH / Hetzner selon contexte).",
      "Modèles IA souverains (Mistral) par défaut — OpenAI seulement si vous le demandez.",
      "Vos prompts, vos workflows, vos automatisations : c'est votre actif, pas notre service.",
      "Vous pouvez emporter votre cockpit — code livré, accès admin total.",
    ],
  },
];

const compareItems = [
  {
    titre: "Les logiciels métier classiques",
    body: "Vous payez 200 €/mois pour utiliser 25 % d'un outil. Les 75 % restants — modules génériques, fonctions qui ne servent jamais — sont conçus pour le voisin. Et vos données dorment dans leur cloud.",
  },
  {
    titre: "Le cockpit 9·58",
    body: "Pour le même budget annuel, on construit l'écran qui couvre 100 % de votre métier. Vos données restent chez vous, votre IA parle votre langue, votre équipe travaille avec — pas malgré l'outil.",
  },
];
---

<V2bLayout
  title="Le produit — Cockpit IA souverain sur-mesure"
  description="Le cockpit 9·58 : un écran qui rassemble votre métier, une couche IA qui travaille à votre ton, une souveraineté qui vous appartient. Pour TPE-PME du bâtiment et de l'immobilier 360°."
>
  <V2cHeader currentSection="produit" />

  <!-- HERO -->
  <section class="hero">
    <div class="container is-default">
      <p class="eyebrow reveal">Le produit</p>
      <h1 class="manifesto reveal">
        Un écran.<br>
        <em>Le vôtre.</em>
      </h1>
      <p class="killer-line reveal">
        Trois briques.<br>
        Aucune dépendance.
      </p>
      <p class="lead reveal">
        Le cockpit 9·58 ne ressemble à aucun SaaS du marché —
        parce qu'il est conçu pour <strong>votre métier réel</strong>,
        avec <strong>vos données</strong>, sous <strong>votre contrôle</strong>.
      </p>
      <div class="hero-ctas reveal">
        <a href="/diagnostic/" class="btn btn--primary btn--lg">
          Demander un diagnostic
          <Icon name="arrow-right" size={18} class="arrow" />
        </a>
        <a href="https://demo.958.fr" target="_blank" rel="noopener" class="btn btn--ghost btn--lg">
          Voir une démo sectorielle
          <Icon name="arrow-up-right" size={18} class="arrow" />
        </a>
      </div>
    </div>
  </section>

  <!-- 3 PILIERS DÉTAILLÉS -->
  <section class="section section--soft" aria-labelledby="piliers-title">
    <div class="container">
      <div class="section-head">
        <h2 id="piliers-title" class="reveal section-h2">
          Trois briques. <em>Une seule promesse.</em>
        </h2>
        <p class="reveal section-sub">
          Aucune des trois sans les deux autres. C'est ce qui change tout
          par rapport à un SaaS générique ou un agent ChatGPT en marque blanche.
        </p>
      </div>

      <ol class="piliers-list">
        {piliers.map((p) => (
          <li class="pilier-block reveal">
            <header class="pilier-block-head">
              <span class="pilier-block-n">{p.n}</span>
              <div class="pilier-block-icon">
                <Icon name={p.icon} size={28} strokeWidth={1.5} />
              </div>
              <div>
                <h3 class="pilier-block-h">{p.titre}</h3>
                <p class="pilier-block-sub">{p.sous}</p>
              </div>
            </header>
            <p class="pilier-block-body">{p.body}</p>
            <ul class="pilier-items">
              {p.points.map((point) => (
                <li>
                  <Icon name="check" size={18} strokeWidth={2.5} class="check" />
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- AVEC QUELS OUTILS — preuve neutralité + rassurance -->
  <OutilsCombines variant="plain" />

  <!-- MANIFESTE WHY — Pourquoi 9·58 & Ça fait Tilt® -->
  <Manifeste958 variant="soft" />

  <!-- VS MARCHÉ -->
  <section class="section" aria-labelledby="vs-title">
    <div class="container is-default">
      <div class="section-head">
        <h2 id="vs-title" class="reveal section-h2">
          La différence, <em>tenue en une ligne.</em>
        </h2>
      </div>
      <div class="vs-grid reveal">
        {compareItems.map((c, i) => (
          <article class={i === 0 ? "vs-card vs-card--before" : "vs-card vs-card--after"}>
            <p class="vs-tag">{i === 0 ? 'Hier' : 'Maintenant'}</p>
            <h3 class="vs-h">{c.titre}</h3>
            <p class="vs-body">{c.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 3 PORTES D'ENTRÉE -->
  <PortesEntree variant="soft" />

  <!-- CTA FINAL -->
  <section class="section section--accent" aria-labelledby="cta-title">
    <div class="container is-default" style="text-align: center;">
      <h2 id="cta-title" class="reveal section-h2" style="color: var(--ivoire);">
        Votre cockpit existe déjà <em>quelque part</em>.<br>
        Il manque juste qu'on le construise.
      </h2>
      <p class="reveal lead" style="color: var(--ivoire); max-width: 56ch; margin: var(--s-5) auto;">
        Un audit d'un jour pour voir si 9·58 est la bonne réponse.
        Vous repartez avec un rapport, même si on ne travaille pas ensemble.
      </p>
      <div class="reveal" style="margin-top: var(--s-6); display: inline-flex; gap: var(--s-4); flex-wrap: wrap; justify-content: center;">
        <a href="/diagnostic/" class="btn btn--lg btn-on-accent">
          Demander un diagnostic
          <Icon name="arrow-right" size={18} class="arrow" />
        </a>
        <a href="/methode/" class="btn btn--ghost btn--lg btn--on-accent-ghost">
          Voir la méthode
          <Icon name="arrow-right" size={18} class="arrow" />
        </a>
      </div>
    </div>
  </section>

  <V2cFooter />
</V2bLayout>

<style>
  .hero {
    padding-block: var(--s-10) var(--s-9);
  }
  .hero .eyebrow { margin-bottom: var(--s-5); }
  .hero .manifesto { margin-bottom: var(--s-5); max-width: 14ch; }
  .hero .killer-line { margin-bottom: var(--s-6); max-width: 20ch; }
  .hero .lead { max-width: 56ch; }
  .hero-ctas {
    display: flex; gap: var(--s-3); flex-wrap: wrap;
    margin-top: var(--s-7);
  }

  /* Section head */
  .section-head { max-width: 62ch; margin-bottom: var(--s-8); }
  .section-h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw + 0.5rem, 3rem);
    line-height: 1.1; letter-spacing: var(--tr-tighter);
    color: var(--ivoire); font-weight: 400;
    margin: 0 0 var(--s-3) 0;
  }
  .section-h2 em { color: var(--cuivre); font-style: italic; }
  .section-sub {
    font-size: var(--step-1); line-height: var(--lh-loose);
    color: var(--ink-2); margin: 0; max-width: 56ch;
  }

  /* Liste piliers */
  .piliers-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: var(--s-7);
  }
  .pilier-block {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: var(--s-6) var(--s-6);
    transition: border-color var(--dur-1) var(--ease);
  }
  .pilier-block:hover { border-color: var(--cuivre); }
  .pilier-block-head {
    display: flex; align-items: flex-start; gap: var(--s-4);
    margin-bottom: var(--s-4);
  }
  .pilier-block-n {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.08em;
    color: var(--cuivre);
    flex-shrink: 0;
    padding-top: 6px;
  }
  .pilier-block-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px;
    background: var(--cuivre-soft);
    color: var(--cuivre);
    border-radius: 50%;
    border: 1px solid var(--cuivre);
    flex-shrink: 0;
  }
  .pilier-block-h {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw + 0.3rem, 2rem);
    color: var(--ivoire);
    margin: 0;
    letter-spacing: var(--tr-tight);
  }
  .pilier-block-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-1);
    color: var(--cuivre);
    margin: 4px 0 0;
    line-height: 1.3;
  }
  .pilier-block-body {
    font-size: var(--step-1);
    line-height: var(--lh-loose);
    color: var(--ink-2);
    margin: 0 0 var(--s-4) 0;
    max-width: 64ch;
  }
  .pilier-items {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: var(--s-3);
  }
  .pilier-items li {
    display: flex; align-items: flex-start; gap: var(--s-3);
    font-size: var(--step-0);
    line-height: var(--lh-loose);
    color: var(--ink-1);
  }
  .pilier-items .check {
    color: var(--cuivre);
    flex-shrink: 0;
    margin-top: 4px;
  }

  /* VS grid */
  .vs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-5);
  }
  @media (max-width: 720px) {
    .vs-grid { grid-template-columns: 1fr; }
  }
  .vs-card {
    padding: var(--s-6);
    border-radius: 14px;
  }
  .vs-card--before {
    background: var(--bg-2);
    border: 1px solid var(--line);
  }
  .vs-card--after {
    background: var(--bg-3);
    border: 1px solid var(--cuivre);
  }
  .vs-tag {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 var(--s-3) 0;
  }
  .vs-card--before .vs-tag { color: var(--ink-3); }
  .vs-card--after .vs-tag { color: var(--cuivre); }
  .vs-h {
    font-family: var(--font-display);
    font-size: var(--step-2);
    color: var(--ivoire);
    margin: 0 0 var(--s-3) 0;
    line-height: 1.2;
  }
  .vs-body {
    font-size: var(--step-0);
    line-height: var(--lh-loose);
    color: var(--ink-2);
    margin: 0;
  }

  /* CTA accent */
  .section--accent {
    background: var(--cuivre);
    padding-block: var(--s-9);
  }
  .btn-on-accent {
    background: var(--ivoire);
    color: var(--cuivre);
    border-color: var(--ivoire);
  }
  .btn-on-accent:hover {
    background: var(--bg);
    color: var(--ivoire);
    border-color: var(--bg);
  }
  .btn--on-accent-ghost {
    color: var(--ivoire);
    border-color: var(--ivoire);
  }
  .btn--on-accent-ghost:hover {
    background: var(--ivoire);
    color: var(--cuivre);
  }
</style>

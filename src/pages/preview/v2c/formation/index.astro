---
import V2bLayout from '../../../../layouts/V2bLayout.astro';
import Icon from '../../../../components/v2/Icon.astro';
import LogoMark from '../../../../components/v2/LogoMark.astro';
import V2cHeader from '../../../../components/v2/V2cHeader.astro';
import V2cFooter from '../../../../components/v2/V2cFooter.astro';

// Publics — accompagnement dirigeant placé en premier
const publics = [
  {
    tag: 'Dirigeants',
    titre: 'Votre assistant IA. Vos process réinventés.',
    corps: "L'accompagnement IA du dirigeant. On conçoit ensemble votre assistant IA autonome — et on refond les process clés pour qu'ils tirent vraiment parti de l'IA. Pas du coaching business.",
    proactive: true,
  },
  {
    tag: 'Commerciaux · ADV',
    titre: 'Vendre et suivre avec une longueur d\'avance.',
    corps: "Synthèse d'appels, relances personnalisées, comptes-rendus dictés, propale en minutes. Les CRM deviennent lisibles.",
  },
  {
    tag: 'Opérations · Back-office',
    titre: 'Trier, rédiger, acheminer.',
    corps: "Tri de mails, brouillons automatiques, courriers types générés, extraction de documents. Le bruit s'efface.",
  },
  {
    tag: 'Métiers réglementés',
    titre: 'Rigueur et confidentialité d\'abord.',
    corps: "CGP, notariat, juridique, santé, comptabilité. Sur modèles européens, avec garde-fous documentés. Ce qui sort peut se défendre.",
  },
  {
    tag: 'Tech · Dev',
    titre: 'De la productivité au système.',
    corps: "Claude Code, Cursor, agents d'ingénierie, prompts de spec. De 1 dev productif à 1 équipe augmentée.",
  },
  {
    tag: 'RH · Communication',
    titre: 'Accélérer sans déshumaniser.',
    corps: "Annonces, briefs, supports internes, synthèse d'entretiens. La voix de l'entreprise reste la vôtre.",
  },
];

const temps = [
  {
    n: '01',
    titre: 'Avant — le cadrage',
    duree: '30 à 60 min · visio',
    corps: "Entretien avec vous ou votre équipe. On repère les irritants, les cas concrets, le niveau de départ. Le programme se bâtit sur vos données, pas sur un PDF d'éditeur.",
  },
  {
    n: '02',
    titre: 'Pendant — l\'atelier',
    duree: '1 à 10 jours · sur site',
    corps: "Ateliers pratiques sur vos cas réels. Chaque participant repart avec 3 prompts qui tournent, 1 workflow testé, 1 outil configuré pour son poste.",
  },
  {
    n: '03',
    titre: 'Après — la traction',
    duree: '30 · 60 · 90 jours',
    corps: "Trois points de contrôle. On mesure ce qui a tenu, on corrige ce qui a glissé. Une bibliothèque interne de prompts métier se constitue.",
  },
];

const programmes = [
  { code: 'F-INTRO', cat: 'decouverte', icon: 'sparkles', niveau: 'Découverte', titre: 'Découverte intégrée digitale — Niveau 1', duree: '1 jour · inter ou intra',
    pour: 'Tous publics · première marche',
    livre: "Comprendre l'IA générative concrètement. Premiers prompts utiles, premiers outils, premiers réflexes. Le point de départ — pour celles et ceux qui veulent décoller propre.",
    url: 'https://formation.958.fr/f/decouverte-integree-digitale-niveau-1' },
  { code: 'F-00', cat: 'accompagnement', icon: 'users', niveau: 'Accompagnement', titre: 'Accompagnement IA du dirigeant', duree: '6 mois · bi-mensuel',
    pour: 'DG seul ou avec son équipe rapprochée',
    livre: "Conception de votre assistant IA autonome. Refonte des process clés où l'IA change tout. Présent derrière vos sessions, je connais vos équipes — j'ajuste avec vous." },
  { code: 'F-01', cat: 'strategique', icon: 'briefcase', niveau: 'Stratégique', titre: 'IA pour dirigeants', duree: '1 jour',
    pour: 'DG, COMEX, fondateurs',
    livre: "Cadre de décision, grille de souveraineté, cartographie des outils pertinents pour votre secteur." },
  { code: 'F-02', cat: 'metier', icon: 'phone', niveau: 'Métier', titre: 'IA commerciale appliquée', duree: '2 jours',
    pour: 'Équipes sales · ADV',
    livre: "Workflow complet prospection → proposition → relance. 12 prompts métier validés et signés." },
  { code: 'F-03', cat: 'metier', icon: 'mail', niveau: 'Métier', titre: 'Automatisation back-office', duree: '3 jours',
    pour: 'Ops · assistants',
    livre: "Chaîne de traitement mails, documents, extractions. n8n auto-hébergé. Zéro dépendance US." },
  { code: 'F-04', cat: 'reglemente', icon: 'shield', niveau: 'Réglementé', titre: 'IA en métier réglementé', duree: '2 jours',
    pour: 'CGP · notaires · juristes',
    livre: "Cadre RGPD, modèles EU, traçabilité, validation humaine. Ce qui sort est défendable." },
  { code: 'F-05', cat: 'sur-mesure', icon: 'monitor', niveau: 'Sur-mesure', titre: 'Cockpit en équipe', duree: '5 jours',
    pour: 'Équipes produit · dev · ops',
    livre: "Conception et livraison d'un cockpit interne sur votre cas. L'équipe le maintient ensuite." },
];

// Témoignages — depuis les 6 réalisations de la home v2c
const temoignages = [
  {
    quote: "Nos 9 développeurs sont opérationnels dès le lendemain. Le cadre prompt que nous avons écrit ensemble, on l'utilise encore chaque semaine.",
    role: 'DSI',
    context: 'éditeur SaaS B2B · 120 collaborateurs',
  },
  {
    quote: "Nos commerciaux dictent leurs visites sur le terrain. Le support de présentation est prêt en minutes, plus en jours. L'équipe vend.",
    role: 'Directeur commercial',
    context: 'groupe immobilier breton',
  },
  {
    quote: "200 mails par jour, c'était impossible. Aujourd'hui l'IA trie, rédige les brouillons. On absorbe la croissance sans recruter.",
    role: 'Gérant',
    context: 'acteur régional du syndic',
  },
  {
    quote: "On voulait l'IA mais on ne savait pas par où commencer. 1 journée chez nous, 9 développeurs autonomes le lendemain. La bibliothèque de prompts grandit chaque semaine.",
    role: 'Directeur du développement',
    context: "groupe d'aménageurs fonciers",
  },
];

const versus = [
  { eux: '1 semaine en groupe, à distance',       nous: '1 à 10 jours chez vous, avec votre équipe' },
  { eux: 'Catalogue standardisé, promis à tous',  nous: 'Programme construit sur vos cas réels' },
  { eux: 'Certificat joli à afficher',            nous: 'Cockpit qui tourne dès lundi matin' },
  { eux: 'Liste de 100 prompts à copier-coller',  nous: 'Un cadre — SPARI — qui se transmet' },
  { eux: 'Modèles US par défaut, sans carve-out', nous: 'Modèles européens, souveraineté documentée' },
  { eux: 'Facture à l\'inscription',              nous: 'Proposition écrite après entretien' },
  { eux: 'Formateur jamais revu après',           nous: 'Suivi 30 · 60 · 90 jours inclus' },
];
---

<V2bLayout
  title="Formation Ça fait Tilt® — Accompagnement IA du dirigeant"
  description="Formations IA sur-mesure intra-entreprise + accompagnement du dirigeant. Ateliers terrain, cas réels, suivi 30·60·90 jours. Une formation IA ne vaut rien si elle se finit le vendredi soir. Organisme de formation enregistré, Qualiopi prévu."
>
  <V2cHeader currentSection="formation" />

  <!-- HERO -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="container is-default">
      <p class="eyebrow reveal">
        Ça fait Tilt<sup>®</sup> — Formation intra-entreprise &amp; accompagnement du dirigeant
      </p>
      <h1 id="hero-title" class="manifesto reveal">
        Le déclic.<br>
        <em>Pas le discours.</em>
      </h1>
      <p class="killer-line reveal">
        Des ateliers qui font tilt.<br>
        Des équipes qui repartent<br>
        avec quelque chose qui tourne lundi.
      </p>
      <p class="lead reveal">
        Formations IA <strong>pour dirigeants et équipes métier</strong>.
        Sur vos cas réels. Avec suivi 30 · 60 · 90 jours.
      </p>
      <div class="hero-ctas reveal">
        <a href="/preview/v2c/formation/brief/" class="btn btn--primary btn--lg">
          Brief formation
          <Icon name="arrow-right" size={18} class="arrow" />
        </a>
        <a href="#publics" class="btn btn--ghost btn--lg">
          Voir pour qui
          <Icon name="arrow-right" size={18} class="arrow" />
        </a>
      </div>
      <ul class="hero-assurances reveal">
        <li>Centre de formation enregistré · NDA 11757585175</li>
        <li>Qualiopi en cours · obtention juin 2026</li>
        <li>Accord de confidentialité systématique</li>
      </ul>
    </div>
  </section>

  <!-- MANIFESTE -->
  <section class="section section--clarif is-tight">
    <div class="container is-default">
      <p class="reveal clarif-text">
        <em>Une formation IA ne vaut rien<br>si elle se finit le vendredi soir.</em>
      </p>
      <p class="reveal manifeste-sub">
        Ce qui compte, ce n'est pas ce qu'on dit en formation.
        C'est ce que vos équipes emportent <strong>le lundi matin</strong>.
        Un prompt trouvé ensemble, un workflow testé sur un vrai dossier, un outil branché sur vos données,
        un cadre qui se transmet : voilà ce qui reste.<br>
        Le reste — slides, théorie, catalogues — n'est pas notre métier.
      </p>
    </div>
  </section>

  <!-- ACCOMPAGNEMENT DU DIRIGEANT — angle dédié -->
  <section id="accompagnement" class="section section--soft" aria-labelledby="accomp-title">
    <div class="container">
      <div class="section-head">
        <h2 id="accomp-title" class="reveal section-h2">
          L'accompagnement <em>IA</em> du dirigeant.<br>
          Pas du coaching business.
        </h2>
        <p class="reveal section-sub">
          Vos confrères ont leur coach, leur expert-comptable, leur avocat.
          Personne ne leur parle d'IA <strong>sur leur cas, à leur rythme, avec leurs données</strong>.
          C'est ce trou qu'on remplit — sur deux fronts précis.
        </p>
      </div>

      <div class="accomp-grid">
        <article class="accomp-card reveal">
          <div class="accomp-icon"><Icon name="sparkles" size={26} strokeWidth={1.6} /></div>
          <span class="accomp-tag">Pilier 1</span>
          <h3>Concevoir <em>votre</em> assistant IA autonome.</h3>
          <p>
            Un assistant qui connaît votre agenda, vos dossiers, vos contacts, vos enjeux.
            Qui prépare vos décisions, synthétise vos lectures, rédige vos brouillons.
            <strong>À votre nom. À votre métier. À votre charte.</strong>
          </p>
        </article>
        <article class="accomp-card reveal">
          <div class="accomp-icon"><Icon name="monitor" size={26} strokeWidth={1.6} /></div>
          <span class="accomp-tag">Pilier 2</span>
          <h3>Refondre <em>les process</em>, pas les automatiser.</h3>
          <p>
            <strong>Coller de l'IA sur un process ancien, c'est garder un mauvais process.</strong>
            On identifie ensemble les 3 à 5 process clés où l'IA change la nature du travail —
            et on les réinvente.
          </p>
        </article>
        <article class="accomp-card reveal">
          <div class="accomp-icon"><Icon name="users" size={26} strokeWidth={1.6} /></div>
          <span class="accomp-tag">Pilier 3</span>
          <h3>Être <em>là</em> quand ça se joue.</h3>
          <p>
            Derrière votre caméra pendant que vous formez votre équipe. Présent en réunion.
            Je connais chaque salarié, je sais ce qui passe, ce qui bof, ce qui non.
            <strong>J'adapte la formation et le suivi à <em>chaque</em> personne.</strong>
          </p>
        </article>
      </div>

      <p class="reveal accomp-note">
        <strong>Format type</strong> : 6 mois renouvelables. 1 demi-journée tous les 15 jours.
        Sur site ou visio. Sujets apportés par vous, livrables construits ensemble.
        Souveraineté européenne par défaut — le choix vous appartient.
      </p>
    </div>
  </section>

  <!-- POUR QUI -->
  <section id="publics" class="section" aria-labelledby="publics-title">
    <div class="container">
      <div class="section-head">
        <h2 id="publics-title" class="reveal section-h2">
          Un parcours par métier.<br>
          <em>Jamais un catalogue générique.</em>
        </h2>
        <p class="reveal section-sub">Chaque métier a ses objets, ses contraintes, ses irritants. La formation aussi.</p>
      </div>

      <ul class="publics-grid">
        {publics.map((p) => (
          <li class={`public-card reveal ${p.proactive ? 'public-card--feat' : ''}`}>
            <span class="public-tag">{p.tag}</span>
            <h3 class="public-titre">{p.titre}</h3>
            <p class="public-corps">{p.corps}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- TROIS TEMPS -->
  <section id="methode" class="section section--soft" aria-labelledby="methode-title">
    <div class="container is-default">
      <div class="section-head">
        <h2 id="methode-title" class="reveal section-h2">
          Trois temps. <em>Toujours.</em>
        </h2>
        <p class="reveal section-sub">
          Ce qui transforme la formation en compétence : le cadrage avant, la traction après.
        </p>
      </div>

      <ol class="temps-list">
        {temps.map((t) => (
          <li class="temps-item reveal">
            <span class="temps-n">{t.n}</span>
            <div class="temps-body">
              <h3 class="temps-h">
                {t.titre} <span class="temps-duree">{t.duree}</span>
              </h3>
              <p class="temps-corps">{t.corps}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- VS LE MARCHÉ -->
  <section class="section" aria-labelledby="vs-title">
    <div class="container">
      <div class="section-head">
        <h2 id="vs-title" class="reveal section-h2">
          Pas un énième bootcamp IA.
        </h2>
        <p class="reveal section-sub">Même question, deux réponses. À chaque ligne, le choix devient évident.</p>
      </div>

      <div class="vs-grid reveal">
        <div class="vs-col vs-col--eux">
          <p class="vs-head">Les bootcamps · formations LinkedIn</p>
          <ul>
            {versus.map((row) => (
              <li><span class="vs-mark">×</span> {row.eux}</li>
            ))}
          </ul>
        </div>
        <div class="vs-col vs-col--nous">
          <p class="vs-head">9·58 — Ça fait Tilt<sup>®</sup></p>
          <ul>
            {versus.map((row) => (
              <li><span class="vs-mark vs-mark--ok">+</span> {row.nous}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- PROGRAMMES TYPES -->
  <section class="section section--soft" aria-labelledby="prog-title">
    <div class="container">
      <div class="section-head">
        <h2 id="prog-title" class="reveal section-h2">
          Des parcours inspirés du terrain.
        </h2>
        <p class="reveal section-sub">
          Tous nos programmes sont adaptés au contexte du client.
          Voici six points de départ pour que la conversation aille vite.
        </p>
      </div>

      <ul class="programmes-grid">
        {programmes.map((p) => (
          <li class="prog-card reveal" data-cat={p.cat}>
            <div class="prog-head">
              <span class="prog-icon"><Icon name={p.icon} size={20} strokeWidth={1.7} /></span>
              <span class="prog-niveau">{p.niveau}</span>
              <span class="prog-duree">{p.duree}</span>
            </div>
            <h3 class="prog-titre">{p.titre}</h3>
            <p class="prog-pour">{p.pour}</p>
            <p class="prog-livre">{p.livre}</p>
            <div class="prog-footer">
              <span class="prog-code">{p.code}</span>
              {p.url
                ? <a href={p.url} target="_blank" rel="noopener" class="prog-link">S'inscrire <Icon name="arrow-up-right" size={14} /></a>
                : <a href="/preview/v2c/formation/brief/" class="prog-link">Demander un devis <Icon name="arrow-right" size={14} /></a>}
            </div>
          </li>
        ))}
      </ul>

      <p class="reveal prog-note">
        <strong>Devis en 48 h</strong> · NDA 11757585175 · Qualiopi obtention juin 2026 (la prise en charge OPCO sera possible après certification)
      </p>
    </div>
  </section>

  <!-- TÉMOIGNAGES -->
  <section class="section" aria-labelledby="temo-title">
    <div class="container">
      <div class="section-head">
        <h2 id="temo-title" class="reveal section-h2">
          Ce qu'ils en disent.
        </h2>
        <p class="reveal section-sub">
          Quatre voix, quatre secteurs, une même chose qui change : le quotidien.
        </p>
      </div>

      <div class="temoignages-grid">
        {temoignages.map((t) => (
          <figure class="temoignage reveal">
            <blockquote>« {t.quote} »</blockquote>
            <figcaption>
              <span class="quote-role">{t.role}</span>
              <span class="quote-context">{t.context}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section id="contact" class="section section--accent" aria-labelledby="cta-title">
    <div class="container is-default cta-inner">
      <h2 id="cta-title" class="reveal cta-title">
        Briefons votre formation.<br>
        <em>Ou votre accompagnement.</em>
      </h2>
      <p class="reveal cta-lead">
        Un entretien court. On comprend votre contexte, vos cas, vos contraintes.
        On vous envoie une proposition écrite sous 48 h. Sans engagement.
      </p>
      <div class="cta-ctas reveal">
        <a href="/preview/v2c/formation/brief/" class="btn btn--lg btn-on-accent">
          Brief formation
          <Icon name="arrow-right" size={18} class="arrow" />
        </a>
        <a href="/preview/v2c/" class="btn btn--ghost btn--lg btn--on-accent-ghost">
          Voir le cockpit 9·58
          <Icon name="arrow-up-right" size={18} class="arrow" />
        </a>
      </div>
    </div>
  </section>

  <V2cFooter />
</V2bLayout>

<style>
  /* ============ HEADER ============ */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(11, 11, 10, 0.78);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-h);
    gap: var(--s-5);
  }
  .brand {
    display: inline-flex;
    flex-direction: column;
    line-height: 1;
    color: var(--ivoire);
    text-decoration: none;
    gap: 3px;
  }
  .brand { display: inline-flex; align-items: center; gap: 12px; }
  .footer-brand {
    display: inline-flex !important;
    flex-direction: row !important;
    align-items: center;
    gap: 12px;
  }
  .brand-mark {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    color: var(--cuivre);
  }
  .brand-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .nav-desktop ul {
    display: flex;
    gap: var(--s-5);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-desktop a {
    font-size: var(--step-0);
    font-weight: 500;
    color: var(--ink-2);
    padding: 6px 2px;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-1) var(--ease),
                border-color var(--dur-1) var(--ease);
  }
  .nav-desktop a:hover, .nav-desktop a[aria-current="page"] {
    color: var(--cuivre);
    border-bottom-color: var(--cuivre);
  }
  @media (max-width: 900px) { .nav-desktop, .header-cta { display: none; } }

  /* ============ HERO ============ */
  .hero {
    padding-block: var(--s-10) var(--s-9);
  }
  .hero .eyebrow { margin-bottom: var(--s-5); }
  .hero .manifesto { margin-bottom: var(--s-5); max-width: 14ch; }
  .hero .killer-line { margin-bottom: var(--s-6); }
  .hero .lead { margin-bottom: var(--s-7); max-width: 56ch; }
  .hero-ctas { display: flex; gap: var(--s-3); flex-wrap: wrap; }
  .hero-assurances {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-5);
    margin-top: var(--s-6);
    list-style: none;
    padding: 0;
  }
  .hero-assurances li {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-3);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    position: relative;
    padding-left: 14px;
  }
  .hero-assurances li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    background: var(--cuivre);
    border-radius: 50%;
  }
  sup { font-size: 0.55em; vertical-align: super; }
  @media (max-width: 720px) {
    .hero { padding-block: var(--s-8) var(--s-7); }
    .hero .manifesto { max-width: 100%; }
  }

  /* ============ MANIFESTE (clarif) ============ */
  .section--clarif {
    background: var(--bg);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: var(--s-7);
  }
  .clarif-text {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.5rem);
    line-height: 1.15;
    color: var(--ivoire);
    max-width: 760px;
    margin: 0 auto var(--s-5) auto;
    text-align: center;
    text-wrap: balance;
    font-weight: 400;
  }
  .clarif-text em { color: var(--cuivre); font-style: italic; }
  .manifeste-sub {
    font-size: var(--step-1);
    line-height: var(--lh-loose);
    color: var(--ink-2);
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .manifeste-sub strong { color: var(--ivoire); font-weight: 600; }

  /* ============ SECTION HEAD ============ */
  .section-head {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    margin-bottom: var(--s-7);
    max-width: 760px;
  }
  .section-h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: var(--tr-tighter);
    color: var(--ivoire);

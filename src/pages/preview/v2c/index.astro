            <circle r="9" fill="#6B8E54"/>
            <circle r="13" fill="none" stroke="#6B8E54" stroke-opacity="0.3" stroke-width="2"/>
          </g>

          <!-- Dot 2 — 2025-2026 Vous êtes ici (mimosa pulse) -->
          <g transform="translate(420, 240)" class="ap-svg-g ap-svg-here">
            <circle r="11" fill="#FEF86C"/>
            <circle r="11" fill="#FEF86C" opacity="0.5">

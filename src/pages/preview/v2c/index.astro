    white-space: nowrap;
    border-right: 1.5px solid var(--cuivre);
    animation: typing 4s steps(28) infinite, blink 1s step-end infinite;
    width: 28ch;
    max-width: 100%;
  }
  @keyframes typing {
    0% { width: 0; }
    60% { width: 28ch; }
    90% { width: 28ch; }
    100% { width: 0; }
  }
  @keyframes blink {
    50% { border-color: transparent; }
  }
  .cc-mail-badge {
    position: absolute;
    top: -8px;
    right: 8px;
    background: var(--cuivre);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 999px;
  }

  .cc-ai-text {
    margin: 0;
    max-width: none;
    font-size: 13px;
    color: var(--ivoire);
    line-height: 1.5;
  }
  .cc-ai-text strong {
    color: var(--cuivre);
    font-weight: 600;
  }
  .cc-ai-actions {
    display: flex;
    gap: 8px;
    margin-top: 4px;
  }
  .cc-ai-btn {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 6px;
    border: 1px solid var(--line-2);
    background: transparent;
    color: var(--ink-2);
    cursor: pointer;
    transition: all var(--dur-1) var(--ease);
  }
  .cc-ai-btn:hover {
    border-color: var(--cuivre);
    color: var(--cuivre);
  }
  .cc-ai-btn--primary {
    background: var(--cuivre);
    color: var(--bg);
    border-color: var(--cuivre);
  }
  .cc-ai-btn--primary:hover {
    background: var(--cuivre-hover);
    color: var(--bg);
  }

  @media (max-width: 720px) {
    .cockpit { transform: none; }
    .cockpit-grid { grid-template-columns: 1fr; }
    .cockpit-card { min-height: auto; }
    .cc-value { font-size: 24px; }
  }

  /* ============ SECTION HEAD ============ */
  .section-head {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    margin-bottom: var(--s-8);
    max-width: 720px;
  }
  .section-h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw + 0.5rem, 3.25rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: var(--tr-tighter);
    color: var(--ink);
    max-width: 22ch;
    text-wrap: balance;
    margin: 0;
  }
  .section-h2 em { font-style: italic; color: var(--cuivre); }
  .section-sub {
    font-size: var(--step-2);
    line-height: var(--lh-normal);
    color: var(--ink-2);
    max-width: 60ch;
    margin: 0;
  }

  /* ============ BANDEAU CLARIF (anti "ça fait CRM") ============ */
  .section--clarif {
    background: var(--bg);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: var(--s-7);
  }
  .clarif-text {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 1.5vw + 0.3rem, 1.5rem);
    line-height: 1.5;
    color: var(--ivoire-2);
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    text-wrap: balance;
    font-weight: 400;
  }
  .clarif-text strong { color: var(--ivoire); font-weight: 500; }
  .clarif-text em { color: var(--cuivre); font-style: italic; font-weight: 500; }

  /* ============ COURBE D'ADOPTION (SVG) ============ */
  .adoption-curve {
    margin-top: var(--s-7);
    color: var(--ivoire);
  }
  .adoption-svg {
    width: 100%;
    height: auto;
    max-height: 440px;
    display: block;
  }
  .adoption-path {
    stroke-dasharray: 1500;
    stroke-dashoffset: 1500;
    animation: drawCurve 2.4s var(--ease-out) 0.3s forwards;
  }
  @keyframes drawCurve {
    to { stroke-dashoffset: 0; }
  }

  .ap-year-txt {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .ap-state-txt {
    font-family: var(--font-display);
    font-size: 14px;
    fill: var(--ivoire);
    font-weight: 500;
  }
  .ap-year-here {
    fill: var(--mimosa);
    font-weight: 600;
  }
  .ap-state-here {
    fill: var(--mimosa);
    font-style: italic;
  }
  .ap-here-txt {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--mimosa);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .ap-axis {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--ink-3);
    letter-spacing: 0.04em;
  }

  /* Tableau métadonnées sous la courbe */
  .adoption-meta {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-3);
    margin-top: var(--s-5);
  }
  .adoption-cell {
    padding: var(--s-4);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .adoption-cell--here {
    background: rgba(254, 248, 108, 0.06);
    border-color: var(--mimosa);
  }
  .adoption-cell--pioneer .ac-tag { color: var(--vert-mousse); border-color: var(--vert-mousse); }
  .adoption-cell--std .ac-tag { color: var(--ink-3); }
  .adoption-cell--late .ac-tag { color: var(--ink-3); opacity: 0.7; }
  .ac-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--cuivre);
    padding: 3px 8px;
    border: 1px solid currentColor;
    border-radius: var(--r-pill);
    align-self: flex-start;
    font-weight: 500;
  }
  .ac-tag--here {
    color: var(--mimosa);
    background: var(--mimosa);
    color: var(--bg);
    border-color: var(--mimosa);
  }
  .adoption-cell p {
    font-size: var(--step-0);
    color: var(--ink-2);
    margin: 0;
    line-height: var(--lh-normal);
    max-width: none;
  }

  @media (max-width: 720px) {
    .adoption-meta { grid-template-columns: repeat(2, 1fr); }
  }

  /* ============ SCHÉMA ADOPTION (legacy, conservé) ============ */
  .adoption-schema {
    position: relative;
    margin-top: var(--s-7);
    padding-block: var(--s-7) var(--s-5);
  }
  .adoption-line {
    position: absolute;
    top: 90px;
    left: 6%;
    right: 6%;
    height: 2px;
    background: linear-gradient(90deg,
      var(--cuivre) 0%,
      var(--cuivre) 30%,
      var(--mimosa) 38%,
      var(--mimosa) 52%,
      var(--ink-3) 70%,
      var(--ink-3) 100%);
    opacity: 0.55;
  }
  .adoption-points {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-4);
    position: relative;
  }
  .adoption-point {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--s-2);
    padding-top: 50px;
    position: relative;
  }
  .ap-dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--cuivre);
    position: absolute;
    top: 82px;
    left: 50%;
    transform: translateX(-50%);
    box-shadow: 0 0 0 4px var(--bg-2);
  }
  .ap-pioneer .ap-dot { background: var(--vert-mousse); }
  .ap-now .ap-dot-pulse {
    background: var(--mimosa);
    width: 22px;
    height: 22px;
    top: 80px;
    animation: ap-pulse 2.4s var(--ease) infinite;
  }
  .ap-standard .ap-dot { background: var(--ink-3); }
  .ap-late .ap-dot { background: var(--ink-3); opacity: 0.55; }

  @keyframes ap-pulse {
    0%, 100% { box-shadow: 0 0 0 4px var(--bg-2), 0 0 0 0 var(--mimosa-soft, rgba(254,248,108,0.45)); }
    50%      { box-shadow: 0 0 0 4px var(--bg-2), 0 0 0 12px transparent; }
  }

  .ap-here {
    position: absolute;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mimosa);
    white-space: nowrap;
    padding: 4px 10px;
    background: var(--bg);
    border: 1px solid var(--mimosa);
    border-radius: var(--r-pill);
    font-weight: 500;
  }
  .ap-here::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 100%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: var(--mimosa);
    margin-top: 1px;
  }

  .ap-year {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.06em;
    color: var(--ink-3);
    text-transform: uppercase;
    margin-top: var(--s-4);
  }
  .ap-now .ap-year { color: var(--mimosa); }

  .ap-state {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--step-2);
    color: var(--ink);
    letter-spacing: -0.015em;
    margin: 0;
    line-height: 1.2;
    max-width: 18ch;
  }
  .ap-pioneer .ap-state { color: var(--ivoire); }
  .ap-now .ap-state { color: var(--ivoire); }
  .ap-late .ap-state { color: var(--ink-2); }

  .ap-desc {
    font-size: var(--step-0);
    color: var(--ink-2);
    margin: 0;
    max-width: 22ch;
    line-height: var(--lh-normal);
  }
  .ap-pioneer .ap-desc { color: var(--vert-mousse); }
  .ap-now .ap-desc { color: var(--mimosa); }
  .ap-late .ap-desc { color: var(--ink-3); }

  .adoption-cta {
    margin-top: var(--s-6);
  }

  @media (max-width: 720px) {
    .adoption-points { grid-template-columns: 1fr; gap: var(--s-6); }
    .adoption-line {
      top: 0;
      bottom: 0;
      left: 30px;
      right: auto;
      width: 2px;
      height: auto;
      background: linear-gradient(180deg,
        var(--vert-mousse) 0%,
        var(--cuivre) 20%,
        var(--mimosa) 35%,
        var(--mimosa) 52%,
        var(--ink-3) 70%,
        var(--ink-3) 100%);
    }
    .adoption-point {
      align-items: flex-start;
      text-align: left;
      padding-top: 0;
      padding-left: 60px;
      min-height: 80px;
    }
    .ap-dot {
      top: 8px;
      left: 30px;
      transform: translateX(-50%);
    }
    .ap-now .ap-dot-pulse { top: 6px; }
    .ap-here {
      position: static;
      transform: none;
      margin-bottom: var(--s-2);
      display: inline-block;
    }
    .ap-here::after { display: none; }
    .ap-year { margin-top: 0; }
    .ap-state, .ap-desc { max-width: 100%; }
  }

  /* ============ DORMENT (Vos données dorment) ============ */
  .dorment-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-6);
    margin-top: var(--s-5);
  }
  .dorment-item {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .dorment-n {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 3vw + 0.5rem, 2.75rem);
    line-height: 1;
    color: var(--cuivre);
    letter-spacing: -0.04em;
  }
  .dorment-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--step-3);
    color: var(--ink);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.2;
  }
  .dorment-h em { color: var(--cuivre); font-style: italic; }
  .dorment-item p { margin: 0; max-width: none; font-size: var(--step-1); }

  .dorment-chiffre {
    margin-top: var(--s-10);
    padding-top: var(--s-8);
    border-top: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .dorment-source {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-3);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
    max-width: none;
  }

  @media (max-width: 900px) {
    .dorment-grid { grid-template-columns: 1fr; gap: var(--s-7); }
  }

  /* ============ STEPS (méthode) ============ */
  .steps {
    list-style: none;
    padding: 0;
    margin: var(--s-7) 0 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
  }
  .step {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--s-5);
    padding: var(--s-5);
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    transition: border-color var(--dur-2) var(--ease);
  }
  .step:hover { border-color: var(--cuivre); }
  .step-n {
    font-family: var(--font-mono);
    font-size: var(--step-1);
    color: var(--cuivre);
    letter-spacing: 0.04em;
    font-weight: 500;
  }
  .step-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--step-3);
    color: var(--ink);
    margin: 0 0 var(--s-2) 0;
    letter-spacing: -0.02em;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    align-items: baseline;
  }
  .step-duree {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 400;
  }
  .step p { margin: 0; max-width: 64ch; }

  @media (max-width: 640px) {
    .step { grid-template-columns: 1fr; gap: var(--s-3); padding: var(--s-4); }
  }

  /* ============ PILIERS (accent cuivre) ============ */
  .piliers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-5);
    margin-top: var(--s-7);
  }
  .pilier {
    padding: var(--s-6);
    background: rgba(11, 11, 10, 0.28);
    border: 1px solid rgba(244, 236, 220, 0.2);
    border-radius: var(--r-3);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .pilier-icon {
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    color: var(--cuivre);
    border-radius: var(--r-3);
    margin-bottom: var(--s-2);
  }
  .pilier-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--step-3);
    color: var(--ivoire);
    letter-spacing: -0.02em;
    margin: 0;
  }
  .pilier-sub {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ivoire);
    margin: 0;
    max-width: none;
    font-size: var(--step-1);
  }
  .pilier-sub em { color: var(--ivoire); font-style: normal; font-weight: 600; }
  .pilier-body {
    color: var(--ivoire-2);
    font-size: var(--step-1);
    line-height: var(--lh-normal);
    margin: 0;
    max-width: none;
  }
  .pilier-body em { color: var(--ivoire); font-style: italic; }

  @media (max-width: 900px) {
    .piliers-grid { grid-template-columns: 1fr; }
  }

  /* ============ ENFONCER LE CLOU (Terrain) ============ */
  .terrain-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-4);
    margin-top: var(--s-7);
  }
  .terrain-card {
    padding: var(--s-5);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    transition: border-color var(--dur-2) var(--ease),
                transform var(--dur-2) var(--ease);
  }
  .terrain-card:hover {
    border-color: var(--cuivre);
    transform: translateY(-3px);
  }
  .terrain-head {
    display: flex;
    align-items: center;
    gap: var(--s-2);
  }
  .terrain-icon {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--cuivre);
    color: var(--bg);
    border-radius: var(--r-3);
    transition: transform var(--dur-2) var(--ease), box-shadow var(--dur-2) var(--ease);
  }
  .terrain-card:hover .terrain-icon {
    transform: scale(1.08) rotate(-3deg);
    box-shadow: var(--glow-cuivre);
  }
  .terrain-secteur {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cuivre);
    font-weight: 600;
  }
  .terrain-titre {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--step-3);
    color: var(--ivoire);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: none;
  }
  .terrain-body {
    color: var(--ink-2);
    font-size: var(--step-1);
    line-height: var(--lh-loose);
    margin: 0;
    max-width: none;
  }

  /* Indicateur de gain en pied de carte */
  .terrain-gain {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    padding-top: var(--s-3);
    border-top: 1px dashed var(--line-2);
  }
  .terrain-gain-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: var(--vert-mousse-soft);
    color: var(--vert-mousse);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .terrain-gain-label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--vert-mousse);
    font-weight: 600;
  }

  .terrain-outro {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-2);
    color: var(--ivoire-2);
    margin-top: var(--s-7);
    text-align: center;
    max-width: 60ch;
    margin-inline: auto;
    text-wrap: balance;
  }
  .terrain-outro em { color: var(--cuivre); font-style: italic; font-weight: 500; }

  /* Card IA proactive — Anniversaire client (full-width, distinguée vert) */
  .terrain-card--proactive {
    grid-column: 1 / -1;
    background: linear-gradient(135deg,
      var(--vert-mousse-soft) 0%,
      var(--bg) 60%,
      var(--cuivre-soft) 100%);
    border: 1px solid var(--vert-mousse);
    padding: var(--s-6);
    position: relative;
    overflow: hidden;
  }
  .terrain-icon--vert {
    background: var(--vert-mousse);
    color: var(--bg);
  }
  .terrain-secteur--vert {
    color: var(--vert-mousse);
  }
  .proactive-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--s-6);
    align-items: center;
  }
  .proactive-copy { display: flex; flex-direction: column; gap: var(--s-3); }
  .proactive-copy .terrain-gain {
    border-top: 1px dashed var(--vert-mousse);
    margin-top: var(--s-3);
    padding-top: var(--s-3);
  }
  .terrain-card--proactive .terrain-titre em {
    color: var(--vert-mousse);
    font-style: italic;
  }

  /* Mini-mockup du mail anniversaire */
  .proactive-mock {
    background: var(--bg-2);
    border: 1px solid var(--line-2);
    border-radius: var(--r-3);
    overflow: hidden;
    box-shadow: 0 20px 50px -20px rgba(0,0,0,0.6);
  }
  .pmock-bar {
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    padding: 8px 12px;
  }
  .pmock-from {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--vert-mousse);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .pmock-body { padding: 12px; display: flex; flex-direction: column; gap: 8px; }
  .pmock-to {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }
  .pmock-subject {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14px;
    color: var(--ivoire);
    letter-spacing: -0.01em;
  }
  .pmock-text {
    font-size: 11px;
    color: var(--ivoire-2);
    line-height: 1.55;
    margin: 0;
    max-width: none;

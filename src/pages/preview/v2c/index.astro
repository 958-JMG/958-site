          <!-- Courbe en S -->
          <path class="adoption-path"
                d="M 60,320 C 220,318 320,310 420,240 C 520,170 640,90 800,70 C 880,62 940,60 960,60"
                fill="none" stroke="#C75F2D" stroke-width="3"
                stroke-linecap="round"/>

          <!-- Dot 1 — 2024 Pionniers -->

          <line x1="60" y1="200" x2="960" y2="200" stroke="currentColor" stroke-opacity="0.06" stroke-dasharray="2 4"/>
          <line x1="60" y1="80"  x2="960" y2="80"  stroke="currentColor" stroke-opacity="0.06" stroke-dasharray="2 4"/>

          <!-- Aire sous la courbe (subtile) -->
          <path d="M 60,320 C 220,318 320,310 420,240 C 520,170 640,90 800,70 C 880,62 940,60 960,60 L 960,320 Z"

          </div>
          <div class="adoption-cell adoption-cell--std">
            <span class="ac-tag">2027</span>
            <p>Le coût d'entrée devient élevé.</p>
          </div>
          <div class="adoption-cell adoption-cell--late">
            <span class="ac-tag">Après</span>
            <p>Prix de l'attente.</p>
          </div>
        </div>
      </div>

      <p class="reveal adoption-cta">
        <a href="#contact" class="link-arrow">
          Bouger pendant que la courbe monte <Icon name="arrow-right" size={16} class="arrow" />
        </a>
      </p>
    </div>
  </section>


  <!-- =========================================
       SECTION 3 — CE QU'ON CONSTRUIT (3 piliers)
       ========================================= -->
  <section id="construit" class="section section--accent" aria-labelledby="quoi-title">
    <div class="container">
      <p class="eyebrow reveal">Ce qu'on construit</p>

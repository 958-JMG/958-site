            <text x="160" y="370" text-anchor="middle" class="ap-state-txt">Pionniers</text>
          </g>
          <g class="ap-label ap-label--here">
            <text x="420" y="220" text-anchor="middle" class="ap-year-txt ap-year-here">2025–2026</text>
            <text x="420" y="205" text-anchor="middle" class="ap-state-txt ap-state-here">Différenciation</text>
            <text x="420" y="270" text-anchor="middle" class="ap-here-txt">↑ Vous êtes ici</text>
          </g>
          <g class="ap-label">
            <text x="700" y="55" text-anchor="middle" class="ap-year-txt">2027</text>
            <text x="700" y="40" text-anchor="middle" class="ap-state-txt">Standard</text>
          </g>

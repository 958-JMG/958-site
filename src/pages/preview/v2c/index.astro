          <text x="960" y="345" text-anchor="end" class="ap-axis">~ 100 %</text>
        </svg>

        <!-- Bénéfices/coûts sous la courbe -->
        <div class="adoption-meta">
          <div class="adoption-cell adoption-cell--pioneer">
            <span class="ac-tag">2024</span>

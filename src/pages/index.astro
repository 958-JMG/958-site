  "image": "https://958.fr/images/golfe.webp",
  "email": "jmg@958.fr",
  "identifier": "912 884 228",
  "description": "9·58 installe l'IA dans les TPE/PME : elle gère, trie, anticipe. Conçu en Bretagne.",
  "founder": { "@type": "Person", "name": "Jean Marc Geuring" },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "1 bis rue Thiers",
    "postalCode": "56000",
    "addressLocality": "Vannes",
    "addressCountry": "FR"

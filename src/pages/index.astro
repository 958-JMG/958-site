<meta property="og:image" content="https://958.fr/images/golfe.webp">
<meta property="og:image:width" content="1600">
<meta property="og:image:height" content="1066">
<meta property="og:image:alt" content="9·58 — l'IA au service des dirigeants, conçu en Bretagne">
<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="9·58 | L'IA prépare. Vous décidez.">
<meta name="twitter:description" content="9·58 installe l'IA dans votre entreprise : elle gère, trie, anticipe. Vous menez. Conçu en Bretagne.">
<meta name="twitter:image" content="https://958.fr/images/golfe.webp">

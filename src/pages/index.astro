---
import Header from '../components/Header.astro';
import Deck from '../components/Deck.astro';
import Reveal from '../components/Reveal.astro';
import Manifeste from '../components/Manifeste.astro';
import Breath from '../components/Breath.astro';
import Marquee from '../components/Marquee.astro';
import Preuve from '../components/Preuve.astro';
import Recit from '../components/Recit.astro';
import Objection from '../components/Objection.astro';
import Steps from '../components/Steps.astro';
import Faq from '../components/Faq.astro';
import Fermeture from '../components/Fermeture.astro';
import Footer from '../components/Footer.astro';
import StickyCta from '../components/StickyCta.astro';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="9·58 installe l'IA dans votre entreprise | elle gère, trie, anticipe. Vous menez. Conçu en Bretagne.">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<title>9·58 | L'IA prépare. Vous décidez.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Instrument+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
  <Header />
  <Deck />
  <Reveal />
  <Manifeste />
  <Breath />
  <Marquee />
  <Preuve />
  <Recit />
  <Objection />
  <Steps />
  <Faq />
  <Fermeture />
  <Footer />
  <StickyCta />
  <script src="/js/main.js" is:inline></script>
</body>
</html>

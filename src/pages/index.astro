---

<V2bLayout
  title="On installe l'IA dans votre entreprise"
  description="60 % de votre croissance dort déjà dans vos données. 9·58 construit l'outil sur-mesure qui les fait parler. Pour artisans, architectes, promoteurs, agences et syndics. Vannes & Paris."
>
  <!-- =========================================
       HEADER
       ========================================= -->
  <V2cHeader currentSection="produit" />

  <!-- =========================================
       HERO — Pivot B : texte court + démo cockpit live
       ========================================= -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="container hero-grid">

      <!-- Colonne texte (gauche) -->
      <div class="hero-copy">
        <p class="eyebrow reveal">
          9·58 — Bretagne, depuis 2022
        </p>

        <h1 id="hero-title" class="manifesto reveal">
          On installe l'IA<br>
          dans votre entreprise.
        </h1>

        <p class="killer-line reveal">
          Votre entreprise<br>
          dans votre poche.
        </p>

        <div class="hero-ctas reveal">
          <a href="/diagnostic/" class="btn btn--primary btn--lg">
            Demander un diagnostic
            <Icon name="arrow-right" size={18} class="arrow" />
          </a>
          <a href="https://demo.958.fr" target="_blank" rel="noopener" class="btn btn--ghost btn--lg">
            Voir une démo sectorielle
            <Icon name="arrow-up-right" size={18} class="arrow" />
          </a>
        </div>

        <ul class="hero-assurances reveal">
          <li>Réponse sous 48 h</li>
          <li>Accord de confidentialité</li>
          <li>Premier échange offert</li>
        </ul>
      </div>

      <!-- Colonne démo cockpit (droite) -->
      <div class="hero-demo reveal" aria-label="Aperçu de l'écran 9·58">
        <div class="cockpit">
          <header class="cockpit-bar">
            <span class="cockpit-brand">9·58</span>
            <span class="cockpit-cabinet">Bâtiment Martin · Vannes</span>
            <span class="cockpit-version">v1.7 · sur-mesure</span>
            <span class="cockpit-time" id="cockpit-time">08:47</span>
          </header>

          <div class="cockpit-grid">
            <!-- Card Tréso -->
            <article class="cockpit-card cockpit-card--treso">
              <div class="cc-head">
                <span class="cc-label">Tréso prévue 90 j</span>
                <span class="cc-dot cc-dot--warn" aria-hidden="true"></span>
              </div>
              <div class="cc-value">
                +<span class="treso-num">28 540</span> €
              </div>
              <div class="cc-spark" aria-hidden="true">
                <svg viewBox="0 0 100 30" preserveAspectRatio="none">
                  <polyline points="0,18 12,15 24,20 36,12 48,14 60,8 72,16 84,22 96,26"
                            fill="none" stroke="currentColor" stroke-width="1.6"/>
                  <circle cx="96" cy="26" r="2.5" fill="currentColor"/>
                </svg>
              </div>
              <p class="cc-note">↘ -3 200 € prévu semaine 34</p>
            </article>

            <!-- Card Chantiers -->
            <article class="cockpit-card cockpit-card--chantiers">
              <div class="cc-head">
                <span class="cc-label">3 chantiers en cours</span>
              </div>
              <ul class="cc-chantiers">
                <li>
                  <div class="cc-chantier-row">
                    <span class="cc-tag cc-tag--ok">✓</span>
                    <span class="cc-chantier-nom">Klein — gros œuvre</span>
                    <span class="cc-chantier-pct">68 %</span>
                  </div>
                  <div class="cc-progress"><span style="width: 68%; background: var(--vert-mousse);"></span></div>
                </li>
                <li>
                  <div class="cc-chantier-row">
                    <span class="cc-tag cc-tag--warn">!</span>
                    <span class="cc-chantier-nom">Lefèvre — second œuvre</span>
                    <span class="cc-chantier-pct">42 %</span>
                  </div>
                  <div class="cc-progress"><span style="width: 42%; background: var(--warn);"></span></div>
                </li>
                <li>
                  <div class="cc-chantier-row">
                    <span class="cc-tag">·</span>
                    <span class="cc-chantier-nom">Dupuis — finitions</span>
                    <span class="cc-chantier-pct">91 %</span>
                  </div>
                  <div class="cc-progress"><span style="width: 91%; background: var(--cuivre);"></span></div>
                </li>
              </ul>
            </article>

            <!-- Card Mails IA -->
            <article class="cockpit-card cockpit-card--mails">
              <div class="cc-head">
                <span class="cc-label">12 mails lus ce matin</span>
              </div>
              <div class="cc-mail-draft">
                <span class="cc-mail-to">→ Sophie Lefort</span>
                <p class="cc-mail-body">
                  <span class="typing">Bonjour Sophie, suite à notre…</span>
                </p>
                <span class="cc-mail-badge">Brouillon prêt</span>
              </div>
            </article>

            <!-- Card RH / Équipe -->
            <article class="cockpit-card cockpit-card--rh">
              <div class="cc-head">
                <span class="cc-label">Équipe — semaine 22</span>
              </div>
              <ul class="cc-rh">
                <li>
                  <span class="cc-rh-name">Pierre M.</span>
                  <div class="cc-progress"><span style="width: 82%; background: var(--vert-mousse);"></span></div>
                  <span class="cc-rh-pct">82 %</span>
                </li>
                <li>
                  <span class="cc-rh-name">Sophie L.</span>
                  <div class="cc-progress"><span style="width: 91%; background: var(--cuivre);"></span></div>
                  <span class="cc-rh-pct">91 %</span>
                </li>
                <li>
                  <span class="cc-rh-name">Marc D.</span>
                  <div class="cc-progress"><span style="width: 38%; background: var(--ink-3);"></span></div>
                  <span class="cc-rh-pct">38 %</span>
                </li>
              </ul>
              <p class="cc-note cc-note--info">+ 1 congé prévu semaine 24</p>
            </article>

            <!-- Card Pipeline Kanban (full-width) -->
            <article class="cockpit-card cockpit-card--kanban">
              <div class="cc-head">
                <span class="cc-label cc-label--ai">
                  <span class="cc-pulse" aria-hidden="true"></span>
                  Pipeline — auto-trié par l'IA
                </span>
                <span class="cc-kanban-meta">↻ 2 cartes déplacées ce matin</span>
              </div>
              <div class="cc-kanban">
                <div class="cc-kcol">
                  <span class="cc-kcol-h">Devis</span>
                  <span class="cc-kcard">Garage L. — 8 200 €</span>
                  <span class="cc-kcard cc-kcard--moving">Cabinet R. — 4 750 €</span>
                  <span class="cc-kcol-count">3</span>
                </div>
                <div class="cc-kcol">
                  <span class="cc-kcol-h">Accepté</span>
                  <span class="cc-kcard">Klein — 18 400 €</span>
                  <span class="cc-kcol-count">2</span>
                </div>
                <div class="cc-kcol">
                  <span class="cc-kcol-h">Chantier</span>
                  <span class="cc-kcard">Lefèvre — 32 100 €</span>
                  <span class="cc-kcard">Dupuis — 7 800 €</span>
                  <span class="cc-kcol-count">4</span>
                </div>
                <div class="cc-kcol">
                  <span class="cc-kcol-h">Facturé</span>
                  <span class="cc-kcard">Morel — 12 600 €</span>
                  <span class="cc-kcol-count">1</span>
                </div>
              </div>
            </article>

            <!-- Card Suggestion IA (full-width) -->
            <article class="cockpit-card cockpit-card--ai">
              <div class="cc-head">
                <span class="cc-label cc-label--ai">
                  <span class="cc-pulse" aria-hidden="true"></span>
                  Suggestion IA
                </span>
              </div>
              <p class="cc-ai-text">
                Client Klein paie en moyenne <strong>+22 jours</strong> de retard sur les 3 derniers chantiers.
                Demander un acompte de 30 % au prochain devis ?
              </p>
              <div class="cc-ai-actions">
                <button class="cc-ai-btn cc-ai-btn--primary" type="button">Appliquer</button>
                <button class="cc-ai-btn" type="button">Plus tard</button>
              </div>
            </article>
          </div>
        </div>
      </div>

    </div>
  </section>

  <script>
    // Anim subtile : l'heure qui avance + le chiffre tréso qui varie légèrement
    const timeEl = document.getElementById('cockpit-time');
    const tresoEl = document.querySelector('.treso-num');
    if (timeEl) {
      let h = 8, m = 47;
      setInterval(() => {
        m++;
        if (m >= 60) { m = 0; h++; }
        timeEl.textContent = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
      }, 3500);
    }
    if (tresoEl) {
      let val = 28540;
      setInterval(() => {
        val += Math.round((Math.random() - 0.5) * 800);
        tresoEl.textContent = val.toLocaleString('fr-FR');
      }, 4200);
    }

    // Animation kanban one-shot (R5 du design-critique) :
    // déclenchée une seule fois quand le mockup entre dans le viewport.
    const movingCard = document.querySelector('.cc-kcard--moving');
    if (movingCard) {
      const kanbanObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-playing');
            kanbanObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.4 });
      kanbanObs.observe(movingCard);
    }

    // Compteurs animés sur les chiffres preuve (au scroll-in)
    function parseProofValue(str) {
      const match = str.match(/^([+\-]?)(\d+)(.*)$/);
      if (!match) return null;
      return { prefix: match[1] || '', number: parseInt(match[2], 10), suffix: match[3] || '' };
    }
    function animateCounter(el, parsed) {
      const duration = 1400;
      const start = performance.now();
      const target = parsed.number;
      const step = (now) => {
        const t = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - t, 3); // ease-out cubic
        const current = Math.round(target * eased);
        el.textContent = `${parsed.prefix}${current}${parsed.suffix}`;
        if (t < 1) requestAnimationFrame(step);
        else el.textContent = `${parsed.prefix}${target}${parsed.suffix}`;
      };
      requestAnimationFrame(step);
    }
    const proofObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        if (el.dataset.animated) return;
        el.dataset.animated = '1';
        const parsed = parseProofValue(el.dataset.final || el.textContent.trim());
        if (parsed) animateCounter(el, parsed);
        proofObs.unobserve(el);
      });
    }, { threshold: 0.4 });
    document.querySelectorAll('.proof-v').forEach((el) => {
      // Démarre à 0 pour donner l'effet "le chiffre apparaît"
      const parsed = parseProofValue(el.dataset.final || el.textContent.trim());
      if (parsed) el.textContent = `${parsed.prefix}0${parsed.suffix}`;
      proofObs.observe(el);
    });
  </script>

  <!-- =========================================
       BANDEAU CLARIF — anti "ça fait CRM"
       ========================================= -->
  <section class="section section--clarif is-tight" aria-label="Précision sur le produit">
    <div class="container is-default">
      <p class="reveal clarif-text">
        Ce que vous venez de voir, c'est l'écran d'un <strong>artisan bâtiment de Bretagne</strong>.
        Construit pour <em>ses</em> devis, <em>ses</em> chantiers, <em>son</em> équipe.
        <strong>Pas un CRM. Pas un logiciel comptable. Pas un outil pour tout le monde.</strong>
        Le vôtre ne lui ressemblera pas — il vous ressemblera, à vous.
      </p>
    </div>
  </section>



  <!-- =========================================
       SECTION 3 — CE QU'ON CONSTRUIT (3 piliers)
       ========================================= -->
  <section id="construit" class="section" aria-labelledby="quoi-title">
    <div class="container">
      <h2 id="quoi-title" class="reveal section-h2">
        Un écran. Le vôtre.
      </h2>

      <div class="piliers-grid">
        <div class="pilier reveal">
          <div class="pilier-icon"><Icon name="monitor" size={28} strokeWidth={1.5} /></div>
          <h3 class="pilier-h">L'écran</h3>
          <p class="pilier-sub">Tout votre métier, au même endroit, en temps réel.</p>
        </div>
        <div class="pilier reveal">
          <div class="pilier-icon"><Icon name="sparkles" size={28} strokeWidth={1.5} /></div>
          <h3 class="pilier-h">La couche IA</h3>
          <p class="pilier-sub">Elle trie, rédige, anticipe — à votre ton.</p>
        </div>
        <div class="pilier reveal">
          <div class="pilier-icon"><Icon name="shield" size={28} strokeWidth={1.5} /></div>
          <h3 class="pilier-h">La souveraineté</h3>
          <p class="pilier-sub">À votre nom. Vous décidez de tout.</p>
        </div>
      </div>
      <p class="reveal piliers-link">
        <a href="/produit/" class="link-arrow">Voir le produit en détail <Icon name="arrow-right" size={16} class="arrow" /></a>
      </p>
    </div>
  </section>

  <!-- =========================================
       SECTION 3.5 — MANIFESTE WHY (Tilt® + 9·58)
       ========================================= -->
  <Manifeste958 variant="soft" />

  <!-- =========================================
       SECTION 4 — LA MÉTHODE (mini-timeline ultra-compressée)
       ========================================= -->
  <section id="methode" class="section" aria-labelledby="methode-title">
    <div class="container is-default">
      <h2 id="methode-title" class="reveal section-h2">
        Quatre temps. Sans bruit. Sans dépendance.
      </h2>

      <ol class="steps-mini reveal">
        <li><span class="sm-n">01</span> <span class="sm-h">Audit</span> <span class="sm-d">1 jour · sous accord de confidentialité</span></li>
        <li><span class="sm-n">02</span> <span class="sm-h">Structuration</span> <span class="sm-d">7 jours · plan chiffré</span></li>
        <li><span class="sm-n">03</span> <span class="sm-h">Construction</span> <span class="sm-d">7 jours · votre écran, vos sources</span></li>
        <li><span class="sm-n">04</span> <span class="sm-h">Suivi</span> <span class="sm-d">3 à 12 mois · vous gardez la main</span></li>
      </ol>
      <p class="reveal methode-link">
        <a href="/methode/" class="link-arrow">Voir la méthode en détail <Icon name="arrow-right" size={16} class="arrow" /></a>
      </p>
    </div>
  </section>

  <!-- =========================================
       SECTION 6 — RÉALISATIONS (6 cas — Avant / Après)
       ========================================= -->
  <section id="preuve" class="section" aria-labelledby="preuve-title">
    <div class="container">
      <div class="section-head">
        <h2 id="preuve-title" class="reveal section-h2">
          Vos données.<br>
          <em>Votre destin.</em>
        </h2>
        <p class="reveal section-sub">6 projets. 6 transformations.</p>
      </div>

      <div class="reals-grid">
        {realisations.map((r) => (
          <article class="real-card reveal">
            <header class="real-head">
              <span class="real-n">{r.n}</span>
              <div>
                <span class="real-secteur">{r.secteur}</span>
                <p class="real-sous">{r.sousTitre}</p>
              </div>
            </header>

            <div class="real-flow">
              <div class="real-state real-state--avant">
                <span class="real-state-tag">Avant</span>
                <p>{r.avant}</p>
              </div>
              <span class="real-arrow" aria-hidden="true">
                <Icon name="arrow-right" size={22} strokeWidth={2} />
              </span>
              <div class="real-state real-state--apres">
                <span class="real-state-tag real-state-tag--apres">Après</span>
                <p>{r.apres}</p>
              </div>
            </div>

            <p class="real-phase">{r.phase}</p>
          </article>
        ))}
      </div>

      <div class="reveal real-tilt">
        <p class="real-outro">
          Une formation IA ne vaut rien<br>
          si elle se finit le vendredi soir.
        </p>
        <p class="real-tilt-sub">
          C'est pourquoi <strong>Ça fait Tilt®</strong> ne s'arrête pas à l'atelier.
          On accompagne le dirigeant et son équipe au-delà — <em>30 · 60 · 90 jours</em>
          après la formation, pendant que les pratiques s'installent vraiment.
        </p>
        <div class="real-tilt-ctas">
          <a href="/formation/" class="btn btn--primary btn--lg">
            Découvrir Ça fait Tilt<sup aria-label="marque déposée">®</sup>
            <Icon name="arrow-right" size={18} class="arrow" />
          </a>
          <a href="/diagnostic/" class="btn btn--ghost btn--lg">
            Demander un diagnostic
            <Icon name="arrow-right" size={18} class="arrow" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================
       SECTION 6.5 — 3 PORTES D'ENTRÉE
       ========================================= -->
  <PortesEntree variant="soft" />

  <!-- =========================================
       SECTION 7 — CTA FINAL
       ========================================= -->
  <section id="contact" class="section section--accent" aria-labelledby="cta-title">
    <div class="container is-default cta-inner">
      <h2 id="cta-title" class="reveal cta-title">
        Un audit. Un jour. <em>Sous accord de confidentialité.</em>
      </h2>
      <p class="reveal cta-lead">
        Je regarde votre contexte. Je vous dis honnêtement ce que 9·58 peut faire pour vous —
        et ce qu'il ne peut pas. Sans engagement pour la suite.
      </p>
      <div class="cta-ctas reveal">
        <a href="/diagnostic/" class="btn btn--lg btn-on-accent">
          Demander un diagnostic
          <Icon name="arrow-right" size={18} class="arrow" />
        </a>
        <a href="https://demo.958.fr" target="_blank" rel="noopener" class="btn btn--ghost btn--lg btn--on-accent-ghost">
          Voir une démo sectorielle
          <Icon name="arrow-up-right" size={18} class="arrow" />
        </a>
      </div>
    </div>
  </section>

  <V2cFooter />
</V2bLayout>

<style>
  /* Header/Footer/Brand styles : voir V2cHeader.astro + V2cFooter.astro */

  /* ============ HERO (layout 2 col + démo) ============ */
  .hero {
    padding-block: var(--s-10) var(--s-9);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: var(--s-9);
    align-items: center;
  }
  .hero-copy {
    display: flex;
    flex-direction: column;
  }
  .hero-copy .eyebrow { margin-bottom: var(--s-5); }
  .hero-copy .manifesto {
    margin-bottom: var(--s-5);
    max-width: 14ch;
  }
  .hero-copy .killer-line {
    margin-bottom: var(--s-6);
  }
  .hero-ctas {
    display: flex;
    gap: var(--s-3);
    flex-wrap: wrap;
    align-items: center;
  }
  .hero-assurances {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-5);
    margin-top: var(--s-6);
    list-style: none;
    padding: 0;
  }
  .hero-assurances li {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-3);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    position: relative;
    padding-left: 14px;
  }
  .hero-assurances li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    background: var(--cuivre);
    border-radius: 50%;
  }

  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--s-8);
    }
    .hero-copy .manifesto { max-width: 100%; }
  }

  @media (max-width: 720px) {
    .hero { padding-block: var(--s-7) var(--s-7); }
  }

  /* ============ COCKPIT DEMO (mockup) ============ */
  .hero-demo {
    perspective: 1200px;
  }
  .cockpit {
    background: var(--bg-2);
    border: 1px solid var(--line-2);
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
      0 30px 80px -20px rgba(0,0,0,0.6),
      0 0 0 1px rgba(244, 236, 220, 0.05),
      0 8px 24px -8px rgba(199, 95, 45, 0.18);
    transform: rotateY(-2deg) rotateX(2deg);
    transition: transform 0.6s var(--ease);
  }
  .cockpit:hover {
    transform: rotateY(0) rotateX(0);
  }

  .cockpit-bar {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    padding: 12px 16px;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
  }
  .cockpit-brand {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--cuivre);
    font-size: 16px;
    letter-spacing: -0.02em;
  }
  .cockpit-cabinet {
    color: var(--ink-2);
    flex: 1;
    text-transform: uppercase;
  }
  .cockpit-time {
    color: var(--ink-3);
  }
  .cockpit-version {
    font-size: 10px;
    color: var(--cuivre);
    border: 1px solid var(--cuivre);
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--cuivre-soft);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .cockpit-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
  }
  .cockpit-card {
    background: var(--bg-2);
    padding: var(--s-4) var(--s-5);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    min-height: 130px;
  }
  .cockpit-card--ai {
    grid-column: 1 / -1;
    background: linear-gradient(180deg, var(--cuivre-soft) 0%, var(--bg-2) 100%);
    border-top: 1px solid var(--cuivre);
  }
  .cc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .cc-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .cc-label--ai {
    color: var(--cuivre);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .cc-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--vert-mousse);
  }
  .cc-dot--warn { background: var(--warn); }
  .cc-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--cuivre);
    box-shadow: 0 0 0 0 var(--cuivre);
    animation: cc-pulse 2s var(--ease) infinite;
  }
  @keyframes cc-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(199, 95, 45, 0.6); }
    50% { box-shadow: 0 0 0 8px transparent; }
  }

  .cc-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 28px;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ivoire);
  }
  .cc-spark {
    color: var(--cuivre);
    margin-top: -4px;
  }
  .cc-spark svg {
    width: 100%;
    height: 24px;
  }
  .cc-note {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--warn);
    margin: 0;
    max-width: none;
    letter-spacing: 0.02em;
  }

  .cc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .cc-list li {
    font-size: 12px;
    color: var(--ink-2);
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 1.4;
  }

  /* Chantiers — progress rows */
  .cc-chantiers {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cc-chantiers li {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cc-chantier-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--ink-2);
  }
  .cc-chantier-nom { flex: 1; }
  .cc-chantier-pct {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.02em;
  }
  .cc-progress {
    height: 4px;
    background: var(--bg);
    border-radius: 999px;
    overflow: hidden;
    position: relative;
  }
  .cc-progress > span {
    display: block;
    height: 100%;
    border-radius: 999px;
    transition: width 0.8s var(--ease-out);
  }

  /* RH / Équipe */
  .cc-rh {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cc-rh li {
    display: grid;
    grid-template-columns: 60px 1fr 32px;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--ink-2);
  }
  .cc-rh-name {
    font-weight: 500;
    color: var(--ivoire-2);
  }
  .cc-rh-pct {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    text-align: right;
    letter-spacing: 0.02em;
  }
  .cc-note--info {
    color: var(--ink-3);
    margin-top: 4px;
  }

  /* Pipeline kanban */
  .cockpit-card--kanban {
    grid-column: 1 / -1;
    padding: var(--s-4) var(--s-5);
    overflow: hidden;
  }
  .cc-kanban-meta {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .cc-kanban {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    margin-top: 4px;
  }
  .cc-kcol {
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    position: relative;
    min-height: 110px;
  }
  .cc-kcol-h {
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--cuivre);
    font-weight: 600;
  }
  .cc-kcard {
    background: var(--bg-3);
    border: 1px solid var(--line-2);
    border-radius: 4px;
    padding: 5px 7px;
    font-size: 10px;
    color: var(--ivoire-2);
    line-height: 1.3;
    transition: transform 0.6s var(--ease), background 0.6s var(--ease);
  }
  .cc-kcard--moving {
    position: relative;
    z-index: 5;
    border-color: var(--cuivre);
  }
  .cc-kcard--moving.is-playing {
    animation: kanban-move 6s var(--ease-out) 1 forwards;
  }
  @keyframes kanban-move {
    /* Repos en Devis */
    0%, 18% {
      transform: translate(0, 0) scale(1);
      background: var(--bg-3);
      opacity: 1;
      box-shadow: none;
    }
    /* Pickup : la carte se soulève (z-index passe au-dessus) */
    24%, 30% {
      transform: translate(0, -3px) scale(1.03);
      background: var(--cuivre-soft);
      opacity: 1;
      box-shadow: 0 12px 24px -6px rgba(0,0,0,0.65);
    }
    /* Drag horizontal vers Accepté (par dessus, pas par dessous) */
    45%, 52% {
      transform: translate(calc(100% + 12px), -3px) scale(1.03);
      background: var(--cuivre-soft);
      opacity: 1;
      box-shadow: 0 12px 24px -6px rgba(0,0,0,0.65);
    }
    /* Drop dans Accepté : descente + fade out */
    60%, 66% {
      transform: translate(calc(100% + 12px), 0) scale(1);
      background: var(--cuivre-soft);
      opacity: 0;
      box-shadow: none;
    }
    /* Retour invisible vers Devis (téléportation discrète) */
    68%, 78% {
      transform: translate(0, 0) scale(1);
      background: var(--bg-3);
      opacity: 0;
    }
    /* Réapparition douce à l'origine */
    90%, 100% {
      transform: translate(0, 0) scale(1);
      background: var(--bg-3);
      opacity: 1;
    }
  }
  .cc-kcol-count {
    position: absolute;
    top: 6px;
    right: 8px;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--ink-3);
    background: var(--bg-3);
    padding: 1px 5px;
    border-radius: 999px;
  }
  .cc-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    flex-shrink: 0;
    background: var(--bg-3);
    color: var(--ink-3);
  }
  .cc-tag--ok { background: var(--vert-mousse-soft); color: var(--vert-mousse); }
  .cc-tag--warn { background: var(--warn-soft); color: var(--warn); }

  .cc-mail-draft {
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: relative;
  }
  .cc-mail-to {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }
  .cc-mail-body {
    margin: 0;
    max-width: none;
    font-size: 12px;
    color: var(--ivoire-2);
    line-height: 1.4;
  }
  .typing {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    border-right: 1.5px solid var(--cuivre);
    animation: typing 4s steps(28) infinite, blink 1s step-end infinite;
    width: 28ch;
    max-width: 100%;
  }
  @keyframes typing {
    0% { width: 0; }
    60% { width: 28ch; }
    90% { width: 28ch; }
    100% { width: 0; }
  }
  @keyframes blink {
    50% { border-color: transparent; }
  }
  .cc-mail-badge {
    position: absolute;
    top: -8px;
    right: 8px;
    background: var(--cuivre);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 999px;
  }

  .cc-ai-text {
    margin: 0;
    max-width: none;
    font-size: 13px;
    color: var(--ivoire);
    line-height: 1.5;
  }
  .cc-ai-text strong {
    color: var(--cuivre);
    font-weight: 600;
  }
  .cc-ai-actions {
    display: flex;
    gap: 8px;
    margin-top: 4px;
  }
  .cc-ai-btn {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 6px;
    border: 1px solid var(--line-2);
    background: transparent;
    color: var(--ink-2);
    cursor: pointer;
    transition: all var(--dur-1) var(--ease);
  }
  .cc-ai-btn:hover {
    border-color: var(--cuivre);
    color: var(--cuivre);
  }
  .cc-ai-btn--primary {
    background: var(--cuivre);
    color: var(--bg);
    border-color: var(--cuivre);
  }
  .cc-ai-btn--primary:hover {
    background: var(--cuivre-hover);
    color: var(--bg);
  }

  @media (max-width: 720px) {
    .cockpit { transform: none; }
    .cockpit-grid { grid-template-columns: 1fr; }
    .cockpit-card { min-height: auto; }
    .cc-value { font-size: 24px; }
  }

  /* ============ SECTION HEAD ============ */
  .section-head {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    margin-bottom: var(--s-8);
    max-width: 720px;
  }
  .section-h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw + 0.5rem, 3.25rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: var(--tr-tighter);
    color: var(--ink);
    max-width: 22ch;
    text-wrap: balance;
    margin: 0;
  }
  .section-h2 em { font-style: italic; color: var(--cuivre); }
  .section-sub {
    font-size: var(--step-2);
    line-height: var(--lh-normal);
    color: var(--ink-2);
    max-width: 60ch;
    margin: 0;
  }

  /* ============ BANDEAU CLARIF (anti "ça fait CRM") ============ */
  .section--clarif {
    background: var(--bg);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: var(--s-7);
  }
  .clarif-text {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 1.5vw + 0.3rem, 1.5rem);
    line-height: 1.5;
    color: var(--ivoire-2);
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    text-wrap: balance;
    font-weight: 400;
  }
  .clarif-text strong { color: var(--ivoire); font-weight: 500; }
  .clarif-text em { color: var(--cuivre); font-style: italic; font-weight: 500; }

  /* ============ COURBE D'ADOPTION (SVG) ============ */
  .adoption-curve {
    margin-top: var(--s-7);
    color: var(--ivoire);
  }
  .adoption-svg {
    width: 100%;
    height: auto;
    max-height: 440px;
    display: block;
  }
  .adoption-path {
    stroke-dasharray: 1500;
    stroke-dashoffset: 1500;
    animation: drawCurve 2.4s var(--ease-out) 0.3s forwards;
  }
  @keyframes drawCurve {
    to { stroke-dashoffset: 0; }
  }

  .ap-year-txt {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .ap-state-txt {
    font-family: var(--font-display);
    font-size: 14px;
    fill: var(--ivoire);
    font-weight: 500;
  }
  .ap-year-here {
    fill: var(--mimosa);
    font-weight: 600;
  }
  .ap-state-here {
    fill: var(--mimosa);
    font-style: italic;
  }
  .ap-here-txt {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--mimosa);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .ap-axis {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--ink-3);
    letter-spacing: 0.04em;
  }

  /* Tableau métadonnées sous la courbe */
  .adoption-meta {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-3);
    margin-top: var(--s-5);
  }
  .adoption-cell {
    padding: var(--s-4);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .adoption-cell--here {
    background: rgba(254, 248, 108, 0.06);
    border-color: var(--mimosa);
  }
  .adoption-cell--pioneer .ac-tag { color: var(--vert-mousse); border-color: var(--vert-mousse); }
  .adoption-cell--std .ac-tag { color: var(--ink-3); }
  .adoption-cell--late .ac-tag { color: var(--ink-3); opacity: 0.7; }
  .ac-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--cuivre);
    padding: 3px 8px;
    border: 1px solid currentColor;
    border-radius: var(--r-pill);
    align-self: flex-start;
    font-weight: 500;
  }
  .ac-tag--here {
    color: var(--mimosa);
    background: var(--mimosa);
    color: var(--bg);
    border-color: var(--mimosa);
  }
  .adoption-cell p {
    font-size: var(--step-0);
    color: var(--ink-2);
    margin: 0;
    line-height: var(--lh-normal);
    max-width: none;
  }

  @media (max-width: 720px) {
    .adoption-meta { grid-template-columns: repeat(2, 1fr); }
  }

  /* ============ SCHÉMA ADOPTION (legacy, conservé) ============ */
  .adoption-schema {
    position: relative;
    margin-top: var(--s-7);
    padding-block: var(--s-7) var(--s-5);
  }
  .adoption-line {
    position: absolute;
    top: 90px;
    left: 6%;
    right: 6%;
    height: 2px;
    background: linear-gradient(90deg,
      var(--cuivre) 0%,
      var(--cuivre) 30%,
      var(--mimosa) 38%,
      var(--mimosa) 52%,
      var(--ink-3) 70%,
      var(--ink-3) 100%);
    opacity: 0.55;
  }
  .adoption-points {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-4);
    position: relative;
  }
  .adoption-point {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--s-2);
    padding-top: 50px;
    position: relative;
  }
  .ap-dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--cuivre);
    position: absolute;
    top: 82px;
    left: 50%;
    transform: translateX(-50%);
    box-shadow: 0 0 0 4px var(--bg-2);
  }
  .ap-pioneer .ap-dot { background: var(--vert-mousse); }
  .ap-now .ap-dot-pulse {
    background: var(--mimosa);
    width: 22px;
    height: 22px;
    top: 80px;
    animation: ap-pulse 2.4s var(--ease) infinite;
  }
  .ap-standard .ap-dot { background: var(--ink-3); }
  .ap-late .ap-dot { background: var(--ink-3); opacity: 0.55; }

  @keyframes ap-pulse {
    0%, 100% { box-shadow: 0 0 0 4px var(--bg-2), 0 0 0 0 var(--mimosa-soft, rgba(254,248,108,0.45)); }
    50%      { box-shadow: 0 0 0 4px var(--bg-2), 0 0 0 12px transparent; }
  }

  .ap-here {
    position: absolute;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mimosa);
    white-space: nowrap;
    padding: 4px 10px;
    background: var(--bg);
    border: 1px solid var(--mimosa);
    border-radius: var(--r-pill);
    font-weight: 500;
  }
  .ap-here::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 100%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: var(--mimosa);
    margin-top: 1px;
  }

  .ap-year {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.06em;
    color: var(--ink-3);
    text-transform: uppercase;
    margin-top: var(--s-4);
  }
  .ap-now .ap-year { color: var(--mimosa); }

  .ap-state {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--step-2);
    color: var(--ink);
    letter-spacing: -0.015em;
    margin: 0;
    line-height: 1.2;
    max-width: 18ch;
  }
  .ap-pioneer .ap-state { color: var(--ivoire); }
  .ap-now .ap-state { color: var(--ivoire); }
  .ap-late .ap-state { color: var(--ink-2); }

  .ap-desc {
    font-size: var(--step-0);
    color: var(--ink-2);
    margin: 0;
    max-width: 22ch;
    line-height: var(--lh-normal);
  }
  .ap-pioneer .ap-desc { color: var(--vert-mousse); }
  .ap-now .ap-desc { color: var(--mimosa); }
  .ap-late .ap-desc { color: var(--ink-3); }

  .adoption-cta {
    margin-top: var(--s-6);
  }

  @media (max-width: 720px) {
    .adoption-points { grid-template-columns: 1fr; gap: var(--s-6); }
    .adoption-line {
      top: 0;
      bottom: 0;
      left: 30px;
      right: auto;
      width: 2px;
      height: auto;
      background: linear-gradient(180deg,
        var(--vert-mousse) 0%,
        var(--cuivre) 20%,
        var(--mimosa) 35%,
        var(--mimosa) 52%,
        var(--ink-3) 70%,
        var(--ink-3) 100%);
    }
    .adoption-point {
      align-items: flex-start;
      text-align: left;
      padding-top: 0;
      padding-left: 60px;
      min-height: 80px;
    }
    .ap-dot {
      top: 8px;
      left: 30px;
      transform: translateX(-50%);
    }
    .ap-now .ap-dot-pulse { top: 6px; }
    .ap-here {
      position: static;
      transform: none;
      margin-bottom: var(--s-2);
      display: inline-block;
    }
    .ap-here::after { display: none; }
    .ap-year { margin-top: 0; }
    .ap-state, .ap-desc { max-width: 100%; }
  }

  /* ============ DORMENT (Vos données dorment) ============ */
  .dorment-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-6);
    margin-top: var(--s-5);
  }
  .dorment-item {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .dorment-n {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 3vw + 0.5rem, 2.75rem);
    line-height: 1;
    color: var(--cuivre);
    letter-spacing: -0.04em;
  }
  .dorment-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--step-3);
    color: var(--ink);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.2;
  }
  .dorment-h em { color: var(--cuivre); font-style: italic; }
  .dorment-item p { margin: 0; max-width: none; font-size: var(--step-1); }

  .dorment-chiffre {
    margin-top: var(--s-10);
    padding-top: var(--s-8);
    border-top: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .dorment-source {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-3);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
    max-width: none;
  }

  @media (max-width: 900px) {
    .dorment-grid { grid-template-columns: 1fr; gap: var(--s-7); }
  }

  /* ============ STEPS MINI (méthode compressée) ============ */
  .steps-mini {
    list-style: none;
    padding: 0;
    margin: var(--s-6) 0 var(--s-5) 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    max-width: 720px;
  }
  .steps-mini li {
    display: grid;
    grid-template-columns: 36px 1fr auto;
    gap: var(--s-4);
    align-items: baseline;
    padding: var(--s-3) 0;
    border-bottom: 1px solid var(--line);
  }
  .steps-mini li:last-child { border-bottom: 0; }
  .sm-n {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--cuivre);
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .sm-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--step-2);
    color: var(--ivoire);
    letter-spacing: -0.015em;
  }
  .sm-d {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-3);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-align: right;
  }
  .methode-link {
    margin-top: var(--s-3);
  }
  .piliers-link {
    margin-top: var(--s-6);
    text-align: center;
  }
  .link-arrow-on-accent {
    display: inline-flex; align-items: center; gap: 0.4rem;
    color: var(--ivoire);
    font-weight: 600;
    border-bottom: 1px solid var(--ivoire);
  }
  .link-arrow-on-accent:hover {
    color: var(--bg);
    background: var(--ivoire);
    border-bottom-color: var(--ivoire);
    padding: 2px 8px;
    border-radius: 4px;
  }
  .link-arrow-on-accent .arrow { transition: transform var(--dur-1) var(--ease); }
  .link-arrow-on-accent:hover .arrow { transform: translateX(3px); }

  @media (max-width: 640px) {
    .steps-mini li {
      grid-template-columns: 30px 1fr;
      grid-template-rows: auto auto;
    }
    .sm-d {
      grid-column: 2;
      text-align: left;
    }
  }

  /* ============ STEPS (méthode — legacy, conservé) ============ */
  .steps {
    list-style: none;
    padding: 0;
    margin: var(--s-7) 0 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
  }
  .step {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--s-5);
    padding: var(--s-5);
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    transition: border-color var(--dur-2) var(--ease);
  }
  .step:hover { border-color: var(--cuivre); }
  .step-n {
    font-family: var(--font-mono);
    font-size: var(--step-1);
    color: var(--cuivre);
    letter-spacing: 0.04em;
    font-weight: 500;
  }
  .step-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--step-3);
    color: var(--ink);
    margin: 0 0 var(--s-2) 0;
    letter-spacing: -0.02em;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    align-items: baseline;
  }
  .step-duree {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 400;
  }
  .step p { margin: 0; max-width: 64ch; }

  @media (max-width: 640px) {
    .step { grid-template-columns: 1fr; gap: var(--s-3); padding: var(--s-4); }
  }

  /* ============ PILIERS (accent cuivre) ============ */
  .piliers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-5);
    margin-top: var(--s-7);
  }
  .pilier {
    padding: var(--s-6);
    background: rgba(11, 11, 10, 0.28);
    border: 1px solid rgba(244, 236, 220, 0.2);
    border-radius: var(--r-3);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .pilier-icon {
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    color: var(--cuivre);
    border-radius: var(--r-3);
    margin-bottom: var(--s-2);
  }
  .pilier-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--step-3);
    color: var(--ivoire);
    letter-spacing: -0.02em;
    margin: 0;
  }
  .pilier-sub {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ivoire);
    margin: 0;
    max-width: none;
    font-size: var(--step-1);
  }
  .pilier-sub em { color: var(--ivoire); font-style: normal; font-weight: 600; }
  .pilier-body {
    color: var(--ivoire-2);
    font-size: var(--step-1);
    line-height: var(--lh-normal);
    margin: 0;
    max-width: none;
  }
  .pilier-body em { color: var(--ivoire); font-style: italic; }

  @media (max-width: 900px) {
    .piliers-grid { grid-template-columns: 1fr; }
  }

  /* ============ ENFONCER LE CLOU (Terrain) ============ */
  .terrain-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-4);
    margin-top: var(--s-7);
  }
  .terrain-card {
    padding: var(--s-5);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    transition: border-color var(--dur-2) var(--ease),
                transform var(--dur-2) var(--ease);
  }
  .terrain-card:hover {
    border-color: var(--cuivre);
    transform: translateY(-3px);
  }
  .terrain-head {
    display: flex;
    align-items: center;
    gap: var(--s-2);
  }
  .terrain-icon {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--cuivre);
    color: var(--bg);
    border-radius: var(--r-3);
    transition: transform var(--dur-2) var(--ease), box-shadow var(--dur-2) var(--ease);
  }
  .terrain-card:hover .terrain-icon {
    transform: scale(1.08) rotate(-3deg);
    box-shadow: var(--glow-cuivre);
  }
  .terrain-secteur {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cuivre);
    font-weight: 600;
  }
  .terrain-titre {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--step-3);
    color: var(--ivoire);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: none;
  }
  .terrain-body {
    color: var(--ink-2);
    font-size: var(--step-1);
    line-height: var(--lh-loose);
    margin: 0;
    max-width: none;
  }

  /* Indicateur de gain en pied de carte */
  .terrain-gain {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    padding-top: var(--s-3);
    border-top: 1px dashed var(--line-2);
  }
  .terrain-gain-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: var(--vert-mousse-soft);
    color: var(--vert-mousse);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .terrain-gain-label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--vert-mousse);
    font-weight: 600;
  }

  .terrain-outro {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-2);
    color: var(--ivoire-2);
    margin-top: var(--s-7);
    text-align: center;
    max-width: 60ch;
    margin-inline: auto;
    text-wrap: balance;
  }
  .terrain-outro em { color: var(--cuivre); font-style: italic; font-weight: 500; }

  /* Card IA proactive — Anniversaire client (full-width, distinguée vert) */
  .terrain-card--proactive {
    grid-column: 1 / -1;
    background: linear-gradient(135deg,
      var(--vert-mousse-soft) 0%,
      var(--bg) 60%,
      var(--cuivre-soft) 100%);
    border: 1px solid var(--vert-mousse);
    padding: var(--s-6);
    position: relative;
    overflow: hidden;
  }
  .terrain-icon--vert {
    background: var(--vert-mousse);
    color: var(--bg);
  }
  .terrain-secteur--vert {
    color: var(--vert-mousse);
  }
  .proactive-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--s-6);
    align-items: center;
  }
  .proactive-copy { display: flex; flex-direction: column; gap: var(--s-3); }
  .proactive-copy .terrain-gain {
    border-top: 1px dashed var(--vert-mousse);
    margin-top: var(--s-3);
    padding-top: var(--s-3);
  }
  .terrain-card--proactive .terrain-titre em {
    color: var(--vert-mousse);
    font-style: italic;
  }

  /* Mini-mockup du mail anniversaire */
  .proactive-mock {
    background: var(--bg-2);
    border: 1px solid var(--line-2);
    border-radius: var(--r-3);
    overflow: hidden;
    box-shadow: 0 20px 50px -20px rgba(0,0,0,0.6);
  }
  .pmock-bar {
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    padding: 8px 12px;
  }
  .pmock-from {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--vert-mousse);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .pmock-body { padding: 12px; display: flex; flex-direction: column; gap: 8px; }
  .pmock-to {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }
  .pmock-subject {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14px;
    color: var(--ivoire);
    letter-spacing: -0.01em;
  }
  .pmock-text {
    font-size: 11px;
    color: var(--ivoire-2);
    line-height: 1.55;
    margin: 0;
    max-width: none;
  }
  .pmock-offer {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px 10px;
    background: var(--cuivre-soft);
    border-left: 2px solid var(--cuivre);
    border-radius: 4px;
  }
  .pmock-offer-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--cuivre);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .pmock-offer-val {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14px;
    color: var(--ivoire);
  }
  .pmock-actions { display: flex; gap: 6px; margin-top: 2px; }
  .pmock-btn {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    padding: 5px 10px;
    border-radius: 4px;
    border: 1px solid var(--line-2);
    background: transparent;
    color: var(--ink-2);
  }
  .pmock-btn--primary {
    background: var(--vert-mousse);
    color: var(--bg);
    border-color: var(--vert-mousse);
  }

  @media (max-width: 900px) {
    .proactive-grid { grid-template-columns: 1fr; gap: var(--s-5); }
  }

  /* Card manifeste pleine largeur — Interroger ≠ Interpréter */
  .terrain-card--manifest {
    grid-column: 1 / -1;
    background: linear-gradient(135deg, var(--cuivre-soft) 0%, var(--bg) 70%);
    border: 1px solid var(--cuivre);
    padding: var(--s-7);
    position: relative;
    overflow: hidden;
  }
  .terrain-card--manifest::before {
    content: "";
    position: absolute;
    top: 0; right: 0;
    width: 200px; height: 200px;
    background: radial-gradient(circle, var(--cuivre-glow) 0%, transparent 65%);
    pointer-events: none;
  }
  .terrain-manifest-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--s-7);
    align-items: center;
    position: relative;
  }
  .terrain-icon--manifest {
    width: 40px;
    height: 40px;
    background: var(--cuivre);
    color: var(--bg);
  }
  .terrain-manifest-titre {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    line-height: 1.1;
    letter-spacing: var(--tr-tighter);
    color: var(--ivoire);
    margin: var(--s-4) 0 var(--s-4) 0;
    max-width: 22ch;
  }
  .terrain-manifest-titre em { color: var(--cuivre); font-style: italic; }
  .terrain-manifest-sub {
    font-size: var(--step-1);
    line-height: var(--lh-loose);
    color: var(--ink-2);
    margin: 0;
    max-width: 56ch;
  }
  .terrain-manifest-sub strong { color: var(--ivoire); font-weight: 600; }
  .terrain-manifest-list {
    list-style: none;
    padding: var(--s-5);
    margin: 0;
    background: rgba(11, 11, 10, 0.5);
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .terrain-manifest-list li {
    font-size: var(--step-0);
    color: var(--ivoire-2);
    display: flex;
    align-items: center;
    gap: 10px;
    line-height: 1.4;
  }
  .tm-bullet {
    color: var(--ink-3);
    font-weight: 700;
  }
  .tm-bullet--ai {
    color: var(--cuivre);
    animation: cc-pulse 2.4s var(--ease) infinite;
  }

  @media (max-width: 900px) {
    .terrain-grid { grid-template-columns: 1fr; }
    .terrain-manifest-grid { grid-template-columns: 1fr; gap: var(--s-5); }
    .terrain-card--manifest { padding: var(--s-5); }
  }

  /* ============ CIBLES (legacy, conservé) ============ */
  .cibles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-4);
    margin-top: var(--s-7);
  }
  .cible {
    display: flex;
    gap: var(--s-4);
    padding: var(--s-5);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    align-items: flex-start;
    transition: border-color var(--dur-2) var(--ease),
                transform var(--dur-2) var(--ease);
  }
  .cible:hover {
    border-color: var(--cuivre);
    transform: translateY(-2px);
  }
  .cible-icon {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--cuivre-soft);
    color: var(--cuivre);
    border-radius: var(--r-2);
    flex-shrink: 0;
  }
  .cible-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--step-2);
    color: var(--ink);
    margin: 0 0 var(--s-1) 0;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .cible-p {
    font-size: var(--step-0);
    color: var(--ink-2);
    line-height: var(--lh-normal);
    margin: 0;
    max-width: none;
  }

  @media (max-width: 900px) { .cibles-grid { grid-template-columns: 1fr; } }

  /* ============ PROOFS ============ */
  .proofs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-6);
    margin-top: var(--s-7);
  }
  .proof {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .proof-v {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw + 0.5rem, 4.25rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--cuivre);
  }
  .proof-l {
    font-size: var(--step-0);
    color: var(--ink-2);
    line-height: var(--lh-normal);
    max-width: 22ch;
  }

  @media (max-width: 720px) {
    .proofs-grid { grid-template-columns: repeat(2, 1fr); gap: var(--s-5); }
  }

  /* ============ RÉALISATIONS (Avant / Après) ============ */
  .reals-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-5);
    margin-top: var(--s-8);
  }
  .real-card {
    padding: var(--s-6);
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    transition: border-color var(--dur-2) var(--ease);
  }
  .real-card:hover { border-color: var(--cuivre); }
  .real-head {
    display: grid;
    grid-template-columns: 52px 1fr;
    gap: var(--s-3);
    align-items: center;
  }
  .real-n {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 2vw + 0.5rem, 2.5rem);
    line-height: 1;
    color: var(--cuivre);
    letter-spacing: -0.04em;
  }
  .real-secteur {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cuivre);
    font-weight: 600;
    display: block;
  }
  .real-sous {
    font-family: var(--font-display);
    font-size: var(--step-2);
    color: var(--ivoire);
    font-weight: 500;
    letter-spacing: -0.015em;
    margin: 2px 0 0 0;
    max-width: none;
    line-height: 1.2;
  }
  .real-flow {
    display: grid;
    grid-template-columns: 1fr 24px 1fr;
    gap: var(--s-3);
    align-items: stretch;
  }
  .real-state {
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r-2);
    padding: var(--s-3);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .real-state--apres {
    border-color: var(--cuivre);
    background: var(--cuivre-soft);
  }
  .real-state-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 600;
  }
  .real-state-tag--apres { color: var(--cuivre); }
  .real-state p {
    margin: 0;
    max-width: none;
    font-size: var(--step-0);
    line-height: var(--lh-normal);
    color: var(--ink-2);
  }
  .real-state--apres p { color: var(--ivoire); }
  .real-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--cuivre);
    align-self: center;
  }
  .real-phase {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0;
    max-width: none;
    padding-top: var(--s-3);
    border-top: 1px dashed var(--line-2);
  }
  .real-outro {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    color: var(--ivoire);
    text-align: center;
    max-width: 28ch;
    margin: 0 auto;
    text-wrap: balance;
    line-height: 1.2;
  }

  /* Bloc Tilt® post-réalisations : formation + accompagnement + CTAs */
  .real-tilt {
    margin: var(--s-9) auto 0 auto;
    max-width: 760px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    align-items: center;

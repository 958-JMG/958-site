---
import V2bLayout from '../../../layouts/V2bLayout.astro';
import Icon from '../../../components/v2/Icon.astro';
import V2cHeader from '../../../components/v2/V2cHeader.astro';
import V2cFooter from '../../../components/v2/V2cFooter.astro';

const programme = [
  {
    n: '01',
    creneau: '9 h — 12 h',
    titre: 'Comprendre.',
    items: [
      "Ce qu'est vraiment l'IA générative aujourd'hui — sans hype, sans peur.",
      "Modèles européens (Mistral) vs américains — pourquoi votre choix compte.",
      "Tour d'horizon des outils utiles à votre métier, pas pour 'les entreprises'.",
    ],
  },
  {
    n: '02',
    creneau: '14 h — 17 h',
    titre: 'Pratiquer.',
    items: [
      "Écrire vos 3 premiers prompts sur vos propres cas.",
      "Tester sur vos propres données — cadre sécurité documenté.",
      "Construire un mini-workflow qui tourne dès le lundi suivant.",
    ],
  },
  {
    n: '03',
    creneau: '17 h — 18 h',
    titre: 'Continuer.',
    items: [
      "La méthode SPARI pour structurer vos prompts à venir.",
      "Démarrer votre bibliothèque interne de prompts métier.",
      "Le point de contrôle inclus à 30 jours après la session.",
    ],
  },
];
---

<V2bLayout
  title="Découverte intégrée digitale — Formation Niveau 1"
  description="Une journée pour comprendre l'IA générative concrètement, écrire ses premiers prompts utiles et repartir avec un workflow qui tourne. Sur vos cas réels, à votre rythme. Déclaration d'activité 11757585175."
>
  <V2cHeader currentSection="formation" />

  <!-- HERO -->
  <section class="hero">
    <div class="container is-default">
      <p class="eyebrow reveal">
        F-INTRO · Découverte intégrée digitale · Niveau 1
      </p>
      <h1 class="manifesto reveal">
        Premier jour.<br>
        <em>Premiers réflexes.</em>
      </h1>
      <p class="killer-line reveal">
        Pour celles et ceux qui veulent<br>
        décoller propre.
      </p>
      <p class="lead reveal">
        Une journée pour <strong>comprendre l'IA générative concrètement</strong>,
        écrire ses premiers prompts utiles et repartir avec un workflow qui tourne —
        sur vos cas réels, à votre rythme. Pas un cours magistral.
        Une mise en marche.
      </p>
      <div class="hero-ctas reveal">
        <a href="#inscription" class="btn btn--primary btn--lg">
          S'inscrire à une session
          <Icon name="arrow-right" size={18} class="arrow" />
        </a>
        <a href="/formation/brief/" class="btn btn--ghost btn--lg">
          Brief sur-mesure
          <Icon name="arrow-right" size={18} class="arrow" />
        </a>
      </div>
      <ul class="hero-assurances reveal">
        <li>1 jour · 7 heures</li>
        <li>Inter (sessions ouvertes) ou intra (sur site)</li>
        <li>Centre de formation enregistré · Déclaration d'activité 11757585175</li>
        <li>Suivi à 30 jours inclus</li>
      </ul>
    </div>
  </section>

  <!-- PROGRAMME DÉTAILLÉ -->
  <section id="programme" class="section section--soft" aria-labelledby="prog-title">
    <div class="container">
      <div class="section-head">
        <h2 id="prog-title" class="reveal section-h2">
          Une journée. <em>Trois temps.</em>
        </h2>
        <p class="reveal section-sub">
          Chaque temps est structuré sur <strong>vos</strong> cas réels — pas sur des exemples génériques.
        </p>
      </div>

      <ol class="prog-list">
        {programme.map((t) => (
          <li class="prog-block reveal">
            <header class="prog-block-head">
              <span class="prog-block-n">{t.n}</span>
              <div>
                <h3 class="prog-block-h">{t.titre}</h3>
                <p class="prog-block-creneau">{t.creneau}</p>
              </div>
            </header>
            <ul class="prog-items">
              {t.items.map((it) => (
                <li>
                  <Icon name="check" size={18} strokeWidth={2.5} class="check" />
                  <span>{it}</span>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- POUR QUI -->
  <section class="section" aria-labelledby="pour-title">
    <div class="container is-default">
      <div class="section-head">
        <h2 id="pour-title" class="reveal section-h2">
          Pour qui c'est utile.
        </h2>
      </div>
      <ul class="public-list reveal">
        <li>
          <Icon name="briefcase" size={20} strokeWidth={1.7} />
          <span><strong>Dirigeants & cadres</strong> qui veulent comprendre sans coder.</span>
        </li>
        <li>
          <Icon name="users" size={20} strokeWidth={1.7} />
          <span><strong>Équipes opérationnelles</strong> qui veulent du concret applicable lundi.</span>
        </li>
        <li>
          <Icon name="hard-hat" size={20} strokeWidth={1.7} />
          <span><strong>Artisans, architectes, agences</strong> qui veulent passer du test au quotidien.</span>
        </li>
        <li>
          <Icon name="sparkles" size={20} strokeWidth={1.7} />
          <span><strong>Toute personne</strong> qui a essayé ChatGPT en perso et veut faire pareil sur son métier.</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- FORMAT / MODALITÉS -->
  <section class="section section--soft" aria-labelledby="format-title">
    <div class="container is-default">
      <div class="section-head">
        <h2 id="format-title" class="reveal section-h2">
          Format &amp; modalités.
        </h2>
      </div>

      <div class="format-grid reveal">
        <article class="format-card">
          <span class="format-tag">Inter-entreprise</span>
          <h3>Session ouverte</h3>
          <p>
            6 participants maximum, à Vannes ou Paris.
            Vous venez avec vos propres cas, vous repartez avec vos propres outils.
          </p>
          <ul>
            <li><Icon name="check" size={16} strokeWidth={2.5} /> Format mutualisé</li>
            <li><Icon name="check" size={16} strokeWidth={2.5} /> Tarif unitaire</li>
            <li><Icon name="check" size={16} strokeWidth={2.5} /> Dates planifiées</li>
          </ul>
        </article>

        <article class="format-card">
          <span class="format-tag">Intra-entreprise</span>
          <h3>Chez vous, pour votre équipe</h3>
          <p>
            On vient sur votre site, avec un programme adapté à vos cas.
            De 3 à 12 personnes. Possible de l'organiser en français ou en anglais.
          </p>
          <ul>
            <li><Icon name="check" size={16} strokeWidth={2.5} /> Programme sur-mesure</li>
            <li><Icon name="check" size={16} strokeWidth={2.5} /> Sur site (Bretagne / France)</li>
            <li><Icon name="check" size={16} strokeWidth={2.5} /> Date à convenir</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- FORMULAIRE D'INSCRIPTION -->
  <section id="inscription" class="section" aria-labelledby="form-title">
    <div class="container">
      <div class="section-head" style="margin-bottom: var(--s-6);">
        <h2 id="form-title" class="reveal section-h2">
          S'inscrire ou demander une date.
        </h2>
        <p class="reveal section-sub">
          On revient vers vous sous <strong>48 heures</strong> avec les dates disponibles
          (inter) ou une proposition adaptée à votre équipe (intra).
        </p>
      </div>

      <form id="decouverte-form" class="ins-form reveal" novalidate aria-label="Inscription Découverte Niveau 1">
        <div class="sr-only" aria-hidden="true">
          <label for="website">Ne pas remplir</label>
          <input type="text" name="website" id="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="field-row">
          <div class="field">
            <label for="nom">Prénom et nom <span aria-hidden="true">*</span></label>
            <input type="text" id="nom" name="nom" required autocomplete="name" />
          </div>
          <div class="field">
            <label for="entreprise">Entreprise <span class="optional">(optionnel)</span></label>
            <input type="text" id="entreprise" name="entreprise" autocomplete="organization" />
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="email">Email pro <span aria-hidden="true">*</span></label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>
          <div class="field">
            <label for="telephone">Téléphone <span class="optional">(optionnel)</span></label>
            <input type="tel" id="telephone" name="telephone" autocomplete="tel" />
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="format">Format souhaité <span aria-hidden="true">*</span></label>
            <select id="format" name="format" required>
              <option value="">Choisir…</option>
              <option>Inter — session ouverte</option>
              <option>Intra — chez nous</option>
              <option>Peu importe — proposez-moi</option>
            </select>
          </div>
          <div class="field">
            <label for="effectif">Effectif estimé <span aria-hidden="true">*</span></label>
            <select id="effectif" name="effectif" required>
              <option value="">Choisir…</option>
              <option>1 — moi seul</option>
              <option>2 à 3 personnes</option>
              <option>4 à 6 personnes</option>
              <option>7 à 12 personnes</option>
              <option>Plus de 12</option>
            </select>
          </div>
        </div>

        <div class="field">
          <label for="delai">Quand ? <span aria-hidden="true">*</span></label>
          <select id="delai" name="delai" required>
            <option value="">Choisir…</option>
            <option>Sous 1 mois</option>
            <option>Sous 3 mois</option>
            <option>Sous 6 mois</option>
            <option>À planifier ensemble</option>
          </select>
        </div>

        <div class="field">
          <label for="commentaire">Un mot sur votre contexte <span class="optional">(optionnel mais utile)</span></label>
          <textarea id="commentaire" name="commentaire" rows="3" placeholder="Ex : on a essayé ChatGPT en perso, on voudrait commencer concrètement par les mails et les devis."></textarea>
        </div>

        <input type="hidden" name="source_page" value="site/formation/decouverte" />
        <input type="hidden" name="type" value="inscription-decouverte-n1" />
        <input type="hidden" name="programme" value="F-INTRO · Découverte intégrée digitale · Niveau 1" />

        <button type="submit" class="btn btn--primary btn--lg submit" id="submit-btn"
                aria-label="Envoyer ma demande d'inscription à la formation Découverte Niveau 1">
          <span>Envoyer ma demande</span>
          <Icon name="arrow-right" size={18} class="arrow" />
        </button>

        <p class="form-legal">
          Données hébergées en Europe. Utilisées uniquement pour vous recontacter.
          Aucun partage. <a href="/mentions-legales/">Mentions légales</a>.
        </p>

        <div id="form-status" role="alert" aria-live="polite" class="form-status"></div>
      </form>
    </div>
  </section>

  <V2cFooter />
</V2bLayout>

<script>
  function bindForm() {
    const form = document.getElementById('decouverte-form') as HTMLFormElement | null;
    if (!form || (form as any).dataset.bound === '1') return;
    (form as any).dataset.bound = '1';

    const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const status = document.getElementById('form-status');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!btn || !status) return;
      const fd = new FormData(form);
      const data = Object.fromEntries(fd) as Record<string, string>;
      if (data.website) return;

      btn.disabled = true;
      const original = btn.innerHTML;
      btn.innerHTML = '<span>Envoi en cours…</span>';
      status.textContent = '';
      status.classList.remove('is-error');

      const payload = {
        ...data,
        timestamp: new Date().toISOString(),
        source: 'site-958-v2c',
        userAgent: navigator.userAgent,
        referrer: document.referrer || null,
      };

      try {
        const r = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!r.ok) {
          const body = await r.text().catch(() => '');
          throw new Error(`HTTP ${r.status}${body ? ' · ' + body.slice(0, 80) : ''}`);
        }
        window.location.href = '/merci/';
      } catch (err: any) {
        status.textContent = `Erreur d'envoi (${err?.message || 'réseau'}). Écrivez-nous à jmg@958.fr.`;
        status.classList.add('is-error');
        btn.disabled = false;
        btn.innerHTML = original;
      }
    });
  }
  bindForm();
  document.addEventListener('astro:page-load', bindForm);
</script>

<style>
  /* ============ HERO ============ */
  .hero { padding-block: var(--s-10) var(--s-9); }
  .hero .eyebrow { margin-bottom: var(--s-5); }
  .hero .manifesto {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw + 0.5rem, 4.5rem);
    line-height: 1.05; letter-spacing: var(--tr-tighter);
    font-weight: 400; color: var(--ivoire);
    margin: 0 0 var(--s-5) 0; max-width: 14ch;
  }
  .hero .manifesto em { color: var(--cuivre); font-style: italic; }
  .hero .killer-line {
    font-family: var(--font-display); font-style: italic;
    font-size: clamp(1.5rem, 3vw + 0.5rem, 2.5rem);
    line-height: 1.2; color: var(--cuivre);
    font-weight: 400; max-width: 28ch;
    margin: 0 0 var(--s-5) 0;
  }
  .hero .lead {
    font-size: var(--step-2); line-height: var(--lh-loose);
    color: var(--ink-2); max-width: 56ch;
    margin: 0 0 var(--s-7) 0;
  }
  .hero .lead strong { color: var(--ivoire); font-weight: 600; }
  .hero-ctas { display: flex; gap: var(--s-3); flex-wrap: wrap; }
  .hero-assurances {
    display: flex; flex-wrap: wrap; gap: var(--s-5);
    margin-top: var(--s-6); list-style: none; padding: 0;
  }
  .hero-assurances li {
    font-family: var(--font-mono); font-size: var(--step--2);
    color: var(--ink-3); letter-spacing: 0.04em;
    text-transform: uppercase; position: relative; padding-left: 14px;
  }
  .hero-assurances li::before {
    content: ""; position: absolute; left: 0; top: 50%;
    transform: translateY(-50%); width: 6px; height: 6px;
    background: var(--cuivre); border-radius: 50%;
  }

  /* ============ SECTION HEAD ============ */
  .section-head {
    display: flex; flex-direction: column; gap: var(--s-3);
    margin-bottom: var(--s-7); max-width: 760px;
  }
  .section-h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    font-weight: 400; line-height: 1.05;
    letter-spacing: var(--tr-tighter); color: var(--ivoire);
    max-width: 24ch; text-wrap: balance; margin: 0;
  }
  .section-h2 em { color: var(--cuivre); font-style: italic; }
  .section-sub {
    font-size: var(--step-1); line-height: var(--lh-normal);
    color: var(--ink-2); max-width: 60ch; margin: 0;
  }
  .section-sub strong { color: var(--ivoire); font-weight: 600; }

  /* ============ PROGRAMME 3 TEMPS ============ */
  .prog-list {
    list-style: none; padding: 0; margin: var(--s-6) 0 0 0;
    display: flex; flex-direction: column; gap: var(--s-5);
  }
  .prog-block {
    padding: var(--s-5); background: var(--bg);
    border: 1px solid var(--line); border-radius: var(--r-3);
  }
  .prog-block-head {
    display: grid; grid-template-columns: 64px 1fr;
    gap: var(--s-4); align-items: baseline;
    margin-bottom: var(--s-4);
  }
  .prog-block-n {
    font-family: var(--font-display); font-weight: 400;
    font-size: clamp(2rem, 3vw + 0.5rem, 2.75rem);
    line-height: 1; color: var(--cuivre);
    letter-spacing: -0.04em;
  }
  .prog-block-h {
    font-family: var(--font-display); font-weight: 500;
    font-size: var(--step-3); color: var(--ivoire);
    margin: 0 0 4px 0; letter-spacing: -0.015em;
  }
  .prog-block-creneau {
    font-family: var(--font-mono); font-size: var(--step--2);
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--ink-3); margin: 0;
  }
  .prog-items {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: var(--s-3);
  }
  .prog-items li {
    display: flex; align-items: flex-start; gap: 12px;
    font-size: var(--step-1); color: var(--ink-2);
    line-height: var(--lh-normal);
  }
  .prog-items .check {
    color: var(--cuivre); flex-shrink: 0; margin-top: 4px;
  }
  @media (max-width: 540px) {
    .prog-block-head { grid-template-columns: 1fr; gap: var(--s-2); }
  }

  /* ============ POUR QUI ============ */
  .public-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: var(--s-4);
  }
  .public-list li {
    display: flex; align-items: flex-start; gap: 14px;
    padding: var(--s-4); background: var(--bg-2);
    border: 1px solid var(--line); border-radius: var(--r-3);
    color: var(--ink-2); font-size: var(--step-1);
    line-height: var(--lh-normal);
  }
  .public-list li svg { color: var(--cuivre); flex-shrink: 0; margin-top: 2px; }
  .public-list strong { color: var(--ivoire); font-weight: 600; }

  /* ============ FORMAT ============ */
  .format-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: var(--s-5); margin-top: var(--s-6);
  }
  .format-card {
    padding: var(--s-6); background: var(--bg);
    border: 1px solid var(--line); border-radius: var(--r-3);
    display: flex; flex-direction: column; gap: var(--s-3);
  }
  .format-tag {
    font-family: var(--font-mono); font-size: var(--step--2);
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--cuivre); font-weight: 600;
  }
  .format-card h3 {
    font-family: var(--font-display); font-weight: 500;
    font-size: var(--step-3); color: var(--ivoire);
    margin: 0; letter-spacing: -0.015em;
  }
  .format-card p {
    font-size: var(--step-1); line-height: var(--lh-normal);
    color: var(--ink-2); margin: 0; max-width: none;
  }
  .format-card ul {
    list-style: none; padding: var(--s-3) 0 0 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
    border-top: 1px dashed var(--line);
  }
  .format-card li {
    display: flex; align-items: center; gap: 8px;
    font-size: var(--step-0); color: var(--ivoire-2);
  }
  .format-card svg { color: var(--cuivre); }
  @media (max-width: 720px) {
    .format-grid { grid-template-columns: 1fr; }
  }

  /* ============ FORM ============ */
  .ins-form {
    display: flex; flex-direction: column; gap: var(--s-4);
    max-width: 760px; padding: var(--s-6);
    background: var(--bg-2); border: 1px solid var(--line);
    border-radius: var(--r-3);
  }
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-4); }
  @media (max-width: 540px) { .field-row { grid-template-columns: 1fr; } }
  .field label {
    font-family: var(--font-mono); font-size: var(--step--2);
    color: var(--ink-2); letter-spacing: 0.04em;
    text-transform: uppercase; font-weight: 600;
  }
  .field label span[aria-hidden="true"] { color: var(--cuivre); }
  .field .optional {
    font-family: var(--font-sans); text-transform: none;
    letter-spacing: 0; font-weight: 400; color: var(--ink-3);
  }
  .field input, .field select, .field textarea {
    width: 100%; background: var(--bg);
    border: 1px solid var(--line-2); border-radius: var(--r-2);
    color: var(--ivoire); padding: 12px 14px;
    font-family: var(--font-sans); font-size: var(--step-1); line-height: 1.4;
    transition: border-color var(--dur-1) var(--ease), box-shadow var(--dur-1) var(--ease);
    min-height: 48px;
  }
  .field textarea { resize: vertical; min-height: 90px; font-family: var(--font-sans); }
  .field input:focus, .field select:focus, .field textarea:focus {
    outline: none; border-color: var(--cuivre);
    box-shadow: 0 0 0 3px var(--cuivre-soft);
  }
  .field input::placeholder, .field textarea::placeholder { color: var(--ink-3); opacity: 0.7; }
  .submit { margin-top: var(--s-2); justify-content: center; }
  .submit:disabled { opacity: 0.65; cursor: wait; }
  .form-legal {
    font-size: var(--step--1); color: var(--ink-3);
    line-height: var(--lh-normal); margin: 0; max-width: none;
  }
  .form-legal a { color: var(--ink-2); text-decoration: underline; text-underline-offset: 3px; }
  .form-legal a:hover { color: var(--cuivre); }
  .form-status:not(:empty) {
    padding: var(--s-3) var(--s-4); background: var(--bg-3);
    border: 1px solid var(--line-2); border-radius: var(--r-2);
    font-size: var(--step-0); color: var(--ivoire-2);
  }
  .form-status.is-error {
    background: rgba(208, 79, 60, 0.15);
    border-color: rgba(244, 150, 133, 0.5);
    color: #f49685;
  }
</style>

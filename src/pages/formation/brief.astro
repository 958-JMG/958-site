---
import Base from '../../layouts/Base.astro';

// Webhook partagé avec /diagnostic — n8n distingue via `source: formation-brief`.
const WEBHOOK = import.meta.env.PUBLIC_N8N_WEBHOOK_DIAGNOSTIC || '';
---

<Base
  title="Brief formation — Proposition sous 48 h"
  description="Formulaire court et ciblé pour un brief de formation IA : qui former, combien, quel objectif. Réponse écrite sous 48 h."
>
  <section class="section is-tight" aria-labelledby="h-brief">
    <div class="container diag">
      <!-- ===== Colonne gauche : pitch court ===== -->
      <div class="diag-pitch reveal">
        <p class="eyebrow">Brief formation</p>
        <h1 id="h-brief" style="margin-top: var(--s-3);">
          7 champs.<br>
          Une proposition sous 48&nbsp;h.
        </h1>
        <p class="lead" style="margin-top: var(--s-5);">
          Le reste se dit au téléphone. On appelle, on écoute, on propose.
        </p>

        <dl class="diag-facts">
          <div>
            <dt>Cadre</dt>
            <dd>NDA en cours · Qualiopi prévu</dd>
          </div>
          <div>
            <dt>Engagement</dt>
            <dd>Aucun</dd>
          </div>
        </dl>

        <p class="pitch-back">
          <a href="/formation" class="link-arrow">
            <span aria-hidden="true">←</span> Retour aux programmes
          </a>
        </p>
      </div>

      <!-- ===== Colonne droite : form ultra-court ===== -->
      <div class="diag-form-wrap reveal">
        <form
          id="formation-form"
          class="diag-form"
          novalidate
          aria-label="Brief formation"
          data-webhook={WEBHOOK}
        >
          <!-- Honeypot -->
          <div class="sr-only" aria-hidden="true">
            <label for="website">Ne pas remplir</label>
            <input type="text" name="website" id="website" tabindex="-1" autocomplete="off" />
          </div>

          <!-- 1. Identité courte -->
          <div class="field-row">
            <div class="field">
              <label for="nom">Prénom & nom <span aria-hidden="true">*</span></label>
              <input type="text" id="nom" name="nom" required autocomplete="name" />
            </div>
            <div class="field">
              <label for="email">Email pro <span aria-hidden="true">*</span></label>
              <input type="email" id="email" name="email" required autocomplete="email" />
            </div>
          </div>

          <div class="field-row">
            <div class="field">
              <label for="entreprise">Entreprise <span aria-hidden="true">*</span></label>
              <input type="text" id="entreprise" name="entreprise" required autocomplete="organization" />
            </div>
            <div class="field">
              <label for="telephone">Téléphone <span class="optional">(optionnel)</span></label>
              <input type="tel" id="telephone" name="telephone" autocomplete="tel" />
            </div>
          </div>

          <!-- 2. Qui former (chips, visuel) -->
          <div class="field">
            <label>Qui former <span aria-hidden="true">*</span></label>
            <div class="chips">
              {[
                'Dirigeants',
                'Commerciaux',
                'Ops · back-office',
                'Métier réglementé',
                'Tech · dev',
                'RH · com',
                'Autre',
              ].map((p) => (
                <label class="chip">
                  <input type="checkbox" name="publics" value={p} />
                  <span>{p}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- 3. Combien -->
          <div class="field">
            <label for="effectif">Combien de personnes <span aria-hidden="true">*</span></label>
            <select id="effectif" name="effectif" required>
              <option value="">Choisir…</option>
              <option>1 à 5</option>
              <option>6 à 15</option>
              <option>16 à 50</option>
              <option>50+</option>
            </select>
          </div>

          <!-- 4. Objectif (le champ qui compte le plus) -->
          <div class="field">
            <label for="objectif">Votre objectif, en une phrase <span aria-hidden="true">*</span></label>
            <textarea
              id="objectif"
              name="objectif"
              rows="3"
              required
              placeholder="Ex : « Nos commerciaux doivent maîtriser l'IA pour préparer leurs rendez-vous avant fin T3. »"
            ></textarea>
          </div>

          <button type="submit" class="btn btn--primary btn--lg submit" id="submit-btn">
            <span>Envoyer le brief</span>
            <span class="arrow" aria-hidden="true">→</span>
          </button>

          <p class="form-legal">
            Données hébergées en Europe. Utilisées pour vous recontacter. Aucun partage.
            <a href="/mentions-legales">Mentions légales</a>
          </p>

          <div id="form-status" role="alert" aria-live="polite" class="form-status"></div>
        </form>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Layout split, même grille que /diagnostic */
  .diag {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-7);
    align-items: start;
  }
  @media (min-width: 960px) {
    .diag { grid-template-columns: 1fr 1fr; gap: var(--s-8); }
    .diag-pitch { position: sticky; top: calc(var(--header-h) + var(--s-6)); }
  }

  .diag-pitch h1 { font-size: var(--step-6); line-height: var(--lh-tight); }
  .diag-facts {
    margin-top: var(--s-6);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-4);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: var(--s-5);
  }
  .diag-facts dt {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: var(--tr-mono);
    color: var(--ink-3);
    margin-bottom: var(--s-2);
  }
  .diag-facts dd { font-size: var(--step-1); color: var(--ink); }
  @media (max-width: 560px) {
    .diag-facts { grid-template-columns: 1fr; }
  }
  .pitch-back {
    margin-top: var(--s-7);
    padding-top: var(--s-5);
    border-top: 1px solid var(--line);
  }

  /* Form */
  .diag-form-wrap {
    background: var(--bg-2);
    border: 1px solid var(--line);
    padding: var(--s-6);
  }
  .diag-form {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .field label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: var(--tr-mono);
    color: var(--ink-3);
  }
  .field label span:not(.optional) { color: var(--accent); }
  .optional {
    color: var(--ink-3);
    text-transform: none;
    letter-spacing: var(--tr-normal);
  }
  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    background: var(--bg);
    border: 1px solid var(--line-2);
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: var(--step-1);
    border-radius: 2px;
    transition: border-color var(--dur-1) var(--ease),
                box-shadow var(--dur-1) var(--ease);
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .field select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L6 6L11 1' stroke='%236C6C66' stroke-width='1.5' stroke-linecap='round' fill='none'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 36px;
  }
  .field textarea { resize: vertical; min-height: 88px; line-height: var(--lh-normal); }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4);
  }
  @media (max-width: 560px) {
    .field-row { grid-template-columns: 1fr; }
  }

  /* Chips multi-select */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }
  .chip {
    position: relative;
    cursor: pointer;
  }
  .chip input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }
  .chip span {
    display: inline-block;
    padding: 0.55rem 0.95rem;
    border: 1px solid var(--line-2);
    border-radius: 999px;
    font-size: var(--step-0);
    color: var(--ink-2);
    transition: all var(--dur-1) var(--ease);
    user-select: none;
  }
  .chip:hover span { border-color: var(--ink-3); color: var(--ink); }
  .chip input:checked + span {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
    font-weight: 500;
  }
  .chip input:focus-visible + span {
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .submit {
    margin-top: var(--s-3);
    width: 100%;
    justify-content: center;
  }
  .form-legal {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-3);
    line-height: var(--lh-normal);
    letter-spacing: var(--tr-wide);
  }
  .form-legal a { color: var(--ink-2); text-decoration: underline; text-underline-offset: 3px; }
  .form-status:not(:empty) {
    margin-top: var(--s-3);
    padding: var(--s-3) var(--s-4);
    border: 1px solid var(--line-2);
    font-size: var(--step-0);
  }
  .form-status.is-error { border-color: #d04f3c; color: #f49685; }
</style>

<script>
  function bindFormationForm() {
    const form = document.getElementById('formation-form') as HTMLFormElement | null;
    if (!form) return;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const status = document.getElementById('form-status');
    const webhook = form.dataset.webhook || '';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!btn || !status) return;

      const fd = new FormData(form);
      const data: Record<string, any> = Object.fromEntries(fd);
      if (data.website) return; // honeypot

      data.publics = fd.getAll('publics');
      if (!Array.isArray(data.publics) || data.publics.length === 0) {
        status.textContent = 'Sélectionnez au moins un public à former.';
        status.classList.add('is-error');
        return;
      }

      if (!webhook) {
        status.textContent = 'Configuration manquante. Écrivez-nous à jmg@958.fr.';
        status.classList.add('is-error');
        return;
      }

      btn.disabled = true;
      const original = btn.innerHTML;
      btn.innerHTML = '<span>Envoi en cours…</span>';
      status.textContent = '';
      status.classList.remove('is-error');

      const payload = {
        ...data,
        source: 'formation-brief',
        timestamp: new Date().toISOString(),
        userAgent: navigator.userAgent,
        referrer: document.referrer || null,
      };

      try {
        const r = await fetch(webhook, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        window.location.href = '/merci?sujet=formation';
      } catch {
        status.textContent = 'Erreur d\u2019envoi. Écrivez-nous à jmg@958.fr.';
        status.classList.add('is-error');
        btn.disabled = false;
        btn.innerHTML = original;
      }
    });
  }
  bindFormationForm();
  document.addEventListener('astro:page-load', bindFormationForm);
</script>

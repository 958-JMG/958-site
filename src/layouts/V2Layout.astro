---
/**
 * V2Layout — Layout isolé pour la refonte /preview/v2/
 *
 * - Charge uniquement le nouveau design system v2.css (pas global.css)
 * - Pas de Header/Footer prod (composants V2 importés à la page)
 * - noindex + nofollow pour éviter toute fuite SEO pendant la phase proto
 * - Reveal observer minimal pour les animations scroll
 *
 * Une fois la refonte validée et mergée, V2Layout devient le Base layout
 * du site et global.css/Base.astro/Header.astro/Footer.astro sont retirés.
 */

import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/v2.css';

interface Props {
  title: string;
  description: string;
  hidePreviewBanner?: boolean;
}

const { title, description, hidePreviewBanner = false } = Astro.props;
const pageTitle = `${title} · 958 · v2 preview`;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    {/* Bloquer toute indexation de la zone proto */}
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />

    {/* Favicons réutilisés */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <meta name="theme-color" content="#2C2C52" />
  </head>

  <body>
    <a href="#main" class="skip-link">Aller au contenu</a>

    {!hidePreviewBanner && (
      <div class="preview-banner" aria-label="Preview interne, non indexé">
        v2 · preview
      </div>
    )}

    <main id="main" role="main">
      <slot />
    </main>

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -10% 0px' }
      );

      document.querySelectorAll('.reveal:not(.is-visible)').forEach((el, i) => {
        if (el instanceof HTMLElement) {
          const container = el.parentElement;
          if (container?.classList.contains('reveal-stagger')) {
            el.style.setProperty('--i', String(i));
          }
        }
        io.observe(el);
      });
    </script>
  </body>
</html>

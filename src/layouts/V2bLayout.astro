---
/**
 * V2bLayout — direction "manifesto / éditorial dark"
 *
 * - Dark canvas + ivoire chaud + accent cuivre/rouille
 * - Typo Fraunces Variable (display serif) + Inter Variable (body) + JetBrains Mono
 * - Noise overlay subtil (grain photo)
 * - Pas de Header/Footer prod (composants v2 importés à la page)
 * - noindex en prop : OFF par défaut (prod), ON sur les pages preview
 * - SEO essentials : canonical, OG, Twitter card, JSON-LD Organization
 */

import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/v2b.css';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  hidePreviewBanner?: boolean;
  hideNoise?: boolean;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description,
  noindex = false,
  hidePreviewBanner = true,
  hideNoise = false,
  ogImage = '/og-958.png',
  canonical,
} = Astro.props;

const pageTitle = `${title} · 9·58`;
const siteUrl = 'https://www.958.fr';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="9·58" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="fr_FR" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* JSON-LD Organization */}
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ProfessionalService',
      name: '9·58',
      url: siteUrl,
      logo: `${siteUrl}/logo-958-official.png`,
      description: "Installer l'IA souveraine dans les TPE-PME du bâtiment et de l'immobilier 360°. Accompagnement, formation, programmes Ça fait Tilt®.",
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Vannes',
        addressRegion: 'Bretagne',
        addressCountry: 'FR',
      },
      areaServed: { '@type': 'Country', name: 'France' },
      founder: { '@type': 'Person', name: 'Jean-Marc Geuring' },
      email: 'jmg@958.fr',
      sameAs: ['https://www.linkedin.com/in/jean-marc-geuring/'],
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <meta name="theme-color" content="#0B0B0A" />
  </head>

  <body>
    <a href="#main" class="skip-link">Aller au contenu</a>

    {!hideNoise && <div class="noise-overlay" aria-hidden="true" />}

    {!hidePreviewBanner && (
      <div class="preview-banner" aria-label="Preview interne, non indexé">
        v2b · preview
      </div>
    )}

    <main id="main" role="main" style="position: relative; z-index: 2;">
      <slot />
    </main>

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -10% 0px' }
      );

      document.querySelectorAll('.reveal:not(.is-visible)').forEach((el, i) => {
        if (el instanceof HTMLElement) {
          const container = el.parentElement;
          if (container?.classList.contains('reveal-stagger')) {
            el.style.setProperty('--i', String(i));
          }
        }
        io.observe(el);
      });
    </script>
  </body>
</html>

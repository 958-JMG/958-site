---
/**
 * V2bLayout — direction "manifesto / éditorial dark"
 *
 * - Dark canvas + ivoire chaud + accent cuivre/rouille
 * - Typo Fraunces Variable (display serif) + Inter Variable (body) + JetBrains Mono
 * - Noise overlay subtil (grain photo)
 * - Pas de Header/Footer prod (composants v2 importés à la page)
 * - noindex + nofollow pour éviter toute fuite SEO pendant la phase proto
 */

import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/v2b.css';

interface Props {
  title: string;
  description: string;
  hidePreviewBanner?: boolean;
  hideNoise?: boolean;
}

const { title, description, hidePreviewBanner = false, hideNoise = false } = Astro.props;
const pageTitle = `${title} · 958 · v2b preview`;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <meta name="theme-color" content="#0B0B0A" />
  </head>

  <body>
    <a href="#main" class="skip-link">Aller au contenu</a>

    {!hideNoise && <div class="noise-overlay" aria-hidden="true" />}

    {!hidePreviewBanner && (
      <div class="preview-banner" aria-label="Preview interne, non indexé">
        v2b · preview
      </div>
    )}

    <main id="main" role="main" style="position: relative; z-index: 2;">
      <slot />
    </main>

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -10% 0px' }
      );

      document.querySelectorAll('.reveal:not(.is-visible)').forEach((el, i) => {
        if (el instanceof HTMLElement) {
          const container = el.parentElement;
          if (container?.classList.contains('reveal-stagger')) {
            el.style.setProperty('--i', String(i));
          }
        }
        io.observe(el);
      });
    </script>
  </body>
</html>

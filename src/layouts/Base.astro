---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NoiseOverlay from '../components/NoiseOverlay.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  /** Ordre pour le title : brand-last (défaut, SEO-friendly) ou brand-first */
  titleMode?: 'brand-last' | 'brand-first';
}

const { title, description, canonical, ogImage = '/og-image.png', titleMode = 'brand-last' } = Astro.props;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const pageTitle = titleMode === 'brand-first'
  ? `958 · ${title}`
  : `${title} · 958 · Neuf Cinquante Huit`;

const path = Astro.url.pathname;
const showMobileCta = !(
  path === '/diagnostic' ||
  path === '/diagnostic/' ||
  path === '/merci' ||
  path === '/merci/'
);

// BreadcrumbList auto — généré depuis le chemin pour les rich snippets Google.
function buildBreadcrumbs(p: string) {
  const base = { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://www.958.fr/' };
  const trail: any[] = [base];
  const segs = p.split('/').filter(Boolean);
  let acc = '';
  const labels: Record<string, string> = {
    methode: 'Méthode',
    formation: 'Formation',
    brief: 'Brief formation',
    realisations: 'Réalisations',
    diagnostic: 'Diagnostic',
    faq: 'FAQ',
    'mentions-legales': 'Mentions légales',
    merci: 'Merci',
  };
  segs.forEach((seg, i) => {
    acc += '/' + seg;
    const label = labels[seg] || seg;
    trail.push({
      '@type': 'ListItem',
      position: i + 2,
      name: label,
      item: `https://www.958.fr${acc}/`,
    });
  });
  return trail;
}
const breadcrumbs = buildBreadcrumbs(path);
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0B0B0A" />

    <!-- OG / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="958 · Neuf Cinquante Huit" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD — Organization / ProfessionalService (site-wide) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'ProfessionalService',
        '@id': 'https://www.958.fr/#organization',
        name: 'Neuf Cinquante Huit',
        alternateName: ['9·58', '958'],
        url: 'https://www.958.fr',
        logo: 'https://www.958.fr/logo-958-mark.svg',
        image: 'https://www.958.fr/og-image.png',
        founder: {
          '@type': 'Person',
          name: 'Jean-Marc Geuring',
          jobTitle: 'Fondateur · Consultant IA pour TPE et PME',
          sameAs: ['https://www.linkedin.com/in/jean-marc-geuring/'],
        },
        email: 'jmg@958.fr',
        foundingDate: '2022',
        address: [
          {
            '@type': 'PostalAddress',
            streetAddress: '60 rue François 1er',
            addressLocality: 'Paris',
            postalCode: '75008',
            addressCountry: 'FR',
          },
          {
            '@type': 'PostalAddress',
            streetAddress: '1 bis rue Thiers',
            addressLocality: 'Vannes',
            postalCode: '56000',
            addressRegion: 'Morbihan',
            addressCountry: 'FR',
          },
        ],
        areaServed: ['FR', { '@type': 'Country', name: 'France' }],
        priceRange: '€€',
        sameAs: ['https://www.linkedin.com/in/jean-marc-geuring/'],
        description:
          "Conseil, audit, implémentation et formation IA pour dirigeants de TPE et PME. Méthode propriétaire SPARI. Basé à Vannes et Paris. Souveraineté européenne par défaut.",
        serviceType: ['Audit IA', 'Implémentation IA', 'Formation IA', 'Accompagnement IA'],
        knowsAbout: [
          'Intelligence artificielle',
          'Audit IA',
          'Implémentation IA',
          'Formation IA intra-entreprise',
          'Souveraineté numérique',
          'RGPD',
          'Automatisation n8n',
          'Mistral AI',
          'Claude',
          'Prompt engineering',
        ],
      })}
    />

    <!-- JSON-LD — BreadcrumbList (rich snippets par page) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs,
      })}
    />

    <!-- JSON-LD — WebSite avec SearchAction (rich result Google) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        '@id': 'https://www.958.fr/#website',
        url: 'https://www.958.fr',
        name: '958 · Neuf Cinquante Huit',
        description: "Installer l'IA dans votre entreprise. Sans bruit, sans jargon, sans dépendance.",
        inLanguage: 'fr-FR',
        publisher: { '@id': 'https://www.958.fr/#organization' },
      })}
    />

    <!-- Plausible (EU, cookieless) -->
    <script defer data-domain="958.fr" src="https://plausible.io/js/script.js"></script>

    <ClientRouter />
  </head>

  <body>
    <a href="#main" class="skip-link">Aller au contenu</a>

    <NoiseOverlay />
    <Header />

    <main id="main" role="main">
      <slot />
    </main>

    <Footer />

    {showMobileCta && (
      <a href="/diagnostic" class="mobile-cta" aria-label="Demander un diagnostic">
        <span>Demander un diagnostic</span>
        <span class="mobile-cta-arrow" aria-hidden="true">→</span>
      </a>
    )}

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -10% 0px' }
      );

      function bindReveal() {
        document.querySelectorAll('.reveal:not(.is-visible)').forEach((el, i) => {
          if (el instanceof HTMLElement) {
            const container = el.parentElement;
            if (container?.classList.contains('reveal-stagger')) {
              el.style.setProperty('--i', String(i));
            }
          }
          io.observe(el);
        });
      }

      bindReveal();
      document.addEventListener('astro:page-load', bindReveal);
    </script>
  </body>
</html>

<style is:global>
  html { scroll-padding-top: calc(var(--header-h) + 16px); }
  main { min-height: 60vh; padding-top: var(--header-h); }

  /* ============ STICKY MOBILE CTA ============ */
  .mobile-cta {
    display: none;
  }

  @media (max-width: 720px) {
    .mobile-cta {
      position: fixed;
      left: 50%;
      bottom: calc(14px + env(safe-area-inset-bottom, 0px));
      transform: translateX(-50%);
      z-index: 60;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.85rem 1.35rem;
      background: var(--accent);
      color: var(--bg);
      font-family: var(--font-sans);
      font-size: var(--step-0);
      font-weight: 500;
      letter-spacing: var(--tr-wide);
      white-space: nowrap;
      border-radius: 999px;
      text-decoration: none;
      box-shadow:
        0 10px 30px -8px rgba(0, 0, 0, 0.55),
        0 0 0 1px rgba(212, 255, 78, 0.15),
        0 0 40px -12px rgba(212, 255, 78, 0.35);
      transition: transform var(--dur-1) var(--ease),
                  box-shadow var(--dur-1) var(--ease);
      animation: mobile-cta-in 340ms var(--ease) 280ms both;
    }
    .mobile-cta:active {
      transform: translateX(-50%) translateY(1px) scale(0.98);
    }
    .mobile-cta-arrow {
      transition: transform var(--dur-1) var(--ease);
    }
    .mobile-cta:active .mobile-cta-arrow {
      transform: translateX(2px);
    }

    /* Give bottom breathing room so content doesn't hide under the button */
    main { padding-bottom: calc(64px + env(safe-area-inset-bottom, 0px)); }
  }

  @keyframes mobile-cta-in {
    from { opacity: 0; transform: translateX(-50%) translateY(16px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-cta { animation: none; }
  }
</style>

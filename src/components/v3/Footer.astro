---
/**
 * Footer V3 — fond Encre, texte ivoire (charte prompt JMG).
 * Logo 9·58 (Fraunces), nav vers les 5 sections, contact, signature.
 */
import Icon from '../v2/Icon.astro';

const base = '/v3';
const portes = [
  { href: `${base}/audit-ia`, label: 'Audit IA · par où commencer' },
  { href: `${base}/automatiser-administratif`, label: 'Automatiser l’administratif' },
  { href: `${base}/formation-ia-dirigeants-vannes`, label: 'Formation IA dirigeants · Vannes' },
  { href: `${base}/ia-souveraine-donnees`, label: 'IA souveraine · vos données' },
];
---

<footer class="ft band--ink">
  <div class="container is-full">
    <div class="ft__top">
      <div class="ft__brand">
        <span class="ft__logo">9·58</span>
        <p class="ft__sign">Et là, ça fait tilt.</p>
      </div>

      <nav class="ft__nav" aria-label="Pied de page">
        <span class="ft__nav-title">Les portes d’entrée</span>
        <a href={base + '/'} class="ft__link">Accueil</a>
        {portes.map((p) => <a href={p.href} class="ft__link">{p.label}</a>)}
      </nav>

      <div class="ft__contact">
        <span class="ft__nav-title">Parler à Jean-Marc</span>
        <a href="mailto:jmg@958.fr" class="ft__mail">
          <Icon name="mail" size={18} />
          jmg@958.fr
        </a>
        <p class="ft__loc">
          <Icon name="map-pin" size={16} />
          Vannes · Morbihan · Bretagne
        </p>
      </div>
    </div>

    <div class="ft__bottom">
      <span class="ft__fine">© 2026 9·58 — Jean-Marc Geuring</span>
      <span class="ft__fine">Qualiopi · Souveraineté des données · Méthode SPARI</span>
    </div>
  </div>
</footer>

<style>
  .ft { padding-block: var(--s-10) var(--s-7); }
  .ft__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-8);
    padding-bottom: var(--s-7);
    border-bottom: 1px solid var(--on-ink-line);
  }
  .ft__logo {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 500;
    color: var(--on-ink);
  }
  .ft__sign {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-2);
    color: var(--on-ink-2);
    margin-top: var(--s-2);
  }
  .ft__nav, .ft__contact { display: flex; flex-direction: column; gap: var(--s-3); }
  .ft__nav-title {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: var(--tr-mono);
    text-transform: uppercase;
    color: var(--on-ink-3);
    margin-bottom: var(--s-1);
  }
  .ft__link { color: var(--on-ink-2); transition: color var(--dur-1) var(--ease); }
  .ft__link:hover { color: var(--on-ink); }
  .ft__mail {
    display: inline-flex; align-items: center; gap: 0.5rem;
    color: var(--on-ink); font-weight: 600; font-size: var(--step-2);
    font-family: var(--font-display);
  }
  .ft__mail:hover { color: var(--cuivre); }
  .ft__loc {
    display: inline-flex; align-items: center; gap: 0.5rem;
    color: var(--on-ink-3); font-size: var(--step-0);
  }
  .ft__bottom {
    display: flex; flex-wrap: wrap; gap: var(--s-3) var(--s-6);
    justify-content: space-between;
    padding-top: var(--s-6);
  }
  .ft__fine {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: var(--tr-wide);
    color: var(--on-ink-3);
  }
  @media (min-width: 880px) {
    .ft__top { grid-template-columns: 1.2fr 1fr 1fr; gap: var(--s-7); }
  }
</style>

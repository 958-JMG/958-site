---
/**
 * Header V3 — barre éditoriale claire, logo Fraunces, nav vers les 4 portes.
 * Mobile-first : menu replié en panneau plein écran (toggle JS inline).
 * Le CTA cuivre reste l'unique accent d'action.
 */
import Icon from '../v2/Icon.astro';

const base = '/v3';
const portes = [
  { href: `${base}/audit-ia`, label: 'Audit IA' },
  { href: `${base}/automatiser-administratif`, label: 'Automatiser l’administratif' },
  { href: `${base}/formation-ia-dirigeants-vannes`, label: 'Formation' },
  { href: `${base}/ia-souveraine-donnees`, label: 'IA souveraine' },
];
---

<header class="hdr" data-hdr>
  <div class="container is-full hdr__inner">
    <a href={base + '/'} class="hdr__brand" aria-label="9·58 — accueil">
      <span class="hdr__logo">9·58</span>
    </a>

    <nav class="hdr__nav" aria-label="Navigation principale">
      {portes.map((p) => <a href={p.href} class="hdr__link">{p.label}</a>)}
    </nav>

    <div class="hdr__actions">
      <a href={base + '/audit-ia'} class="btn btn--primary btn--sm hdr__cta">
        Par où on commence
        <Icon name="arrow-right" size={16} class="arrow" />
      </a>
      <button class="hdr__burger" data-burger aria-label="Ouvrir le menu" aria-expanded="false">
        <Icon name="menu" size={22} />
      </button>
    </div>
  </div>

  <!-- Panneau mobile -->
  <div class="hdr__panel" data-panel hidden>
    <nav class="hdr__panel-nav" aria-label="Navigation mobile">
      {portes.map((p) => <a href={p.href} class="hdr__panel-link">{p.label}</a>)}
      <a href={base + '/audit-ia'} class="btn btn--primary hdr__panel-cta">
        Par où on commence
        <Icon name="arrow-right" size={18} class="arrow" />
      </a>
    </nav>
  </div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .hdr__inner {
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-5);
  }
  .hdr__brand { display: inline-flex; align-items: center; }
  .hdr__logo {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 500;
    letter-spacing: var(--tr-tight);
    color: var(--ink);
  }
  .hdr__nav { display: none; align-items: center; gap: clamp(1rem, 2vw, 1.9rem); }
  .hdr__link {
    font-size: var(--step-0);
    font-weight: 500;
    color: var(--ink-2);
    transition: color var(--dur-1) var(--ease);
  }
  .hdr__link:hover { color: var(--ink); }
  .hdr__actions { display: flex; align-items: center; gap: var(--s-3); }
  .hdr__cta { display: none; }
  .hdr__burger {
    display: inline-grid;
    place-items: center;
    width: 44px; height: 44px;
    border-radius: var(--r-sm);
    color: var(--ink);
    border: 1px solid var(--line-2);
  }

  .hdr__panel {
    position: fixed;
    inset: var(--header-h) 0 0 0;
    background: var(--paper);
    z-index: 49;
    padding: var(--s-6) var(--gutter) var(--s-8);
    animation: panel-in var(--dur-2) var(--ease-out);
  }
  @keyframes panel-in { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: none; } }
  .hdr__panel-nav { display: flex; flex-direction: column; gap: var(--s-2); }
  .hdr__panel-link {
    font-family: var(--font-display);
    font-size: var(--step-3);
    color: var(--ink);
    padding: var(--s-3) 0;
    border-bottom: 1px solid var(--line);
  }
  .hdr__panel-cta { margin-top: var(--s-5); justify-content: center; }

  @media (min-width: 880px) {
    .hdr__nav { display: flex; }
    .hdr__cta { display: inline-flex; }
    .hdr__burger { display: none; }
    .hdr__panel { display: none !important; }
  }
</style>

<script>
  const burger = document.querySelector('[data-burger]');
  const panel = document.querySelector('[data-panel]');
  if (burger && panel instanceof HTMLElement) {
    burger.addEventListener('click', () => {
      const open = panel.hasAttribute('hidden');
      if (open) {
        panel.removeAttribute('hidden');
        burger.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      } else {
        panel.setAttribute('hidden', '');
        burger.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    });
    panel.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        panel.setAttribute('hidden', '');
        burger.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      })
    );
  }
</script>

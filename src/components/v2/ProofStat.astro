---
interface Props {
  /** Chiffre / valeur affichée en grand */
  value: string;
  /** Label sous le chiffre */
  label: string;
  /** Mode dark (sur fond bleu nuit) */
  dark?: boolean;
}

const { value, label, dark = false } = Astro.props;
---

<div class={`proof-stat ${dark ? 'is-dark' : ''} reveal`}>
  <span class="proof-value">{value}</span>
  <span class="proof-label">{label}</span>
</div>

<style>
  .proof-stat {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .proof-value {
    font-family: var(--font-sans);
    font-size: clamp(2.5rem, 5vw + 0.5rem, 4.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink);
  }
  .proof-stat.is-dark .proof-value {
    color: var(--ivoire);
  }
  .proof-label {
    font-size: var(--step-0);
    color: var(--ink-2);
    line-height: var(--lh-normal);
    max-width: 22ch;
  }
  .proof-stat.is-dark .proof-label {
    color: var(--bleu-clair);
  }

  @media (max-width: 720px) {
    .proof-value {
      font-size: clamp(2rem, 8vw, 3rem);
    }
  }
</style>

---
/**
 * CTAStickyMobile — barre CTA fixée en bas du viewport sur mobile (≤ 640px).
 *
 * Comportement attendu :
 *   - Cachée par défaut au load (anti-flash).
 *   - Apparaît dès que le hero quitte le viewport (scroll vers le bas).
 *   - Disparaît quand l'utilisateur arrive sur la section CTA inline (anti-doublon).
 *   - Invisible sur desktop (≥ 641px).
 *
 * Props :
 *   label : libellé du bouton (default "Demander un diagnostic")
 *   href : lien du bouton (default "/diagnostic/")
 *   anchorHide : id de la section qui doit cacher la sticky bar (default "contact")
 *   heroSelector : selector du hero qui doit garder la bar cachée tant qu'il est visible (default "section.hero, section.hero-demo, [data-hero]")
 *
 * À inclure une seule fois par page (juste avant </body> idéalement).
 */
interface Props {
  label?: string;
  href?: string;
  anchorHide?: string;
  heroSelector?: string;
}

const {
  label = 'Demander un diagnostic',
  href = '/diagnostic/',
  anchorHide = 'contact',
  heroSelector = 'section.hero, section.hero-demo, [data-hero]',
} = Astro.props;
---

<div
  class="cta-sticky-mobile"
  data-cta-sticky
  data-anchor-hide={anchorHide}
  data-hero-selector={heroSelector}
  aria-hidden="true"
  role="region"
  aria-label="Accès rapide diagnostic"
>
  <a href={href} class="cta-sticky-btn">
    <span class="cta-sticky-label">{label}</span>
    <svg
      class="cta-sticky-arrow"
      aria-hidden="true"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  </a>
</div>

<script>
  // CTAStickyMobile — show/hide logic mobile only.
  // Activé uniquement si matchMedia(max-width: 640px) match.
  const root = document.querySelector<HTMLElement>('[data-cta-sticky]');
  if (root) {
    const heroSelector = root.dataset.heroSelector || '';
    const anchorHide = root.dataset.anchorHide || '';
    const hero = heroSelector ? document.querySelector<HTMLElement>(heroSelector) : null;
    const anchor = anchorHide ? document.getElementById(anchorHide) : null;
    const mql = window.matchMedia('(max-width: 640px)');

    // États suivis indépendamment, et combinés pour décider show/hide.
    let heroVisible = true; // au load, le hero est visible
    let anchorVisible = false;

    const apply = () => {
      const shouldShow = mql.matches && !heroVisible && !anchorVisible;
      if (shouldShow) {
        root.classList.add('is-visible');
        root.setAttribute('aria-hidden', 'false');
      } else {
        root.classList.remove('is-visible');
        root.setAttribute('aria-hidden', 'true');
      }
    };

    let heroIO: IntersectionObserver | null = null;
    let anchorIO: IntersectionObserver | null = null;

    const attach = () => {
      if (!mql.matches) return;
      if (hero && !heroIO) {
        heroIO = new IntersectionObserver(
          ([entry]) => {
            heroVisible = entry.isIntersecting;
            apply();
          },
          { threshold: 0.1 }
        );
        heroIO.observe(hero);
      }
      if (anchor && !anchorIO) {
        anchorIO = new IntersectionObserver(
          ([entry]) => {
            anchorVisible = entry.isIntersecting;
            apply();
          },
          { threshold: 0.1 }
        );
        anchorIO.observe(anchor);
      }
      // Fallback : si pas de hero détecté, on déclenche dès qu'on a scrollé 400px
      if (!hero) {
        const onScroll = () => {
          heroVisible = window.scrollY < 400;
          apply();
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
      apply();
    };

    const detach = () => {
      heroIO?.disconnect();
      heroIO = null;
      anchorIO?.disconnect();
      anchorIO = null;
      root.classList.remove('is-visible');
      root.setAttribute('aria-hidden', 'true');
    };

    attach();
    mql.addEventListener('change', () => (mql.matches ? attach() : detach()));
  }
</script>

<style>
  .cta-sticky-mobile {
    /* Caché par défaut sur tous les viewports (le show/hide est piloté en JS) */
    display: none;
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 50;
    padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
    /* Slide up animation au show */
    transform: translateY(100%);
    transition: transform 280ms cubic-bezier(0.2, 0.8, 0.2, 1),
                opacity 240ms ease-out;
    opacity: 0;
    pointer-events: none;
    /* Fond OPAQUE noir brand qui masque le contenu juste au-dessus
       (séparateurs, border-top de sections, etc.) sans créer de halo flou.
       Petit fade transparent SEULEMENT sur les 8 derniers pixels du haut
       pour éviter une coupe nette qui paraîtrait artificielle.
       Aucun backdrop-filter → aucun voile blanchâtre. */
    background: linear-gradient(
      to top,
      var(--bg) 0%,
      var(--bg) 88%,
      rgba(11, 11, 10, 0) 100%
    );
  }

  .cta-sticky-mobile.is-visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .cta-sticky-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    /* Tap target 56px = bien au-delà des 44px AA */
    min-height: 56px;
    padding: 14px 22px;
    background: var(--cuivre);
    color: var(--bg);
    border-radius: 14px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1rem, 2.5vw + 0.5rem, 1.1rem);
    letter-spacing: 0;
    text-decoration: none;
    box-shadow: 0 8px 28px -4px rgba(199, 95, 45, 0.45),
                0 0 0 1px rgba(255, 255, 255, 0.05) inset;
    transition: background var(--dur-1) var(--ease),
                transform var(--dur-1) var(--ease);
  }

  .cta-sticky-btn:active {
    transform: scale(0.985);
    background: var(--cuivre-2, #E07C42);
  }

  .cta-sticky-arrow {
    flex-shrink: 0;
    transition: transform var(--dur-1) var(--ease);
  }
  .cta-sticky-btn:hover .cta-sticky-arrow {
    transform: translateX(2px);
  }

  /* Mobile only */
  @media (max-width: 640px) {
    .cta-sticky-mobile {
      display: block;
    }
  }

  /* Focus visible accessibility */
  .cta-sticky-btn:focus-visible {
    outline: 2px solid var(--ivoire);
    outline-offset: 3px;
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .cta-sticky-mobile {
      transition: opacity 120ms linear;
      transform: none !important;
    }
    .cta-sticky-mobile:not(.is-visible) {
      opacity: 0;
    }
  }
</style>

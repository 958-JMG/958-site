---
/**
 * PortesEntree — bloc "Trois manières de commencer"
 *
 * Composant V2c réutilisable sur toutes les pages publiques.
 * 3 portes équivalentes : Audit IA / Formation Tilt® / Échange initial.
 *
 * Props :
 *   variant : 'soft' (fond bg-2, default) | 'plain' (fond bg)
 *   eyebrow : libellé eyebrow (default "Portes d'entrée")
 *   title : H2 (default "Trois manières de commencer.")
 *   subtitle : phrase d'intro (default texte standard)
 *   sectionId : id ancre (default "portes")
 */
import Icon from './Icon.astro';

interface Props {
  variant?: 'soft' | 'plain';
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  sectionId?: string;
}

const {
  variant = 'soft',
  eyebrow = "Portes d'entrée",
  title = "Trois manières <em>de commencer.</em>",
  subtitle = "Selon votre maturité IA et votre urgence, l'entrée se fait par l'audit, la formation ou un échange initial.",
  sectionId = 'portes',
} = Astro.props;

const sectionClass = variant === 'soft' ? 'section section--soft' : 'section';
---

<section class={sectionClass} aria-labelledby={`${sectionId}-title`} id={sectionId}>
  <div class="container is-default">
    <div class="portes-head">
      <p class="eyebrow reveal">{eyebrow}</p>
      <h2 id={`${sectionId}-title`} class="reveal portes-h2" set:html={title} />
      <p class="reveal portes-sub">{subtitle}</p>
    </div>

    <ul
      class="portes-list reveal"
      data-portes-list
      aria-roledescription="carousel"
      aria-label="Trois portes d'entrée — Audit, Formation, Échange initial"
    >
      <li data-portes-slide>
        <a href="/diagnostic/" class="porte">
          <Icon name="shield" size={22} strokeWidth={1.7} />
          <div>
            <strong>Audit IA <em class="porte-delai">— 1 jour</em></strong>
            <span>Sur site, sous accord de confidentialité, rapport à la clé.</span>
          </div>
          <Icon name="arrow-right" size={16} class="arrow" />
        </a>
      </li>
      <li data-portes-slide>
        <a href="/formation/" class="porte">
          <Icon name="graduation-cap" size={22} strokeWidth={1.7} />
          <div>
            <strong>Formation Ça fait Tilt® <em class="porte-delai">— 2 jours</em></strong>
            <span>Programmes inter ou intra, du Niveau 1 au sur-mesure.</span>
          </div>
          <Icon name="arrow-right" size={16} class="arrow" />
        </a>
      </li>
      <li data-portes-slide>
        <a href="/diagnostic/?type=echange" class="porte">
          <Icon name="phone" size={22} strokeWidth={1.7} />
          <div>
            <strong>Échange initial <em class="porte-delai">— 30 min</em></strong>
            <span>Pour cadrer votre besoin, sans engagement.</span>
          </div>
          <Icon name="arrow-right" size={16} class="arrow" />
        </a>
      </li>
    </ul>

    <ol class="portes-dots" data-portes-dots aria-hidden="true">
      <li><span aria-current="true"></span></li>
      <li><span></span></li>
      <li><span></span></li>
    </ol>
  </div>
</section>

<script>
  // Highlight le dot correspondant au slide visible (mobile uniquement).
  // Pas de polyfill : IntersectionObserver est dispo Safari 12.1+ / Chrome 51+.
  const lists = document.querySelectorAll<HTMLElement>('[data-portes-list]');
  lists.forEach((list) => {
    const slides = Array.from(list.querySelectorAll<HTMLElement>('[data-portes-slide]'));
    const dotsContainer = list.parentElement?.querySelector<HTMLElement>('[data-portes-dots]');
    if (!dotsContainer) return;
    const dots = Array.from(dotsContainer.querySelectorAll<HTMLElement>('span'));
    if (dots.length !== slides.length) return;

    // Mobile only : on n'active l'observer que si le carousel est actif (overflow horizontal).
    const mql = window.matchMedia('(max-width: 640px)');
    let io: IntersectionObserver | null = null;

    const attach = () => {
      if (io || !mql.matches) return;
      io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const idx = slides.indexOf(entry.target as HTMLElement);
            if (idx < 0) return;
            dots.forEach((d, i) => {
              if (i === idx) d.setAttribute('aria-current', 'true');
              else d.removeAttribute('aria-current');
            });
          });
        },
        { root: list, threshold: 0.6 }
      );
      slides.forEach((s) => io!.observe(s));
    };

    const detach = () => {
      if (!io) return;
      io.disconnect();
      io = null;
    };

    attach();
    mql.addEventListener('change', () => (mql.matches ? attach() : detach()));
  });
</script>

<style>
  .portes-head {
    max-width: 62ch;
    margin-bottom: var(--s-8);
  }
  .portes-h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw + 0.5rem, 3rem);
    line-height: 1.1;
    letter-spacing: var(--tr-tighter);
    color: var(--ivoire);
    font-weight: 400;
    margin: var(--s-3) 0 var(--s-3) 0;
  }
  .portes-h2 :global(em) {
    color: var(--cuivre);
    font-style: italic;
  }
  .portes-sub {
    font-size: var(--step-1);
    line-height: var(--lh-loose);
    color: var(--ink-2);
    margin: 0;
    max-width: 56ch;
  }

  .portes-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .porte {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    padding: var(--s-4) var(--s-5);
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 12px;
    color: var(--ivoire);
    text-decoration: none;
    transition: border-color var(--dur-1) var(--ease),
                background var(--dur-1) var(--ease);
    min-height: 64px;
  }
  .porte:hover {
    border-color: var(--cuivre);
    background: var(--bg-3);
  }
  .porte > svg:first-of-type {
    color: var(--cuivre);
    flex-shrink: 0;
  }
  .porte > div {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .porte strong {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-1);
    color: var(--ivoire);
  }
  .porte-delai {
    font-style: italic;
    color: var(--ink-3);
    font-weight: 400;
    margin-left: 2px;
  }
  .porte span {
    font-size: var(--step--1);
    color: var(--ink-3);
  }
  .porte .arrow {
    color: var(--cuivre);
    flex-shrink: 0;
    transition: transform var(--dur-1) var(--ease);
  }
  .porte:hover .arrow {
    transform: translateX(3px);
  }

  /* ─────────────────────────────────────────────
     Dots indicateurs — visibles en mobile only.
     Sur desktop, .portes-dots est caché (display:none).
     ───────────────────────────────────────────── */
  .portes-dots {
    display: none;
    list-style: none;
    padding: 0;
    margin: var(--s-3) 0 0 0;
    justify-content: center;
    gap: 8px;
  }
  .portes-dots li {
    display: flex;
  }
  .portes-dots span {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--line);
    transition: background var(--dur-1) var(--ease),
                transform var(--dur-1) var(--ease);
  }
  .portes-dots span[aria-current="true"] {
    background: var(--cuivre);
    transform: scale(1.3);
  }

  /* ─────────────────────────────────────────────
     Carousel mobile ≤ 640px
     - Scroll-snap horizontal natif (zero JS pour le swipe)
     - Card width = 86% du conteneur, peek de la suivante à droite
     - Pas de scrollbar visible (UA-specific)
     ───────────────────────────────────────────── */
  @media (max-width: 640px) {
    .portes-list {
      flex-direction: row;
      align-items: stretch; /* Cards toutes à la même hauteur (évite saut visuel au swipe) */
      gap: var(--s-3);
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-padding-inline: var(--s-5);
      scrollbar-width: none;
      -ms-overflow-style: none;
      /* Padding latéral pour que la 1ère et la dernière card s'alignent au container */
      padding-inline: var(--s-5);
      margin-inline: calc(var(--s-5) * -1);
      /* Permet de scroller au-delà du dernier item sans rogner */
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
    }
    .portes-list::-webkit-scrollbar {
      display: none;
    }
    .portes-list > li {
      flex: 0 0 86%;
      scroll-snap-align: center;
      scroll-snap-stop: always;
      display: flex; /* pour que .porte puisse stretch en hauteur */
    }
    .porte {
      /* Hauteur équivalente entre les 3 cards pour un swipe propre */
      width: 100%;
      min-height: 110px;
    }
    .portes-dots {
      display: flex;
    }
  }

  /* ─────────────────────────────────────────────
     Respect prefers-reduced-motion
     ───────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .portes-list {
      scroll-behavior: auto;
    }
    .portes-dots span {
      transition: none;
    }
  }
</style>

---
/**
 * V2cHeader — header partagé sur toutes les pages du site.
 * Inclut : logo + nav desktop avec sous-menu Formation + burger mobile + drawer.
 *
 * Props :
 *   currentSection : 'produit' | 'formation' | 'accompagnement' | 'realisations' | 'diagnostic'
 *     marque l'entrée active via aria-current.
 *   compact : si true, header simplifié (utilisé sur diagnostic / merci / brief)
 */
import Icon from './Icon.astro';
import LogoMark from './LogoMark.astro';

interface Props {
  currentSection?: 'produit' | 'formation' | 'accompagnement' | 'realisations' | 'diagnostic';
  compact?: boolean;
}

const { currentSection, compact = false } = Astro.props;

const isFormation = currentSection === 'formation' || currentSection === 'accompagnement';

// Liens primaires (peuvent pointer vers ancre home ou page externe)
const navItems = [
  { id: 'produit', label: 'Le produit', href: '/#construit' },
  {
    id: 'formation',
    label: 'Formation',
    href: '/formation/',
    submenu: [
      { label: "Présentation",                       href: '/formation/' },
      { label: "Accompagnement du dirigeant",        href: '/formation/#accompagnement', highlight: true },
      { label: "Programmes",                         href: '/formation/#programmes' },
      { label: "Demander un devis",                  href: '/formation/brief/', cta: true },
    ],
  },
  { id: 'realisations', label: 'Réalisations', href: '/#preuve' },
];
---

<header class="site-header" role="banner">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="9·58, retour à l'accueil">
      <LogoMark height={38} />
      <span class="brand-tag">Neuf Cinquante Huit</span>
    </a>

    {!compact && (
      <nav class="nav-desktop" aria-label="Navigation principale">
        <ul>
          {navItems.map((item) => (
            <li class={item.submenu ? 'has-sub' : ''}>
              <a
                href={item.href}
                aria-current={currentSection === item.id || (item.id === 'formation' && isFormation) ? 'page' : undefined}
                aria-expanded={item.submenu ? 'false' : undefined}
                aria-haspopup={item.submenu ? 'true' : undefined}
              >
                {item.label}
                {item.submenu && <span class="sub-chevron" aria-hidden="true">▾</span>}
              </a>
              {item.submenu && (
                <ul class="submenu" role="menu">
                  {item.submenu.map((sub) => (
                    <li role="none">
                      <a
                        href={sub.href}
                        role="menuitem"
                        class={[sub.highlight && 'is-highlight', sub.cta && 'is-cta'].filter(Boolean).join(' ')}
                      >
                        {sub.label}
                        {sub.cta && <Icon name="arrow-right" size={14} class="arrow" />}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </nav>
    )}

    <a
      href="/diagnostic/"
      class="btn btn--primary btn--sm header-cta"
      aria-current={currentSection === 'diagnostic' ? 'page' : undefined}
    >
      Diagnostic
      <Icon name="arrow-right" size={14} class="arrow" />
    </a>

    {!compact && (
      <button
        type="button"
        class="burger"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        <span></span><span></span><span></span>
      </button>
    )}
  </div>

  {!compact && (
    <div id="mobile-drawer" class="mobile-drawer" hidden>
      <div class="drawer-head">
        <span class="drawer-title">Menu</span>
        <button type="button" class="drawer-close" aria-label="Fermer le menu">
          <Icon name="x" size={24} />
        </button>
      </div>
      <nav aria-label="Navigation mobile">
        <ul class="drawer-list">
          {navItems.map((item) => (
            <li>
              {item.submenu ? (
                <details class="drawer-section" open={isFormation && item.id === 'formation'}>
                  <summary>
                    {item.label}
                    <Icon name="arrow-right" size={16} class="summary-arrow" />
                  </summary>
                  <ul class="drawer-sublist">
                    {item.submenu.map((sub) => (
                      <li>
                        <a
                          href={sub.href}
                          class={[sub.highlight && 'is-highlight', sub.cta && 'is-cta'].filter(Boolean).join(' ')}
                        >
                          {sub.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ) : (
                <a href={item.href} class="drawer-link">{item.label}</a>
              )}
            </li>
          ))}
        </ul>
        <a href="/diagnostic/" class="btn btn--primary btn--lg drawer-cta">
          Demander un diagnostic
          <Icon name="arrow-right" size={18} class="arrow" />
        </a>
      </nav>
    </div>
  )}
</header>

<script>
  function bindHeader() {
    const burger = document.querySelector<HTMLButtonElement>('.burger');
    const drawer = document.querySelector<HTMLElement>('#mobile-drawer');
    const closeBtn = document.querySelector<HTMLButtonElement>('.drawer-close');
    if (!burger || !drawer) return;

    const setOpen = (open: boolean) => {
      drawer.hidden = !open;
      burger.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
    };

    burger.addEventListener('click', () => setOpen(drawer.hidden));
    closeBtn?.addEventListener('click', () => setOpen(false));

    // Fermer au clic sur un lien
    drawer.querySelectorAll<HTMLAnchorElement>('a').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });

    // Fermer avec Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !drawer.hidden) setOpen(false);
    });

    // Sous-menus desktop : toggle aria-expanded au hover/focus pour a11y
    document.querySelectorAll<HTMLLIElement>('.nav-desktop .has-sub').forEach((li) => {
      const trigger = li.querySelector<HTMLAnchorElement>(':scope > a');
      if (!trigger) return;
      const setExp = (val: boolean) => trigger.setAttribute('aria-expanded', String(val));
      li.addEventListener('mouseenter', () => setExp(true));
      li.addEventListener('mouseleave', () => setExp(false));
      li.addEventListener('focusin', () => setExp(true));
      li.addEventListener('focusout', (e) => {
        if (!li.contains(e.relatedTarget as Node)) setExp(false);
      });
    });
  }
  bindHeader();
  document.addEventListener('astro:page-load', bindHeader);
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(11, 11, 10, 0.78);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-h);
    gap: var(--s-4);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--ivoire);
    text-decoration: none;
  }
  .brand-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
    line-height: 1.2;
  }

  /* ============ NAV DESKTOP ============ */
  .nav-desktop {
    flex: 1;
    display: flex;
    justify-content: center;
  }
  .nav-desktop > ul {
    display: flex;
    gap: var(--s-5);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-desktop a {
    font-size: var(--step-0);
    font-weight: 500;
    color: var(--ink-2);
    padding: 8px 2px;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-1) var(--ease),
                border-color var(--dur-1) var(--ease);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .nav-desktop a:hover,
  .nav-desktop a[aria-current="page"] {
    color: var(--cuivre);
    border-bottom-color: var(--cuivre);
  }
  .sub-chevron {
    font-size: 10px;
    color: var(--ink-3);
    transition: transform var(--dur-1) var(--ease);
  }
  .has-sub:hover .sub-chevron,
  .has-sub:focus-within .sub-chevron {
    transform: rotate(180deg);
    color: var(--cuivre);
  }

  /* Dropdown sous-menu desktop */
  .has-sub { position: relative; }
  .submenu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    min-width: 280px;
    max-width: 300px;
    background: var(--bg-2);
    border: 1px solid var(--line-2);
    border-radius: var(--r-3);
    padding: 6px;
    list-style: none;
    margin: 0;
    box-shadow: var(--shadow-lg);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--dur-1) var(--ease),
                visibility var(--dur-1) var(--ease),
                transform var(--dur-1) var(--ease);
  }
  .has-sub:hover .submenu,
  .has-sub:focus-within .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .submenu a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 10px 12px;
    border-radius: var(--r-2);
    border-bottom: 0;
    font-size: var(--step-0);
    color: var(--ink-2);
    white-space: nowrap;
  }
  .submenu a:hover {
    background: var(--bg-3);
    color: var(--cuivre);
    border-bottom-color: transparent;
  }
  /* Highlight item — fond cuivre soft pour mettre en avant le différenciateur */
  .submenu a.is-highlight {
    background: var(--cuivre-soft);
    color: var(--ivoire);
    font-weight: 600;
  }
  .submenu a.is-highlight:hover {
    background: var(--cuivre-soft);
    color: var(--cuivre);
  }
  /* CTA secondary — divider top + lien cuivre simple (pas de fond plein) */
  .submenu li:last-child {
    margin-top: 6px;
    padding-top: 6px;
    border-top: 1px solid var(--line);
  }
  .submenu a.is-cta {
    color: var(--cuivre);
    font-weight: 600;
  }
  .submenu a.is-cta:hover {
    background: var(--cuivre-soft);
    color: var(--cuivre);
  }
  .submenu a.is-cta .arrow {
    transition: transform var(--dur-1) var(--ease);
  }
  .submenu a.is-cta:hover .arrow {
    transform: translateX(3px);
  }

  /* ============ BURGER (mobile only) ============ */
  .burger {
    display: none;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid var(--line-2);
    border-radius: var(--r-2);
    cursor: pointer;
    padding: 12px 10px;
    flex-direction: column;
    justify-content: space-between;
    align-items: stretch;
  }
  .burger span {
    display: block;
    height: 2px;
    background: var(--ivoire);
    border-radius: 1px;
    transition: transform var(--dur-1) var(--ease);
  }
  .burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .burger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ============ MOBILE DRAWER ============ */
  .mobile-drawer {
    position: fixed;
    inset: 0;
    top: var(--header-h);
    background: var(--bg);
    z-index: 49;
    padding: var(--s-5) var(--gutter) var(--s-7);
    overflow-y: auto;
    animation: drawerFadeIn 0.25s var(--ease-out);
  }
  @keyframes drawerFadeIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: var(--s-4);
    border-bottom: 1px solid var(--line);
    margin-bottom: var(--s-4);
  }
  .drawer-title {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 600;
  }
  .drawer-close {
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid var(--line-2);
    border-radius: var(--r-2);
    color: var(--ivoire);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .drawer-close:hover { border-color: var(--cuivre); color: var(--cuivre); }

  .drawer-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--s-6) 0;
    display: flex;
    flex-direction: column;
  }
  .drawer-list > li {
    border-bottom: 1px solid var(--line);
  }
  .drawer-link, .drawer-section > summary {
    font-family: var(--font-display);
    font-size: var(--step-3);
    color: var(--ivoire);
    padding: var(--s-4) 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    list-style: none;
    cursor: pointer;
    min-height: 44px;
  }
  .drawer-section > summary::-webkit-details-marker { display: none; }
  .drawer-section[open] > summary { color: var(--cuivre); }
  .summary-arrow {
    transition: transform var(--dur-1) var(--ease);
    color: var(--ink-3);
  }
  .drawer-section[open] > summary .summary-arrow {
    transform: rotate(90deg);
    color: var(--cuivre);
  }
  .drawer-sublist {
    list-style: none;
    padding: 0 0 var(--s-4) var(--s-4);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .drawer-sublist a {
    display: block;
    padding: 12px 0;
    font-size: var(--step-1);
    color: var(--ink-2);
    text-decoration: none;
    min-height: 44px;
  }
  .drawer-sublist a:hover { color: var(--cuivre); }
  .drawer-sublist a.is-highlight {
    color: var(--ivoire);
    font-weight: 600;
  }
  .drawer-sublist a.is-cta {
    color: var(--cuivre);
    font-weight: 600;
  }
  .drawer-cta {
    width: 100%;
    justify-content: center;
  }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 1024px) {
    .submenu { min-width: 240px; }
  }
  @media (max-width: 900px) {
    .nav-desktop, .header-cta { display: none; }
    .burger { display: inline-flex; }
  }
  @media (min-width: 901px) {
    .mobile-drawer { display: none !important; }
  }
</style>

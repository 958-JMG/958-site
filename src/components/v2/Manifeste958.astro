---
/**
 * Manifeste958 v3 — épuré + cockpit pédagogique
 *
 * 5 paliers de lecture côté texte (au lieu de 10) :
 *   1. Eyebrow (contexte)
 *   2. H2 court (entrée + lien Tilt®↔9·58 explicite)
 *   3. Constat 3 lignes (preuve concrète)
 *   4. Punchline WHY Sinek
 *   5. Coda + signature (ancrage 28 ans)
 *
 * Visuel pédagogique côté droit :
 *   - Mini ampoule (le déclic Tilt®) en haut
 *   - Cockpit détaillé avec labels lisibles : sidebar, KPIs, graph, assistant IA
 *
 * Props :
 *   variant : 'soft' (fond bg-2, default) | 'plain' (fond bg)
 *   sectionId : id ancre (default "manifeste")
 *   showSignature : afficher la signature (default true)
 */

interface Props {
  variant?: 'soft' | 'plain';
  sectionId?: string;
  showSignature?: boolean;
}

const {
  variant = 'soft',
  sectionId = 'manifeste',
  showSignature = true,
} = Astro.props;

const sectionClass = variant === 'soft' ? 'section section--soft' : 'section';
---

<section class={sectionClass} aria-labelledby={`${sectionId}-title`} id={sectionId}>
  <div class="container">
    <p class="eyebrow reveal manifeste-eyebrow">
      <span class="eyebrow-dash" aria-hidden="true"></span>
      Pourquoi 9·58 <span aria-hidden="true">&amp;</span><span class="sr-only">et</span> Ça fait Tilt<sup aria-label="marque déposée">®</sup>
    </p>

    <div class="manifeste-grid">
      <div class="manifeste-text">
        <h2 class="reveal manifeste-h2" id={`${sectionId}-title`}>
          Avant, <em>j'étais comme vous.</em>
        </h2>

        <div class="reveal manifeste-recit">
          <p class="recit-decouverte">
            <span class="manifeste-kicker">Ça fait Tilt<sup aria-label="marque déposée">®</sup></span>
            le jour où j'ai compris que l'IA pouvait être notre alliée —
            <em>à condition qu'elle vive chez nous</em>.
          </p>
          <p class="recit-transmission">
            Ce déclic, j'ai voulu le partager.<br>
            <em>C'est devenu <strong>Ça fait Tilt<sup aria-label="marque déposée">®</sup></strong>, la formation.</em><br>
            <em>Et <strong>9·58</strong>, le cockpit qui fait qu'il ne s'éteint pas le lundi suivant.</em>
          </p>
        </div>

        <ul class="reveal manifeste-constat" role="list">
          <li>Une formation IA qui finit le vendredi soir, ça ne tient pas trois mois.</li>
          <li>Un cockpit IA livré sans formation, ça prend la poussière.</li>
          <li>Une IA hébergée loin de chez vous, ça ne deviendra jamais vraiment la vôtre.</li>
        </ul>

        <blockquote class="reveal manifeste-punchline">
          L'IA n'a pas été inventée pour vous remplacer.<br>
          <em>Elle a été inventée pour vous rendre votre temps.</em>
        </blockquote>

        <p class="reveal manifeste-coda">
          Encore faut-il qu'elle <em>vive chez vous</em>.
        </p>

        {showSignature && (
          <p class="reveal manifeste-sig">
            — Jean-Marc Geuring · 28 ans d'entrepreneuriat · Fondateur 9·58
          </p>
        )}
      </div>

      <aside class="manifeste-visual reveal" aria-hidden="true">
        <!-- Mini ampoule (le déclic Tilt® qui allume le cockpit) -->
        <svg class="manifeste-bulb" viewBox="0 0 80 110" xmlns="http://www.w3.org/2000/svg">
          <g class="bulb-rays">
            <line x1="40" y1="14" x2="40" y2="2" />
            <line x1="14" y1="32" x2="3" y2="22" />
            <line x1="66" y1="32" x2="77" y2="22" />
            <line x1="10" y1="56" x2="0" y2="56" />
            <line x1="70" y1="56" x2="80" y2="56" />
          </g>
          <circle cx="40" cy="48" r="26" fill="#0B0B0A" stroke="#C75F2D" stroke-width="2" />
          <path
            class="bulb-filament"
            d="M 28 48 Q 28 36 40 36 Q 52 36 52 48 Q 52 56 40 54 Q 28 56 28 48 Z"
            fill="none"
            stroke="#C75F2D"
            stroke-width="2"
            stroke-linecap="round"
          />
          <line x1="35" y1="60" x2="35" y2="74" stroke="#C75F2D" stroke-width="1.5" />
          <line x1="45" y1="60" x2="45" y2="74" stroke="#C75F2D" stroke-width="1.5" />
          <rect x="30" y="76" width="20" height="8" fill="#C75F2D" rx="1" />
          <rect x="31" y="86" width="18" height="1.5" fill="#0B0B0A" />
          <rect x="31" y="90" width="18" height="1.5" fill="#0B0B0A" />
          <rect x="33" y="95" width="14" height="5" fill="#C75F2D" rx="1" />
        </svg>

        <!-- Trait de connexion ampoule → cockpit -->
        <div class="manifeste-link" aria-hidden="true">
          <span class="link-label">Le déclic alimente l'outil</span>
        </div>

        <!-- Cockpit détaillé avec labels lisibles -->
        <div class="manifeste-cockpit">
          <!-- Header cockpit -->
          <div class="cockpit-header">
            <span class="cockpit-brand">9·58 COCKPIT</span>
            <span class="cockpit-search">⌕ Rechercher dans 9·58…</span>
            <span class="cockpit-avatar" aria-hidden="true">
              <span class="avatar-dot"></span>
              JMG
            </span>
          </div>

          <div class="cockpit-body">
            <!-- Sidebar -->
            <nav class="cockpit-sidebar" aria-label="Navigation cockpit (illustratif)">
              <ul>
                <li class="is-active"><span class="side-icon" aria-hidden="true">▦</span> Accueil</li>
                <li><span class="side-icon" aria-hidden="true">✉</span> Inbox IA <em>3</em></li>
                <li><span class="side-icon" aria-hidden="true">◯</span> Clients <em>12</em></li>
                <li><span class="side-icon" aria-hidden="true">◰</span> Projets <em>7</em></li>
                <li><span class="side-icon" aria-hidden="true">◊</span> Docs IA</li>
                <li><span class="side-icon" aria-hidden="true">▤</span> Tréso</li>
              </ul>
            </nav>

            <!-- Main content -->
            <div class="cockpit-main">
              <p class="cockpit-eyebrow">ACCUEIL · VENDREDI 29 MAI</p>
              <p class="cockpit-greet">Bonjour Jean-Marc,</p>
              <p class="cockpit-sub">Vous avez <em>2 mails</em> à traiter et <em>5 tâches</em> prioritaires.</p>

              <div class="cockpit-kpis">
                <div class="kpi">
                  <span class="kpi-label">CA 12 mois</span>
                  <span class="kpi-value">148 k€</span>
                  <span class="kpi-delta">+18 %</span>
                </div>
                <div class="kpi">
                  <span class="kpi-label">Pipeline</span>
                  <span class="kpi-value">122 k€</span>
                  <span class="kpi-delta">+4 missions</span>
                </div>
                <div class="kpi">
                  <span class="kpi-label">Trésorerie</span>
                  <span class="kpi-value">92 k€</span>
                  <span class="kpi-delta">+12 %</span>
                </div>
              </div>

              <!-- Mini graphique -->
              <div class="cockpit-graph" aria-hidden="true">
                <svg viewBox="0 0 200 50" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                  <polyline
                    points="0,38 25,32 50,36 75,28 100,30 125,22 150,24 175,16 200,10"
                    fill="none"
                    stroke="#C75F2D"
                    stroke-width="1.5"
                  />
                  <polyline
                    points="0,40 25,38 50,42 75,36 100,38 125,32 150,34 175,28 200,24 200,50 0,50"
                    fill="rgba(199,95,45,0.08)"
                    stroke="none"
                  />
                </svg>
              </div>
            </div>
          </div>

          <!-- Bandeau IA -->
          <div class="cockpit-ia">
            <span class="ia-dot" aria-hidden="true"></span>
            <span class="ia-label">Assistant IA</span>
            <span class="ia-text"><em>Je peux préparer vos relances clients du jour ?</em></span>
          </div>
        </div>

        <!-- Légende pédagogique -->
        <ol class="manifeste-legende">
          <li><span class="lg-n">①</span> <strong>Sidebar</strong> · Tout votre métier, un seul endroit</li>
          <li><span class="lg-n">②</span> <strong>KPIs</strong> · Vos chiffres en temps réel, sans Excel</li>
          <li><span class="lg-n">③</span> <strong>Assistant IA</strong> · Branché sur vos données, hébergé chez vous</li>
        </ol>
      </aside>
    </div>
  </div>
</section>

<script>
  // IntersectionObserver pour déclencher l'animation au scroll-in
  function bindManifesteVisual() {
    const visuals = document.querySelectorAll<HTMLElement>('.manifeste-visual');
    if (!visuals.length) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-lit');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.25 }
    );

    visuals.forEach((v) => io.observe(v));
  }

  bindManifesteVisual();
  document.addEventListener('astro:page-load', bindManifesteVisual);
</script>

<style>
  /* ============ LAYOUT GRID 50/50 ============ */
  .manifeste-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--s-8);
    align-items: start;
  }
  @media (max-width: 960px) {
    .manifeste-grid {
      grid-template-columns: 1fr;
      gap: var(--s-7);
    }
    .manifeste-visual {
      order: -1;
      max-width: 540px;
      margin-inline: auto;
    }
  }

  /* ============ EYEBROW ============ */
  .manifeste-eyebrow {
    margin-bottom: var(--s-7);
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
    font-size: 13px;
  }
  .eyebrow-dash {
    display: inline-block;
    width: 28px;
    height: 2px;
    background: var(--cuivre);
    flex-shrink: 0;
  }

  /* ============ TEXTE GAUCHE — 5 paliers seulement ============ */
  .manifeste-text {
    max-width: 52ch;
    display: flex;
    flex-direction: column;
    gap: var(--s-6);
  }

  /* 1. H2 — récit fondateur, court et mémorable */
  .manifeste-h2 {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 3.4vw + 0.4rem, 2.9rem);
    line-height: 1.15;
    letter-spacing: var(--tr-tighter);
    color: var(--ivoire);
    margin: 0;
    font-weight: 400;
  }
  .manifeste-h2 em {
    color: var(--cuivre);
    font-style: italic;
  }

  /* 2. Récit narratif — découverte personnelle → transmission */
  .manifeste-recit {
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
  }
  .manifeste-recit p {
    font-family: var(--font-display);
    font-size: var(--step-1);
    line-height: var(--lh-loose);
    color: var(--ivoire);
    margin: 0;
  }
  .manifeste-recit strong {
    color: var(--cuivre);
    font-weight: 500;
  }
  .manifeste-recit em {
    color: var(--cuivre);
    font-style: italic;
  }
  /* Pivot dramatique : "Ce déclic, j'ai voulu le partager" — légèrement
     en retrait + couleur ivoire forte sur la 1re ligne, italique cuivre
     sur les 2 suivantes (la transmission proprement dite) */
  .recit-transmission {
    padding-left: var(--s-4);
    border-left: 1px solid var(--cuivre-soft);
  }
  .recit-transmission em {
    line-height: 1.5;
  }
  .manifeste-kicker {
    display: inline;
    font-weight: 500;
    color: var(--cuivre);
    margin-right: 0.2em;
  }

  /* 2. Constat 3 lignes — preuve concrète, serif droit */
  .manifeste-constat {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    border-left: 2px solid var(--ink-3);
    padding-left: var(--s-5);
  }
  .manifeste-constat li {
    font-family: var(--font-display);
    font-size: var(--step-1);
    line-height: var(--lh-loose);
    color: var(--ivoire);
  }

  /* 3. Punchline WHY Sinek */
  .manifeste-punchline {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.6vw + 0.4rem, 2.2rem);
    line-height: 1.2;
    letter-spacing: var(--tr-tighter);
    color: var(--ivoire);
    border-left: 3px solid var(--cuivre);
    padding: var(--s-3) 0 var(--s-3) var(--s-5);
    margin: 0;
    font-weight: 400;
  }
  .manifeste-punchline em {
    color: var(--cuivre);
    font-style: italic;
    display: inline-block;
  }

  /* 4. Coda */
  .manifeste-coda {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.4vw + 0.4rem, 2rem);
    line-height: 1.3;
    color: var(--ivoire);
    margin: 0;
    font-weight: 400;
  }
  .manifeste-coda em {
    color: var(--cuivre);
    font-style: italic;
  }

  /* 5. Signature — ancrage 28 ans */
  .manifeste-sig {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0;
    border-top: 1px solid var(--line);
    padding-top: var(--s-4);
  }

  /* Sup pour ® */
  :where(.manifeste-text, .manifeste-cockpit, .cockpit-brand) sup {
    font-size: 0.55em;
    vertical-align: super;
  }

  /* ============ VISUEL DROITE — pédagogique ============ */
  .manifeste-visual {
    position: sticky;
    top: calc(var(--header-h) + var(--s-4));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-3);
  }
  @media (max-width: 960px) {
    .manifeste-visual { position: static; }
  }

  /* Mini ampoule en haut, centrée */
  .manifeste-bulb {
    width: 64px;
    height: auto;
  }
  .bulb-rays line {
    stroke: var(--cuivre);
    stroke-width: 2;
    stroke-linecap: round;
    opacity: 0;
    transition: opacity 0.6s var(--ease);
  }
  .bulb-filament {
    opacity: 0.3;
    transition: opacity 0.6s var(--ease), filter 0.8s var(--ease);
  }
  .manifeste-visual.is-lit .bulb-rays line { opacity: 0.7; }
  .manifeste-visual.is-lit .bulb-filament {
    opacity: 1;
    filter: drop-shadow(0 0 4px rgba(199, 95, 45, 0.6));
  }

  /* Trait connexion + label */
  .manifeste-link {
    height: 32px;
    width: 2px;
    background-image: linear-gradient(180deg, var(--cuivre) 50%, transparent 50%);
    background-size: 1px 6px;
    background-repeat: repeat-y;
    position: relative;
    margin: 4px 0;
  }
  .link-label {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-3);
    white-space: nowrap;
  }

  /* ============ COCKPIT DÉTAILLÉ ============ */
  .manifeste-cockpit {
    width: 100%;
    max-width: 480px;
    background: var(--bg-3);
    border: 1px solid var(--cuivre);
    border-radius: 10px;
    overflow: hidden;
    font-family: var(--font-mono);
    box-shadow: 0 8px 24px -8px rgba(199, 95, 45, 0.25);
    opacity: 0.65;
    transition: opacity 0.6s var(--ease);
  }
  .manifeste-visual.is-lit .manifeste-cockpit { opacity: 1; }

  /* Header cockpit */
  .cockpit-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: var(--bg-2);
    border-bottom: 1px solid var(--line);
    font-size: 10px;
  }
  .cockpit-brand {
    font-family: var(--font-display);
    color: var(--ivoire);
    font-size: 12px;
    letter-spacing: 0;
    font-weight: 500;
  }
  .cockpit-search {
    flex: 1;
    color: var(--ink-3);
    font-size: 9px;
    text-align: left;
    padding-left: 12px;
    letter-spacing: 0.04em;
  }
  .cockpit-avatar {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--ink-2);
    font-size: 9px;
    letter-spacing: 0.06em;
  }
  .avatar-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cuivre);
  }

  /* Body cockpit : sidebar + main */
  .cockpit-body {
    display: grid;
    grid-template-columns: 90px 1fr;
    min-height: 220px;
  }
  .cockpit-sidebar {
    background: var(--bg-2);
    border-right: 1px solid var(--line);
    padding: 8px 4px;
  }
  .cockpit-sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cockpit-sidebar li {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 8px;
    font-size: 9px;
    letter-spacing: 0.02em;
    color: var(--ink-2);
    border-radius: 4px;
  }
  .cockpit-sidebar li.is-active {
    background: rgba(199, 95, 45, 0.12);
    color: var(--cuivre);
  }
  .side-icon {
    font-size: 11px;
    color: var(--ink-3);
    width: 12px;
    text-align: center;
  }
  .cockpit-sidebar li.is-active .side-icon { color: var(--cuivre); }
  .cockpit-sidebar li em {
    margin-left: auto;
    font-style: normal;
    color: var(--ink-3);
    background: var(--bg-3);
    padding: 1px 4px;
    border-radius: 3px;
    font-size: 8px;
  }

  /* Main */
  .cockpit-main {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cockpit-eyebrow {
    font-size: 8px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0;
  }
  .cockpit-greet {
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--ivoire);
    margin: 0;
    line-height: 1.1;
  }
  .cockpit-sub {
    font-size: 9px;
    color: var(--ink-2);
    margin: 0;
    line-height: 1.4;
  }
  .cockpit-sub em {
    font-style: normal;
    color: var(--cuivre);
    font-weight: 600;
  }

  /* KPIs */
  .cockpit-kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    margin-top: 2px;
  }
  .kpi {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 6px 7px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .kpi-label {
    font-size: 7px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .kpi-value {
    font-family: var(--font-display);
    font-size: 14px;
    color: var(--ivoire);
    line-height: 1.05;
  }
  .kpi-delta {
    font-size: 8px;
    color: var(--cuivre);
    font-weight: 600;
  }

  /* Mini graph */
  .cockpit-graph {
    margin-top: 4px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 6px;
    height: 50px;
  }
  .cockpit-graph svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Bandeau IA */
  .cockpit-ia {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: rgba(199, 95, 45, 0.06);
    border-top: 1px solid var(--cuivre);
    font-size: 10px;
  }
  .ia-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cuivre);
    flex-shrink: 0;
  }
  .manifeste-visual.is-lit .ia-dot {
    animation: ia-pulse 2s ease-in-out infinite;
  }
  @keyframes ia-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }
  .ia-label {
    color: var(--cuivre);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 9px;
  }
  .ia-text {
    color: var(--ink-2);
    flex: 1;
    font-size: 10px;
  }
  .ia-text em {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ivoire);
  }

  /* ============ LÉGENDE PÉDAGOGIQUE ============ */
  .manifeste-legende {
    list-style: none;
    padding: 0;
    margin: var(--s-4) 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: 480px;
    width: 100%;
  }
  .manifeste-legende li {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 12px;
    line-height: 1.4;
    color: var(--ink-2);
  }
  .manifeste-legende strong {
    color: var(--ivoire);
    font-weight: 600;
  }
  .lg-n {
    color: var(--cuivre);
    font-family: var(--font-mono);
    font-size: 13px;
    flex-shrink: 0;
  }

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .manifeste-visual.is-lit .ia-dot { animation: none; }
    .manifeste-visual.is-lit .bulb-filament { filter: none; }
  }
</style>

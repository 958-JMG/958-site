---
import Icon from './Icon.astro';

interface Props {
  /** Chemin courant pour marquer le lien actif */
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const nav = [
  { href: '/produit/',       label: 'Produit' },
  { href: '/souverainete/',  label: 'Souveraineté' },
  { href: '/formation/',     label: 'Formation' },
  { href: '/methode/',       label: 'Méthode' },
  { href: '/realisations/',  label: 'Réalisations' },
];
---

<header class="site-header" role="banner">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="9·58, retour à l'accueil">
      <span class="brand-mark">9·58</span>
      <span class="brand-tag">Neuf Cinquante Huit</span>
    </a>

    <nav class="nav nav-desktop" aria-label="Navigation principale">
      <ul>
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class={currentPath.startsWith(item.href) ? 'is-active' : ''}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <a href="/contact/" class="btn btn--primary btn--sm header-cta">
        Diagnostic
        <Icon name="arrow-right" size={14} class="arrow" />
      </a>
      <button type="button" class="menu-toggle" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
        <Icon name="menu" size={24} />
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="mobile-menu" hidden>
    <nav aria-label="Navigation mobile">
      <ul>
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
        <li><a href="/a-propos/">À propos</a></li>
        <li><a href="/contact/" class="mobile-cta-link">Demander un diagnostic <Icon name="arrow-right" size={16} /></a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(245, 245, 235, 0.92);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-h);
    gap: var(--s-5);
  }
  .brand {
    display: inline-flex;
    flex-direction: column;
    line-height: 1;
    color: var(--ink);
    text-decoration: none;
    gap: 2px;
  }
  .brand-mark {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    color: var(--bleu);
  }
  .brand-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-2);
  }
  .nav-desktop ul {
    display: flex;
    gap: var(--s-5);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-desktop a {
    font-size: var(--step-0);
    font-weight: 500;
    color: var(--ink);
    padding: 6px 2px;
    border-bottom: 2px solid transparent;
    transition: border-color var(--dur-1) var(--ease),
                color var(--dur-1) var(--ease);
  }
  .nav-desktop a:hover {
    color: var(--bleu);
    border-bottom-color: var(--bleu);
  }
  .nav-desktop a.is-active {
    color: var(--bleu);
    border-bottom-color: var(--bleu);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--s-3);
  }
  .menu-toggle {
    display: none;
    padding: 8px;
    border-radius: var(--r-2);
    color: var(--ink);
  }
  .menu-toggle:hover {
    background: var(--ivoire-2);
  }
  .mobile-menu {
    display: none;
    border-top: 1px solid var(--line);
    background: var(--ivoire);
  }
  .mobile-menu[aria-expanded="true"],
  .mobile-menu:not([hidden]) {
    display: block;
  }
  .mobile-menu ul {
    list-style: none;
    padding: var(--s-4) var(--gutter);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .mobile-menu a {
    display: block;
    padding: 12px 0;
    font-size: var(--step-1);
    color: var(--ink);
    border-bottom: 1px solid var(--line);
  }
  .mobile-cta-link {
    display: inline-flex !important;
    align-items: center;
    gap: 0.4rem;
    color: var(--bleu) !important;
    font-weight: 600;
    border-bottom: 0 !important;
    padding: 12px 0 !important;
  }

  @media (max-width: 900px) {
    .nav-desktop {
      display: none;
    }
    .header-cta {
      display: none;
    }
    .menu-toggle {
      display: inline-flex;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const menu = document.querySelector<HTMLElement>('#mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = !menu.hidden;
      menu.hidden = isOpen;
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>

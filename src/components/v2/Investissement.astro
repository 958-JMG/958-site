---
/**
 * Investissement — section transparence tarifaire.
 *
 * 3 lignes simples : Atelier découverte / Cockpit 90 jours / Accompagnement annuel.
 * Pas une grille tarifaire, juste un ordre de grandeur honnête qui rassure
 * et différencie face à la concurrence locale opaque.
 *
 * Props :
 *   variant : 'soft' (default) | 'plain'
 *   eyebrow : libellé eyebrow (default "Investissement")
 *   title : H2 (default "Transparence tarifaire.")
 *   subtitle : phrase d'intro
 *   sectionId : id ancre
 */
interface Props {
  variant?: 'soft' | 'plain';
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  sectionId?: string;
}

const {
  variant = 'soft',
  eyebrow = 'Investissement',
  title = 'Transparence <em>tarifaire.</em>',
  subtitle = "Pour qu'on parle vrai dès le départ. Les prix planchers ci-dessous couvrent la grande majorité des cas. Le devis personnalisé arrive après l'échange initial.",
  sectionId = 'investissement',
} = Astro.props;

const offres = [
  {
    label: 'Atelier découverte IA dirigeant',
    duree: '½ journée à 1 jour',
    prix: 'à partir de 900 €',
    note: 'HT, financement OPCO possible',
  },
  {
    label: 'Cockpit IA — 90 jours',
    duree: 'Audit → Build → Mise en service',
    prix: 'à partir de 2 000 €',
    note: 'HT, paiement échelonné',
  },
  {
    label: 'Accompagnement annuel',
    duree: 'SAV inclus, évolutions, support dirigeant',
    prix: 'sur devis',
    note: 'après le cockpit',
  },
];

const sectionClass = variant === 'soft' ? 'section section--soft' : 'section';
---

<section class={sectionClass} aria-labelledby={`${sectionId}-title`} id={sectionId}>
  <div class="container is-default">
    <div class="invest-head">
      <p class="eyebrow reveal">{eyebrow}</p>
      <h2 id={`${sectionId}-title`} class="reveal invest-h2" set:html={title} />
      <p class="reveal invest-sub">{subtitle}</p>
    </div>

    <ul class="invest-list reveal">
      {offres.map((offre) => (
        <li class="invest-row">
          <div class="invest-row-label">
            <strong>{offre.label}</strong>
            <span class="invest-duree">{offre.duree}</span>
          </div>
          <div class="invest-row-prix">
            <span class="invest-prix">{offre.prix}</span>
            <span class="invest-note">{offre.note}</span>
          </div>
        </li>
      ))}
    </ul>

    <p class="invest-foot reveal">
      Souverain par défaut, le choix vous appartient.
      <a href="/diagnostic/" class="invest-link">
        Cadrons votre besoin
        <span aria-hidden="true">→</span>
      </a>
    </p>
  </div>
</section>

<style>
  .invest-head {
    max-width: 62ch;
    margin-bottom: var(--s-7);
  }
  .invest-h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw + 0.5rem, 3rem);
    line-height: 1.1;
    letter-spacing: var(--tr-tighter);
    color: var(--ivoire);
    font-weight: 400;
    margin: var(--s-3) 0 var(--s-3) 0;
  }
  .invest-h2 :global(em) {
    color: var(--cuivre);
    font-style: italic;
  }
  .invest-sub {
    font-size: var(--step-1);
    line-height: var(--lh-loose);
    color: var(--ink-2);
    margin: 0;
    max-width: 56ch;
  }

  .invest-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--s-5) 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--line);
  }
  .invest-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-4);
    padding: var(--s-4) 0;
    border-bottom: 1px solid var(--line);
  }
  .invest-row-label {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .invest-row-label strong {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-1);
    color: var(--ivoire);
    line-height: 1.2;
  }
  .invest-duree {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-3);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .invest-row-prix {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    flex-shrink: 0;
    text-align: right;
  }
  .invest-prix {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-1);
    color: var(--cuivre);
    line-height: 1.2;
    white-space: nowrap;
  }
  .invest-note {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-3);
    letter-spacing: 0.02em;
  }

  .invest-foot {
    font-size: var(--step--1);
    color: var(--ink-2);
    margin: 0;
  }
  .invest-link {
    color: var(--cuivre);
    text-decoration: none;
    margin-left: 6px;
    font-weight: 500;
    transition: color var(--dur-1) var(--ease);
  }
  .invest-link:hover { color: var(--cuivre-2, #E07C42); }
  .invest-link span {
    display: inline-block;
    margin-left: 4px;
    transition: transform var(--dur-1) var(--ease);
  }
  .invest-link:hover span { transform: translateX(3px); }

  /* Mobile : empiler label/prix verticalement pour lisibilité (390px) */
  @media (max-width: 640px) {
    .invest-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
    .invest-row-prix {
      align-items: flex-start;
      text-align: left;
    }
    .invest-foot {
      font-size: var(--step--1);
      line-height: 1.5;
    }
    .invest-link {
      display: inline-block;
      margin-top: 6px;
      margin-left: 0;
    }
  }
</style>

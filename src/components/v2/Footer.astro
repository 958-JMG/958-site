---
import Icon from './Icon.astro';

const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand" aria-label="9·58, retour à l'accueil">
        <span class="brand-mark">9·58</span>
        <span class="brand-tag">Neuf Cinquante Huit</span>
      </a>
      <p class="footer-pitch">
        L'IA souveraine du bâtiment et de l'immobilier 360°.
        Audit, sur-mesure, formation. Vannes &amp; Paris.
      </p>
      <p class="footer-cities">
        <Icon name="map-pin" size={14} /> Vannes &middot; Paris
      </p>
    </div>

    <nav class="footer-nav" aria-label="Plan du site">
      <div>
        <h2 class="footer-h">Produit</h2>
        <ul>
          <li><a href="/produit/">Présentation</a></li>
          <li><a href="/produit/batiment/">Bâtiment</a></li>
          <li><a href="/produit/immobilier/">Immobilier</a></li>
          <li><a href="/realisations/">Réalisations</a></li>
          <li><a href="https://demo.958.fr">Hub démo →</a></li>
        </ul>
      </div>
      <div>
        <h2 class="footer-h">Approche</h2>
        <ul>
          <li><a href="/souverainete/">Souveraineté</a></li>
          <li><a href="/methode/">Méthode SPARI</a></li>
          <li><a href="/a-propos/">À propos</a></li>
          <li><a href="/blog/">Blog</a></li>
        </ul>
      </div>
      <div>
        <h2 class="footer-h">Formation</h2>
        <ul>
          <li><a href="/formation/">Catalogue</a></li>
          <li><a href="/formation/dirigeants/">Dirigeants</a></li>
          <li><a href="/formation/equipes/">Équipes</a></li>
          <li><a href="/formation/qualiopi-opco/">Qualiopi &amp; OPCO</a></li>
        </ul>
      </div>
      <div>
        <h2 class="footer-h">Contact</h2>
        <ul>
          <li><a href="/contact/">Demander un diagnostic</a></li>
          <li><a href="mailto:jmg@958.fr">jmg@958.fr</a></li>
          <li>
            <a href="https://www.linkedin.com/in/jean-marc-geuring/" rel="me noopener" target="_blank">
              <Icon name="linkedin" size={14} /> LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="footer-bottom container">
    <div class="footer-meta">
      <span>© {year} Neuf Cinquante Huit</span>
      <span class="dot">·</span>
      <a href="/mentions-legales/">Mentions légales</a>
      <span class="dot">·</span>
      <a href="/confidentialite/">Confidentialité</a>
    </div>
    <div class="footer-signal">
      <span class="chip chip--mimosa">Qualiopi · juin 2026</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bleu-deep);
    color: var(--bleu-clair);
    padding-block: var(--s-9) var(--s-5);
    margin-top: var(--s-10);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: var(--s-8);
  }
  .brand {
    display: inline-flex;
    flex-direction: column;
    line-height: 1;
    color: var(--ivoire);
    text-decoration: none;
    gap: 4px;
    margin-bottom: var(--s-4);
  }
  .brand-mark {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    color: var(--mimosa);
  }
  .brand-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bleu-clair);
  }
  .footer-pitch {
    color: var(--bleu-clair);
    font-size: var(--step-0);
    line-height: var(--lh-normal);
    margin: 0 0 var(--s-4) 0;
    max-width: 32ch;
  }
  .footer-cities {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mimosa);
    margin: 0;
    max-width: none;
  }
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-5);
  }
  .footer-h {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mimosa);
    margin: 0 0 var(--s-4) 0;
    font-weight: 500;
  }
  .footer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .footer-nav a {
    color: var(--bleu-clair);
    font-size: var(--step-0);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .footer-nav a:hover {
    color: var(--mimosa);
  }
  .footer-bottom {
    margin-top: var(--s-7);
    padding-top: var(--s-5);
    border-top: 1px solid rgba(220, 220, 236, 0.15);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    flex-wrap: wrap;
  }
  .footer-meta {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--bleu-clair);
    letter-spacing: 0.04em;
  }
  .footer-meta a { color: var(--bleu-clair); }
  .footer-meta a:hover { color: var(--mimosa); }
  .dot { color: rgba(220, 220, 236, 0.4); }

  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--s-6);
    }
    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--s-6);
    }
  }
  @media (max-width: 520px) {
    .footer-nav {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Icon from './Icon.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  primary?: { label: string; href: string };
  secondary?: { label: string; href: string };
  /** Variante : default (sur ivoire), dark (bleu nuit), mimosa */
  variant?: 'default' | 'dark' | 'mimosa';
}

const {
  eyebrow,
  title,
  description,
  primary,
  secondary,
  variant = 'default',
} = Astro.props;

const sectionClass =
  variant === 'dark' ? 'section section--dark' :
  variant === 'mimosa' ? 'section section--mimosa' :
  'section';
---

<section class={`cta-section ${sectionClass}`} aria-labelledby="cta-title">
  <div class="container is-default cta-inner reveal">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2 id="cta-title" class="cta-title" set:html={title} />
    {description && <p class="lead">{description}</p>}
    {(primary || secondary) && (
      <div class="cta-ctas">
        {primary && (
          <a href={primary.href} class="btn btn--primary btn--lg">
            {primary.label}
            <Icon name="arrow-right" size={18} class="arrow" />
          </a>
        )}
        {secondary && (
          <a href={secondary.href} class="btn btn--ghost btn--lg">
            {secondary.label}
            <Icon name="arrow-right" size={18} class="arrow" />
          </a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .cta-inner {
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }
  .cta-title {
    font-size: clamp(1.75rem, 3vw + 1rem, 2.75rem);
    font-weight: 700;
    letter-spacing: var(--tr-tight);
    line-height: 1.1;
    color: var(--ink);
    max-width: 24ch;
  }
  .section--dark .cta-title { color: var(--ivoire); }
  .cta-ctas {
    display: flex;
    gap: var(--s-3);
    flex-wrap: wrap;
    margin-top: var(--s-3);
  }
  .section--dark .btn--ghost {
    color: var(--ivoire);
    border-color: var(--bleu-clair);
  }
  .section--dark .btn--ghost:hover {
    color: var(--mimosa);
    border-color: var(--mimosa);
    background: transparent;
  }
</style>

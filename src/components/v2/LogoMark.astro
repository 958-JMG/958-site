---
/**
 * LogoMark — Le vrai logo 9·58 (PNG transparent généré depuis LOGO958.jpg)
 *
 * Le PNG public/logo-958-official.png a été préparé via scripts/make-logo-transparent
 * (sharp + threshold blanc → alpha 0). Il contient :
 * - Le rounded rect noir comme zone OPAQUE
 * - Les chiffres "9" et "8" en creux (transparent)
 * - Le fond extérieur transparent
 *
 * On l'utilise comme MASK CSS + background-color paramétrable, ce qui
 * permet de recoloriser dynamiquement le badge selon la palette brand.
 * Effet : silhouette du logo officielle + couleur custom + chiffres en
 * "découpe" qui révèlent le fond du parent (effet incrusté).
 *
 * Usage :
 *   <LogoMark />                       (cuivre par défaut sur palette v2c)
 *   <LogoMark height={48} />
 *   <LogoMark color="var(--ivoire)" /> (variante ivoire)
 */
interface Props {
  height?: number;
  /** Couleur du badge (par défaut cuivre brand) */
  color?: string;
  class?: string;
  title?: string;
}

const {
  height = 36,
  color = 'var(--cuivre)',
  class: className = '',
  title = '9·58 — Neuf Cinquante Huit',
} = Astro.props;

// Ratio du PNG : 986 × 1355 (~ 0.728)
const width = Math.round((height * 986) / 1355);
---

<span
  class={`logo-mark ${className}`}
  role="img"
  aria-label={title}
  style={`--logo-w: ${width}px; --logo-h: ${height}px; --logo-color: ${color};`}
>
  <span class="visually-hidden">{title}</span>
</span>

<style>
  .logo-mark {
    display: inline-block;
    width: var(--logo-w);
    height: var(--logo-h);
    background-color: var(--logo-color);
    -webkit-mask: url('/logo-958-official.png') no-repeat center / contain;
            mask: url('/logo-958-official.png') no-repeat center / contain;
    flex-shrink: 0;
  }
  .visually-hidden {
    position: absolute !important;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

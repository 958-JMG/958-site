---
/**
 * LogoMark — Le vrai logo 9·58 (inline SVG, recoloré via CSS vars).
 *
 * Usage :
 *   <LogoMark />                              (cuivre / ivoire par défaut)
 *   <LogoMark height={48} />                  (taille custom)
 *   <LogoMark bg="var(--bg)" fg="var(--cuivre)" /> (couleurs custom)
 *
 * Le SVG existant utilise --mark-bg (rect fond) et --mark-fg (chiffres).
 * On les override via inline style ou via class CSS.
 */
interface Props {
  height?: number;
  /** Fond du badge (intérieur du rounded rect) */
  bg?: string;
  /** Couleur des chiffres "9·8" */
  fg?: string;
  /** Couleur du conteneur extérieur (rect arrondi) — currentColor par défaut */
  border?: string;
  class?: string;
  title?: string;
}

const {
  height = 36,
  bg = 'var(--bg)',
  fg = 'var(--cuivre)',
  border = 'var(--cuivre)',
  class: className = '',
  title = '9·58 — Neuf Cinquante Huit',
} = Astro.props;

// Ratio viewBox 200×300 → 2:3
const width = Math.round((height * 200) / 300);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 200 300"
  width={width}
  height={height}
  class={`logo-mark ${className}`}
  style={`color: ${border}; --mark-bg: ${bg}; --mark-fg: ${fg};`}
  role="img"
  aria-label={title}
>
  <title>{title}</title>
  {/* Container rounded rect — utilise currentColor (héritage style.color) */}
  <rect width="200" height="300" rx="32" fill="currentColor"/>

  {/* 9 (haut) : cercle + stem */}
  <circle cx="110" cy="82" r="56" fill="var(--mark-bg)"/>
  <circle cx="110" cy="82" r="56" fill="none" stroke="var(--mark-fg)" stroke-width="28"/>
  <circle cx="110" cy="82" r="28" fill="var(--mark-bg)"/>
  <rect x="88" y="110" width="44" height="60" fill="var(--mark-fg)"/>

  {/* · (interpunct) */}
  <rect x="40" y="136" width="24" height="24" fill="var(--mark-fg)"/>

  {/* 8 (bas) : cercle ouvert */}
  <circle cx="110" cy="222" r="56" fill="var(--mark-fg)"/>
  <circle cx="110" cy="222" r="28" fill="var(--mark-bg)"/>
  <rect x="138" y="200" width="62" height="44" fill="var(--mark-bg)"/>
  <circle cx="145" cy="250" r="20" fill="var(--mark-bg)"/>
</svg>

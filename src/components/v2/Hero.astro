---
import Icon from './Icon.astro';

interface Props {
  /** Bandeau supérieur (eyebrow) */
  eyebrow?: string;
  /** Titre principal (peut contenir <br>) — passé tel quel */
  title: string;
  /** Lead sous le titre */
  lead?: string;
  /** CTA primaire { label, href } */
  ctaPrimary?: { label: string; href: string };
  /** CTA secondaire (ghost) */
  ctaSecondary?: { label: string; href: string };
  /** Assurances listées sous les CTAs (séparées par · à l'affichage) */
  assurances?: string[];
  /** Variante visuelle */
  variant?: 'default' | 'xl';
}

const {
  eyebrow,
  title,
  lead,
  ctaPrimary,
  ctaSecondary,
  assurances = [],
  variant = 'default',
} = Astro.props;

const titleClass = variant === 'xl' ? 'hero-title-xl' : 'hero-title';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="container">
    {eyebrow && <p class="eyebrow reveal" set:html={eyebrow} />}

    <h1 id="hero-title" class={`${titleClass} reveal`} set:html={title} />

    {lead && <p class="lead reveal" set:html={lead} />}

    {(ctaPrimary || ctaSecondary) && (
      <div class="hero-ctas reveal">
        {ctaPrimary && (
          <a href={ctaPrimary.href} class="btn btn--primary btn--lg">
            {ctaPrimary.label}
            <Icon name="arrow-right" size={18} class="arrow" />
          </a>
        )}
        {ctaSecondary && (
          <a href={ctaSecondary.href} class="btn btn--ghost btn--lg">
            {ctaSecondary.label}
            <Icon name="arrow-right" size={18} class="arrow" />
          </a>
        )}
      </div>
    )}

    {assurances.length > 0 && (
      <ul class="hero-assurances reveal" aria-label="Engagements">
        {assurances.map((a) => <li>{a}</li>)}
      </ul>
    )}
  </div>
</section>

<style>
  .hero {
    padding-block: var(--s-9) var(--s-8);
  }
  .hero .eyebrow {
    margin-bottom: var(--s-5);
  }
  .hero .hero-title,
  .hero .hero-title-xl {
    margin-bottom: var(--s-5);
    max-width: 22ch;
  }
  .hero .lead {
    margin-bottom: var(--s-7);
    max-width: 56ch;
  }
  .hero-ctas {
    display: flex;
    gap: var(--s-3);
    flex-wrap: wrap;
    align-items: center;
  }
  .hero-assurances {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-4);
    margin-top: var(--s-6);
    list-style: none;
    padding: 0;
  }
  .hero-assurances li {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-2);
    letter-spacing: 0.02em;
    position: relative;
    padding-left: 1.1rem;
  }
  .hero-assurances li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    background: var(--bleu);
    border-radius: 50%;
  }

  @media (max-width: 720px) {
    .hero {
      padding-block: var(--s-7) var(--s-6);
    }
    .hero .hero-title,
    .hero .hero-title-xl {
      max-width: 100%;
    }
  }
</style>

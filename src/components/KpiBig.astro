---
// Bloc KPI géant full-bleed. Compteur animé au reveal.
//
// Usage :
//   <KpiBig
//     value={500}
//     prefix="+"
//     label="Personnes formées"
//     sub="Depuis 2022 · PME, grands comptes, ateliers intra-entreprise"
//   />
//
// Le chiffre s'anime de 0 → value au premier passage. Respecte reduced-motion.

interface Props {
  value: number;
  prefix?: string;
  suffix?: string;
  label: string;
  sub?: string;
  variant?: 'default' | 'accent'; // accent = chiffre lime, default = chiffre ink
  duration?: number;              // ms
}

const {
  value,
  prefix = '',
  suffix = '',
  label,
  sub,
  variant = 'default',
  duration = 1800,
} = Astro.props;
---

<section class={`kpi-big kpi-big--${variant}`} aria-label={`${prefix}${value}${suffix} ${label}`}>
  <div class="kpi-big-inner container">
    <p class="kpi-big-label">{label}</p>

    <p
      class="kpi-big-n"
      data-kpi-big
      data-target={value}
      data-prefix={prefix}
      data-suffix={suffix}
      data-duration={duration}
    >
      <span class="kpi-big-prefix">{prefix}</span><span class="kpi-big-num">0</span><span class="kpi-big-suffix">{suffix}</span>
    </p>

    {sub && <p class="kpi-big-sub">{sub}</p>}
  </div>
</section>

<style>
  .kpi-big {
    position: relative;
    padding-block: var(--s-10);
    border-block: 1px solid var(--line);
    overflow: hidden;
  }
  /* Filet lime vertical à gauche du bloc — touche signature */
  .kpi-big::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 1.1s cubic-bezier(.2, .85, .2, 1);
  }
  .kpi-big.is-visible::before { transform: scaleY(1); }

  .kpi-big-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--s-4);
  }

  .kpi-big-label {
    font-family: var(--font-mono);
    font-size: var(--step-0);
    color: var(--ink-3);
    letter-spacing: var(--tr-mono);
    text-transform: uppercase;
  }

  .kpi-big-n {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(5rem, 16vw, 14rem);
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0;
    display: flex;
    align-items: baseline;
    font-variant-numeric: tabular-nums;
  }
  .kpi-big-prefix {
    color: var(--accent);
    font-size: 0.55em;
    line-height: 1;
    margin-right: 0.08em;
    align-self: flex-start;
    padding-top: 0.15em;
  }
  .kpi-big-suffix {
    color: var(--ink-2);
    font-size: 0.55em;
    line-height: 1;
    margin-left: 0.08em;
    align-self: flex-start;
    padding-top: 0.15em;
  }
  .kpi-big--accent .kpi-big-num  { color: var(--accent); }
  .kpi-big--accent .kpi-big-prefix { color: var(--ink); }

  .kpi-big-sub {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-3);
    letter-spacing: var(--tr-wide);
    max-width: 60ch;
    margin-top: var(--s-3);
  }

  @media (max-width: 720px) {
    .kpi-big { padding-block: var(--s-8); }
  }

  @media (prefers-reduced-motion: reduce) {
    .kpi-big::before { transform: scaleY(1); transition: none; }
  }
</style>

<script>
  function easeOutQuart(t: number): number {
    return 1 - Math.pow(1 - t, 4);
  }

  function animateCounter(el: HTMLElement) {
    const target = Number(el.dataset.target || '0');
    const duration = Number(el.dataset.duration || '1800');
    const numNode = el.querySelector('.kpi-big-num') as HTMLElement | null;
    if (!numNode) return;

    const prefersReduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced || target <= 0) {
      numNode.textContent = String(target);
      return;
    }

    const start = performance.now();
    const tick = (now: number) => {
      const t = Math.min(1, (now - start) / duration);
      const eased = easeOutQuart(t);
      const cur = Math.round(target * eased);
      numNode.textContent = cur.toLocaleString('fr-FR');
      if (t < 1) requestAnimationFrame(tick);
      else numNode.textContent = target.toLocaleString('fr-FR');
    };
    requestAnimationFrame(tick);
  }

  function bindKpiBig() {
    const bigs = document.querySelectorAll<HTMLElement>('[data-kpi-big]');
    bigs.forEach((el) => {
      if (el.dataset.bound === '1') return;
      el.dataset.bound = '1';

      const section = el.closest('.kpi-big') as HTMLElement | null;
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              section?.classList.add('is-visible');
              animateCounter(el);
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.35 },
      );
      obs.observe(el);
    });
  }
  bindKpiBig();
  document.addEventListener('astro:page-load', bindKpiBig);
</script>

# 958.fr — Variables d'environnement
# Copier en .env et remplir. Ne JAMAIS commiter le .env.

# URL publique du webhook n8n qui reçoit les demandes de diagnostic
# Le préfixe PUBLIC_ rend la variable accessible côté navigateur
# (le site est statique → l'appel se fait depuis le client)
PUBLIC_N8N_WEBHOOK_DIAGNOSTIC=https://jmg958.app.n8n.cloud/webhook/diagnostic-site

        "jsCode": "// Normalise et valide la payload reçue du site 958.fr\nconst body = $input.first().json.body ?? $input.first().json;\n\nconst required = ['nom', 'entreprise', 'email', 'contexte', 'secteur', 'taille'];\nconst missing = required.filter((k) => !body[k] || String(body[k]).trim() === '');\n\nconst emailOk = typeof body.email === 'string' && /.+@.+\\..+/.test(body.email);\nconst isSpam = Boolean(body.website);\n\nreturn [{\n  json: {\n    valid: missing.length === 0 && emailOk && !isSpam,\n    missing,\n    emailOk,\n    isSpam,\n    nom: String(body.nom ?? '').trim(),\n    entreprise: String(body.entreprise ?? '').trim(),\n    email: String(body.email ?? '').trim(),\n    telephone: String(body.telephone ?? '').trim(),\n    secteur: String(body.secteur ?? '').trim(),\n    taille: String(body.taille ?? '').trim(),\n    contexte: String(body.contexte ?? '').trim(),\n    timestamp: body.timestamp ?? new Date().toISOString(),\n    source: body.source ?? 'site-958',\n    userAgent: body.userAgent ?? '',\n    referrer: body.referrer ?? null,\n  }\n}];"
      },

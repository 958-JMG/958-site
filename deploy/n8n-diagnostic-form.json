        "html": "=<h2>Nouvelle demande de diagnostic</h2>\n<table style=\"font-family: sans-serif; line-height: 1.5;\">\n  <tr><td><strong>Nom</strong></td><td>{{$json.nom}}</td></tr>\n  <tr><td><strong>Entreprise</strong></td><td>{{$json.entreprise}}</td></tr>\n  <tr><td><strong>Email</strong></td><td><a href=\"mailto:{{$json.email}}\">{{$json.email}}</a></td></tr>\n  <tr><td><strong>Téléphone</strong></td><td>{{$json.telephone || '—'}}</td></tr>\n  <tr><td><strong>Secteur</strong></td><td>{{$json.secteur}}</td></tr>\n  <tr><td><strong>Taille</strong></td><td>{{$json.taille}}</td></tr>\n</table>\n<h3>Contexte</h3>\n<p>{{$json.contexte}}</p>\n<hr>\n<p style=\"color:#666;font-size:12px;\">Reçu le {{$json.timestamp}} depuis {{$json.source}}<br>UA : {{$json.userAgent}}<br>Referer : {{$json.referrer || 'direct'}}</p>",
        "options": {
